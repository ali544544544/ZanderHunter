308,"lng":9.272737},{"lat":54.299361,"lng":9.273182},{"lat":54.299729,"lng":9.273502},{"lat":54.299965,"lng":9.273802},{"lat":54.300427,"lng":9.274349},{"lat":54.300972,"lng":9.274655},{"lat":54.301166,"lng":9.274617},{"lat":54.301764,"lng":9.274435},{"lat":54.302127,"lng":9.274097},{"lat":54.302621,"lng":9.273491},{"lat":54.303028,"lng":9.272236},{"lat":54.303219,"lng":9.270127},{"lat":54.303191,"lng":9.265637},{"lat":54.303272,"lng":9.26405},{"lat":54.303786,"lng":9.26229},{"lat":54.30428,"lng":9.261239},{"lat":54.305119,"lng":9.260488},{"lat":54.305914,"lng":9.260176},{"lat":54.30803,"lng":9.259608}]],"polygons":[[{"lat":54.297049,"lng":9.267952},{"lat":54.296984,"lng":9.267935},{"lat":54.296981,"lng":9.26803},{"lat":54.297047,"lng":9.268038}],[{"lat":54.305676,"lng":9.258767},{"lat":54.305461,"lng":9.258886},{"lat":54.305526,"lng":9.259074},{"lat":54.305679,"lng":9.258975}]],"source":"hejfish_api_map_geojson","confidence":"high"},"links":{"source":"https://www.hejfish.com/d/14815-eider-bei-erfde-km-47-0-52-0","hejfish":"https://www.hejfish.com/d/14815-eider-bei-erfde-km-47-0-52-0","alleangeln":null,"website":null,"image":"https://file.hejfish.com/image/cc1200x900/65/ab/65abb22f3a24d5053d055b1ca12884e72fa52b50.jpeg"},"fish":["Aal","Aland","Brasse","Giebel","Güster","Hecht","Karpfen","Rapfen","Rotauge","Rotfeder","Schleie","Zander","Wels","Flussbarsch","Karausche","Kaulbarsch"],"metadata":{"platform":"hejfish","geocode_source":"hejfish_api_map_geojson","slug":"eider-bei-erfde-km-47-0-52-0","seo_name":"Eider bei Erfde (km 47,0 - 52,0)","description":"<p><b>Barrierefreier Angelplatz! (54.29703, 9.26799) In der interaktiven Karte ist der Angelplatz blau eingezeichnet! <br>(500 m) von Eiderstraße 23 in Erfde. Weitere Informationen finden Sie hier: <a href=\"http://daten2.verwaltungsportal.de/dateien/seitengenerator/6f2a590d1b2fc5bbd3d62342970b9a51214573/steckbrief_eider_bargen.pdf\">Klick</a></b></p> <p><b>Weiterer barrierefreier Angelplatz (54.30564, 9.25890)! Eiderstraße 19, 25788 Delve. Weitere Informationen finden Sie hier: <a href=\"http://daten2.verwaltungsportal.de/dateien/seitengenerator/6f2a590d1b2fc5bbd3d62342970b9a51214573/steckbrief_eider_delve.pdf\">Klick</a></b></p> <p><b>Weitere barrierefreie Angelplätze finden Sie hier: <a href=\"https://www.hejfish.com/search?term=barrierefrei\">Klick</a></b><br></p> <p>Die Eider ist der längste und fischreichste Fluss in Schleswig-Holstein. Sie fließt von Ost nach West quer durch Schleswig-Holstein und mündet beim Eidersperrwerk in die Nordsee. Von der Einmündung des Gieselau-Kanals ca. 20km südwestlich Rendsburg bis zur Mündung ist die Eider eine Bundeswasserstrasse und es gilt die Seeschifffahrtsstraßen-Ordnung.</p> <p>Nachdem die Mitteleider ab Rendsburg zunächst mit Breiten um die 50m und flachem Wasser beginnt erreicht sie im im weiteren Verlauf Breiten von bis zu 200m und Tiefen von bis zu 20m.</p>","borders":"<p>Von KM 47 durch Kilometerstein (54.277983,9.285531) bis KM 52 durch Kilometerstein (54.307982,9.258903)<br></p>","techniques":["Ansitzangeln","Oberflächenangeln","Spinnangeln","Stippangeln","Fliegenfischen","Vertikal"],"rules_text":"<p style=\"margin: 0px;\" align=\"left\"><b>Der Erlaubnisschein ist nur gültig in Verbindung mit einem Fischereischein mit gültiger Fischereiabgabe-Marke!\r\n</b></p><p style=\"margin: 0px;\" align=\"left\"><b>Die/der Scheininhaber*in erhält die Erlaubnis erteilt, den Fischfang mit 3 Handangeln und einer Köderfischsenke von 1 x 1 m auszuüben.</b></p><p style=\"margin: 0px;\" align=\"left\"><b><br></b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\"><b>Es ist verboten:</b></p><p style=\"margin: 0px;\" align=\"left\"><b><br></b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\">1.\tmit mehr als 3 Angeln mit max. 2 Haken pro Angel zu fischen,\r\n</p><p style=\"margin: 0px;\" align=\"left\">2.\tdie Schleppangelei zu betreiben&nbsp; (Boote, auch Bellyboote u.ä. Fahrzeuge, müssen während des Angelns festgelegt sein, die Verwendung von E-Motoren mit GPS-Ankerfunktion ist <u>nicht </u>erlaubt!)</p><p style=\"margin: 0px;\" align=\"left\">3.\tin Schöpfwerksausläufen, an / von Brücken zu fischen.<br>4. beim Fischfang elektronische Hilfsmittel (z.B. Fischfinder, Live-Sonar-Technologie o.ä.) zu verwenden, die Verwendung von Bissanzeigern ist erlaubt.&nbsp;</p><p style=\"margin: 0px;\" align=\"left\"><b><br></b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\"><b>Zur Bestandsschonung ist das Angeln mit Kunstködern sowie totem Köderfisch vom 01.01. bis einschließlich 15.05. untersagt.</b></p><p style=\"margin: 0px;\" align=\"left\"><b><br></b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\"><b>Mindestmaße und Schonzeiten:\r\n</b></p><p style=\"margin: 0px;\" align=\"left\">Aal: 50 cm, Karpfen: 35 cm, Rapfen: 50 cm, Schleie: 25 cm\r\n</p><p style=\"margin: 0px;\" align=\"left\">Zander:\t45 cm (15.03.– 15.05.)\r\n</p><p style=\"margin: 0px;\" align=\"left\">Hecht:\t45 cm (15.02.– 15.04.)\r\n</p><p style=\"margin: 0px;\" align=\"left\">Meerforelle: 40 cm (01.10.– 28.02.)\r\n</p><p style=\"margin: 0px;\" align=\"left\">Lachs:\t60 cm (01.10.– 28.02.)\r\n</p><p style=\"margin: 0px;\" align=\"left\">Es gilt immer die aktuellste Fassung des Landesfischereigesetzes Schleswig-Holstein und weiter die in der schleswig-holsteinischen Binnenfischereiverordnung (BiFVO) festgelegten Mindestmaße und Schonzeiten.</p><p style=\"margin: 0px;\" align=\"left\"><br></p><p style=\"margin: 0px;\" align=\"left\">\r\n</p><p style=\"margin: 0px;\" align=\"left\"><b>Fangbegrenzung für Zander: 3 Stück pro Tag</b></p><p style=\"margin: 0px;\" align=\"left\"><b><br></b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\">Das Kontingent ist nicht übertragbar oder anrechenbar auf andere Angler. Darüber hinaus müssen grundsätzlich alle gefangenen Fische, die das vorgeschriebene Mindestmaß erreicht haben, mitgenommen werden.</p><p style=\"margin: 0px;\" align=\"left\"><b><br></b></p><p style=\"margin: 0px;\" align=\"left\">Der/die<b> Inhaber*in</b> <b>ist verpflichtet</b>, eine <b>Fangmeldung </b>sorgfältig und vollständig zu erstellen und spätestens am Jahresende an den Pächter <b>zurückzugeben</b>!</p><p style=\"margin: 0px;\" align=\"left\"><b><br></b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\">Die Fangmeldung ist die   wichtigste Grundlage für den Besatz und für die Beweisführung in Schadensfällen.\r\n</p><p style=\"margin: 0px;\" align=\"left\"><b><br></b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p>","rules_files":[{"id":446748,"name":"eider-bei-erfde-km-47-0-52-0-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/a0e14bcb04008657a9338008d51a05440ae0c497/eider-bei-erfde-km-47-0-52-0-bestimmungen.pdf"},{"id":446749,"name":"eider-bei-erfde-km-47-0-52-0-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/f500e9654a28f4a047055dc87c126b758db159b3/eider-bei-erfde-km-47-0-52-0-bestimmungen.pdf"},{"id":446750,"name":"eider-bei-erfde-km-47-0-52-0-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/d6567c58dd01df44f51c1da8ad0fc19e439ca248/eider-bei-erfde-km-47-0-52-0-bestimmungen.pdf"}],"tickets":[{"name":"7-Tage-Erlaubnisschein mit Boot - Jugendpreis inkl. 3,00€ Servicegebühr","price":"12,00 EUR","ticket_type_id":7388,"price_id":101746},{"name":"7-Tage-Erlaubnisschein mit Boot - Normalpreis inkl. 3,00€ Servicegebühr","price":"21,00