Plan unter vorhandene Datei, Bestimmungen) </p> <p>Anfüttern verboten.</p>","borders":"<p>Düsseldorfer Hafen mit Hafenbecken A, B, C und Lausward  II, mit Westufer und Hafeneinfahrt. Im Handels- und Zollhafen (Marina) ist das Angeln nicht erlaubt.</p>","techniques":["Ansitzangeln","Fliegenfischen","Posenangeln","Spinnangeln","Raubfischangeln","Friedfischangeln"],"manager":{"id":1983,"name":"Ferienkarte Rheinischer Fischereiverband von 1880 e.V. / Rheinfischereigenossenschaft im Lande NRW","street":"Wahnbachtalstrasse 13a","postal_code":"53721 ","city":"Siegburg","telephone":"","email":"Info@rhfv.de","website":"","logo":"https://file.hejfish.com/image/r200x200/d7/23/d7236a5b65fd41f01fc9fa04541d468756e41477.jpg","slug":"ferienkarte-rheinischer-fischereiverband-von-1880-e-v-rheinfischereigenossenschaft-im-lande-nrw"},"season_begin":"0001-04-12","season_end":"0001-04-27","features":{"accessible":false,"public_transport":false,"boat":false,"belly_boat":false,"digital_ticket":false,"night_fishing":true,"ice_fishing":false,"depth_map":true,"has_gauges":false},"location":{"city":{"id":17049,"name":"Düsseldorf"},"district":{"id":243,"name":"Düsseldorf"},"state":{"id":21,"name":"Nordrhein-Westfalen","slug":"nordrhein-westfalen"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"source_last_updated":"2026-05-07T11:46:44.119Z","error":false},"last_updated":"2026-05-07T11:46:44.119Z"}