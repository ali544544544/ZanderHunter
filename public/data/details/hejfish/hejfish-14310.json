d alle Angelstellen von Nr. 2 - Nr. 80, welche nummeriert sind.</p> <p>Weiterhin ist die maximale Futtermenge auf 1kg pro Wurfrute und Tag beschränkt. </p>","borders":"<p><b>Schongebiet beachten, Siehe Bestimmungen!</b></p>","techniques":["Ansitzangeln","Feedern","Posenangeln","Spinnangeln"],"manager":{"id":1875,"name":"Magdeburger Anglerverein e. V. - INAKTIV","street":"Beimsstr. 89 a ","postal_code":"39110","city":"Magdeburg","telephone":"+49 391 8113033","email":"info@magdeburger-anglerverein.de","website":"https://www.magdeburger-anglerverein.de/","logo":"https://file.hejfish.com/image/r200x200/63/1a/631a65e4dfec68285fa47ba582239e084f563a01.jpeg","slug":"magdeburger-anglerverein-e-v-inaktiv"},"season_begin":"0001-01-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":false,"boat":false,"belly_boat":false,"digital_ticket":true,"night_fishing":true,"ice_fishing":false,"depth_map":true,"has_gauges":false},"location":{"city":{"id":16887,"name":"Magdeburg"},"district":{"id":239,"name":"Magdeburg"},"state":{"id":17,"name":"Sachsen-Anhalt","slug":"sachsen-anhalt"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"source_last_updated":"2026-05-07T11:44:14.747Z","error":false},"last_updated":"2026-05-07T11:44:14.747Z"}