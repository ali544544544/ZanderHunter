 Plan und die örtliche Beschilderung beachten!!! Neben dem Erlaubnisschein ist ein gültiger Fischereischein erforderlich!  Der  Jugendfischereierlaubnisschein berechtigt zur Ausübung des Fischfangs nur in verantwortlicher Begleitung eines volljährigen Inhabers eines Fischereischeins.<br></p>","rules_files":[{"id":1079486,"name":"oeberauer-schleife-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/6a8d6c854e0725c0b87f32f869a1524c269bddb3/oeberauer-schleife-bestimmungen.pdf"},{"id":1079487,"name":"oeberauer-schleife-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/243d771d09579f6de9b0390904b8ccc2a5f7cee5/oeberauer-schleife-bestimmungen.pdf"},{"id":1383928,"name":"oeberauer-schleife-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/69bf69f4cd5035c626d76f8c52c3267dff0e39ba/oeberauer-schleife-bestimmungen.pdf"}],"tickets":[{"name":"Tageskarte Gast - Normalpreis inkl. Servicegebühr","price":"28,00 EUR","ticket_type_id":7729,"price_id":91922}],"manager":{"id":1989,"name":"Bezirksfischereiverein Straubing e.V.","street":"Wundermühlweg 7","postal_code":"94315","city":"Straubing","telephone":"+49 9421 8610551","email":"Vorstand@bfv-sr.de","website":"https://www.bfv-sr.de/","logo":"https://file.hejfish.com/image/r200x200/02/3c/023c39037f3448930ca0283b8d16927b40ed8435.jpg","slug":"bezirksfischereiverein-straubing-e-v"},"season_begin":"0001-01-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":false,"boat":false,"belly_boat":false,"digital_ticket":true,"night_fishing":true,"ice_fishing":false,"depth_map":true,"has_gauges":true},"location":{"city":{"id":35073,"name":"Straubing"},"district":{"id":463,"name":"Straubing"},"state":{"id":10,"name":"Bayern","slug":"bayern"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"source_last_updated":"2026-05-07T11:44:56.260Z","error":false},"last_updated":"2026-05-07T11:44:56.260Z"}