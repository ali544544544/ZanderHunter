g":11.706946},{"lat":52.105239,"lng":11.707015},{"lat":52.105261,"lng":11.70709},{"lat":52.105328,"lng":11.707171},{"lat":52.105375,"lng":11.707213},{"lat":52.105445,"lng":11.707217},{"lat":52.105453,"lng":11.707136}]],"source":"hejfish_api_map_geojson","confidence":"high"},"links":{"source":"https://www.hejfish.com/d/14317-4-kolke-am-klusdamm","hejfish":"https://www.hejfish.com/d/14317-4-kolke-am-klusdamm","alleangeln":null,"website":null,"image":null},"fish":["Aal","Hecht","Karpfen","Schleie","Brasse","Döbel","Giebel","Karausche","Rotauge","Rotfeder","Laube"],"metadata":{"platform":"hejfish","geocode_source":"hejfish_api_map_geojson","slug":"4-kolke-am-klusdamm","seo_name":"4 Kolke am Klusdamm","description":"<p><b>Die Gewässer </b></p> <p><b>13 - 280 - 12 Dreier Kolke bei Zipkeleben<br>13 - 280 - 14 Vier Kolke am Klusdamm</b></p> <p><b>werden hier zur besseren Übersicht gemeinsam beschrieben.</b> </p> <div><b>Lage</b>:</div> <div>Die Kolke liegen im Südosten der Stadt Magdeburg.</div> <div>Die Dreier Kolke befinden sich im Stadtteil Zipkeleben, die Vier Kolke südlich davon zwischen Zipkleben und Pechau am Klusdammradweg.</div> <div><br></div> <div><b>Besonderheiten</b>:</div> <div>Diese Gewässer sind Restlöcher ehemaliger Elbarme im Überflutungsgebiet der Elbe, die durch Kiesgewinnung vertieft wurden. Die Dreier Kolke haben eine Wasserfläche von 0,55 ha, die vier Kolke am Klusdamm haben zusammen 0,25 ha.</div> <div><b>Die Dreierkolke</b> liegen neben einer vor ca. 40 Jahren entstandenen, durch Zaun und Tor abgegrenzten Anglersiedlung. Das Tor ist meist geöffnet, das Gelände kann betreten, aber nicht befahren werden. Geangelt wird überwiegend von den am Ufer errichteten privaten Angelstegen, die von allen Anglern mit gültiger Fischereierlaubnis benutzt werden dürfen. Die bis 3 m hohen Steilufer gehen im Wasser weiter steil abwärts auf 2,5 bis max. 3,5 m Tiefe. Der Grund im Teil 1 ist sauber, im Teil 2 wuchern im Sommer dichte Krautfelder. <br>Von den <b>Vier Kolken am Klusdamm </b>ist vor allem der Lieschenkolk (auch Paradieskolk) für Angler interessant. Er ist mit Fahrzeugen gut zu erreichen, die auf der südlich des Sees liegenden Wiese in unmittelbarer Nähe abgestellt werden können. Die 2 - 3 m hohen Steilufer setzen sich unter Wasser weiter fort. Die maximale Tiefe beträgt 2,8 m. Der Grund ist weitgehend frei von Krautfeldern. Der Lieschenkolk erhält regelmäßig Fischbesatz.</div> <div><br></div> <div><b>Erreichbarkeit</b>:</div> <div><b>Die Dreier Kolke</b> erreicht man über Cracau, fährt auf der <i><b>Pechauer Str</b></i>., biegt am <i><b>Pechauer Platz</b></i> auf den <i><b>Klusdamm </b></i>und davon nach links in den <i><b>Zipkeleber Weg</b></i> ein, der bei Zipkeleben in den <i><b>Stadtweg </b></i>übergeht. Davon rechts abbiegen, nach ca. 250 m ist man an den Dreierkolken. Vor und hinter dem Tor bestehen mehrere Parkmöglichkeiten.</div> <div><b>Die Kolke am Klusdamm </b>erreicht man von Cracau aus entweder, wenn man vom <i><b>Pechauer Platz</b></i> den <i><b>Klusdamm </b></i>bis zum Ende und den anschließenden Fahrweg weiter bis zur Gabelung fährt. Der nach rechts abbiegende <i><b>Klusdammradweg</b></i> führt an die Vier Kolke, ist aber durch Hindernisse am Wegbeginn für Kraftfahrzeuge versperrt.</div> <div>Alternativ fährt man von Cracau über Prester nach Pechau, biegt dort links in den Ort ein, fährt über die <i><b>Hauptstraße </b></i>links in die Straße <i><b>Am See</b></i> bis zur Kreuzung <i><b>Zur Mühle</b></i>. Dort beginnt links der <i><b>Klusdammradweg</b></i>, der zu den Kolken führt.</div> <div><br></div> <div><b>Beangelbare Fischarten:</b></div> <div><u>Hauptfischarten</u>: Aal, Hecht, Karpfen, Schleie.</div> <div><u>Weitere beangelbare Arten</u>: Blei (Brasse), Döbel, Giebel, Karausche, Plötze, Rotfeder, Ukelei</div>","borders":"<p><b>Die gesamten Gewässer dürfen befischt werden. </b></p>","techniques":["Ansitzangeln","Feedern","Posenangeln","Spinnangeln","Friedfischangeln","Karpfenangeln","Naturköderangeln","Raubfischangeln","Stippangeln"],"manager":{"id":1875,"name":"Magdeburger Anglerverein e. V. - INAKTIV","street":"Beimsstr. 89 a ","postal_code":"39110","city":"Magdeburg","telephone":"+49 391 8113033","email":"info@magdeburger-anglerverein.de","website":"https://www.magdeburger-anglerverein.de/","logo":"https://file.hejfish.com/image/r200x200/63/1a/631a65e4dfec68285fa47ba582239e084f563a01.jpeg","slug":"magdeburger-anglerverein-e-v-inaktiv"},"season_begin":"0001-01-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":false,"boat":false,"belly_boat":false,"digital_ticket":true,"night_fishing":true,"ice_fishing":false,"depth_map":true,"has_gauges":false},"location":{"city":{"id":16881,"name":"Magdeburg"},"district":{"id":239,"name":"Magdeburg"},"state":{"id":17,"name":"Sachsen-Anhalt","slug":"sachsen-anhalt"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"source_last_updated":"2026-05-07T11:44:15.662Z","error":false},"last_updated":"2026-05-07T11:44:15.662Z"}