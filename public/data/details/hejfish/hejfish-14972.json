{"id":"hejfish-14972","source_platform":"hejfish","source_ids":{"hejfish":14972},"name":"Helser Kattrepler Fleet","water_type":"Fluss","country":"DE","center":{"lat":53.914737,"lng":9.141909,"source":"hejfish_api_map","confidence":"high"},"geometry":{"points":[{"lat":53.914737,"lng":9.141909},{"lat":53.932599,"lng":9.111704}],"lines":[],"polygons":[],"source":"hejfish_api_map","confidence":"medium"},"links":{"source":"https://www.hejfish.com/d/14972-helser-kattrepler-fleet","hejfish":"https://www.hejfish.com/d/14972-helser-kattrepler-fleet","alleangeln":null,"website":null,"image":"https://file.hejfish.com/image/cc1200x900/dc/b1/dcb11355155d1967d0c0f83d9a565eecad8a56af.jpg"},"fish":["Aal","Aland","Brasse","Döbel","Flussbarsch","Giebel","Amur","Gründling","Güster","Hecht","Karausche","Kaulbarsch","Rapfen","Rotauge","Rotfeder","Schleie","Schuppenkarpfen","Spiegelkarpfen","Laube","Zander"],"metadata":{"platform":"hejfish","geocode_source":"hejfish_api_map","slug":"helser-kattrepler-fleet","seo_name":"Helser Kattrepler Fleet","description":"<h4><b>Kunstköderangeln (Blinker, Wobbler und Gummifisch) ist nur für Mitglieder erlaubt.</b></h4>","borders":"<p>Gewässer-Grenzen siehe Bestimmungen.</p>\n\n<h4><b>Kunstköderangeln (Blinker, Wobbler und Gummifisch) ist nur für Mitglieder erlaubt.</b><br></h4>","techniques":["Ansitzangeln","Naturköderangeln","Posenangeln","Spinnangeln"],"rules_text":"<p><b><u>Bestimmungen AV Brunsbüttel e.V. 1934</u></b></p><ol><li>Den Anordnungen der Kontrollorgane ist Folge zu leisten.</li><li>Diese Erlaubnis erstreckt sich auf 3 Handangeln oder 1 Köderfischsenke (1x1m).</li><li>Kunstköderangeln (Blinker, Wobbler und Gummifisch) ist nur für Mitglieder erlaubt.</li><li>Diese Erlaubnis ist nicht übertragbar und nur mit gültigen Angelpapieren gültig.</li><li>Pachtgewässer: Große Braake, Leher Querwegsfleet, Eddelaker Hauptfleet, Vorfluter 02 an der B5 (nicht auf der KKB Seite) Helser Kattrepler Fleet, Schälgraben.</li><li>Es dürfen zum Fischfang keine Fahrzeuge (Boote und Bellyboote) eingesetzt werden.</li><li>Köderfischsenken bei gleichzeitigem angeln ist nicht erlaubt.</li><li>Die Tagesfangmenge für Karpfen, Hecht und Zander ist auf 2 Stück je Art begrenzt.</li><li>Mindestmaße und Schonzeiten:<br>Aal 50cm<br>Karpfen 40cm<br>Hecht 65cm // 15.02. - 15.04.<br>Schleie 30cm<br>Zander 45cm // 15.03 - 15.05.</li></ol><p><br></p><p><br></p><p><br></p>","rules_files":[{"id":539123,"name":"helser-kattrepler-fleet-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/38555de66120c27196e9b7233acf49560dbb3742/helser-kattrepler-fleet-bestimmungen.pdf"}],"tickets":[{"name":"Tageskarte - Normalpreis inkl. Servicegebühr","price":"13,00 EUR","ticket_type_id":7774,"price_id":102137},{"name":"Wochenkarte - Normalpreis inkl. Servicegebühr","price":"33,00 EUR","ticket_type_id":7775,"price_id":102138},{"name":"Monatskarte - Normalpreis inkl. Servicegebühr","price":"55,00 EUR","ticket_type_id":7777,"price_id":102141}],"manager":{"id":1992,"name":"Angelverein Brunsbüttel e.V. ","street":"Berliner Str. 3 ","postal_code":"25541","city":"Brunsbüttel","telephone":"+49 4852 9374","email":"","website":"http://www.angelverein-brunsbuettel.de/","logo":"https://file.hejfish.com/image/r200x200/e5/0c/e50c07d6bba13cbedec3fe705c6346e72239d355.png","slug":"angelverein-brunsbuettel-e-v"},"season_begin":"0001-01-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":false,"boat":false,"belly_boat":false,"digital_ticket":false,"night_fishing":true,"ice_fishing":false,"depth_map":true,"has_gauges":false},"location":{"city":{"id":11167,"name":"Brunsbüttel"},"district":{"id":166,"name":"Kreis Dithmarschen"},"state":{"id":25,"name":"Schleswig-Holstein","slug":"schleswig-holstein"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"source_last_updated":"2026-05-07T11:44:58.559Z","error":false},"last_updated":"2026-05-07T11:44:58.559Z"}