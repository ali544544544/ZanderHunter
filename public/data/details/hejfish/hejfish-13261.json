des Donaueinzugsgebietes. Neben Brassen, Zährten, Nerflingen oder Rotaugen gibt es Raubfische wie Barsche, Waller, Hecht und Zander. </p>","techniques":["Ansitzangeln","Feedern","Fliegenfischen","Friedfischangeln","Posenangeln","Raubfischangeln","Spinnangeln"],"rules_files":[{"id":1414833,"name":"tageskarte-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/2d5ae19a886062d6128bb31afaf13b7f3989a5bc/tageskarte-bestimmungen.pdf"}],"tickets":[{"name":"Tageskarte - Normalpreis inkl. Servicegebühr","price":"20,00 EUR","ticket_type_id":3275,"price_id":95367}],"manager":{"id":1798,"name":"Anglerbund Regensburg","street":"Belgrader Str. 6","postal_code":"93055 ","city":"Regensburg","telephone":"0049 160 90590430","email":"angler@angler-regensburg.de","website":"http://www.angler-regensburg.de/","logo":"https://file.hejfish.com/image/r200x200/33/b8/33b888417c93469f6610ebe757fca24c912225e0.jpeg","slug":"anglerbund-regensburg"},"season_begin":"0001-01-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":true,"boat":false,"belly_boat":false,"digital_ticket":true,"night_fishing":true,"ice_fishing":false,"depth_map":false,"has_gauges":true},"location":{"city":{"id":34720,"name":"Maxhütte-Haidhof"},"district":{"id":455,"name":"Kreis Schwandorf"},"state":{"id":10,"name":"Bayern","slug":"bayern"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"source_last_updated":"2026-05-07T11:42:22.081Z","error":false},"last_updated":"2026-05-07T11:42:22.081Z"}