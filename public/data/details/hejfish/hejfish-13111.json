0/7f/e9/7fe9b82aec17c0899f28c6d47ed3eefd73a063f7.jpeg"},"fish":["Karpfen","Schleie","Hecht","Zander","Aal","Wels"],"metadata":{"platform":"hejfish","geocode_source":"hejfish_api_map_geojson","slug":"haidenaab","seo_name":"Haidenaab","description":"<p>Ihren Namen hat die Haidenaab von der Haidenlandschaft im Quellgebiet. Der Fluss entspring im Landkreis Bayreuth, etwa sieben Kilometer nördlich von Speichersdorf. Nach etwa 60 Kilometern verbindet sie sich bei Unterwildenau mit der Waldnaab und wird zur Naab. Unseren Abschnitt findet ihr bei Etzenricht.<br></p>","borders":"<p>Gewässer-Grenze: Ufer<br></p>","techniques":["Ansitzangeln","Feedern","Friedfischangeln","Karpfenangeln","Posenangeln","Raubfischangeln","Spinnangeln"],"rules_text":"<p><u><b>Gewässerordnung und Gewässerspezifische Regelungen entnehmen Sie dem PDF.<br></b></u></p><p><u>Abweichende Schonzeiten &amp; Mindestmaße:</u></p>\r\n\r\n<style type=\"text/css\">\r\n\ttable.tableizer-table {\r\n\t\tfont-size: 10px;\r\n\t\tborder: 1px solid #000; \r\n\t\tfont-family: Arial, Helvetica, sans-serif;\r\n\t} \r\n\t.tableizer-table td {\r\n\t\tpadding: 1px;\r\n\t\tmargin: 1px;\r\n\t\tborder: 1px solid #000;\r\n\t}\r\n\t.tableizer-table th {\r\n\t\tbackground-color: #00C1D6; \r\n\t\tcolor: #000;\r\n\t\tfont-weight: bold;\r\n\t}\r\n</style>\r\n<table class=\"tableizer-table\">\r\n<thead><tr class=\"tableizer-firstrow\"><th>Fischart</th><th>Schonmaß in cm</th><th>Schonzeit</th></tr></thead><tbody>\r\n <tr><td>Bachforelle </td><td>28*</td><td>01.10. bis einschl. 15.03</td></tr>\r\n <tr><td>Regenbogenforelle</td><td>28*</td><td>15.12. bis einschl. 15.03.</td></tr>\r\n <tr><td>Äsche</td><td>35*</td><td>01.01. bis einschl. 30.04</td></tr>\r\n <tr><td>Äsche (Nur Wiesent)</td><td>45*</td><td>01.12. bis einschl. 30.04.</td></tr>\r\n <tr><td>Barbe</td><td>40 bzw. 50* (Schwarzach)</td><td>01.05. bis einschl. 30.06.</td></tr>\r\n <tr><td>Hecht und Zander</td><td>50</td><td>15.02. bis einschl. 30.04.</td></tr>\r\n <tr><td>Rutte</td><td>40 bzw. 45* (Schwarzach)</td><td>keine</td></tr>\r\n <tr><td>Aal</td><td>50</td><td>01.11. bis einschl. 28.02.</td></tr>\r\n <tr><td>Schleie</td><td>28*</td><td>01.05. bis einschl. 30.06.</td></tr>\r\n <tr><td>Karpfen</td><td>35</td><td>keine</td></tr>\r\n</tbody></table>\r\n\r\n<p>*In Abstimmung&nbsp;mit der Fachberatung für Fischerei<br>Des Weiteren gelten die Schonmaße und die Schonzeiten des Bayerischen Fischereigesetzes und der entsprechenden Bezirksfischereiverordnungen. Während der Raubfisch Schonzeit ist das Spinnangeln verboten.</p><p><u><b>Fanglimit pro Tag&nbsp;</b></u><br></p><ul><li>1 Stück Karpfen</li><li>2 Stück Schleie</li><li>1 Stück Hecht oder Zander*&nbsp;&nbsp;</li><li>2 Stück Aal</li><li>1 Stück Waller</li><li>2 Stück Salmoniden Schonzeit: Bachforelle</li></ul><p><i>*Keine Beschränkung auf Hecht oder Zander an den Gewässern Schwarzach/Gsteinach, die Wiesent, Schwarzach/Burgthann und Schwarzach Rasch/Gründsberg</i></p><p><b>Liebe Fischerkollegen, \r\n</b></p><p>es freut uns sehr, dass Sie ein paar schöne Stunden an unserem Gewässer verbringen möchten.\r\n</p><p>Hier einige Worte, über die jeder mal für sich nachdenken sollte:\r\n</p><p>An unseren Gewässern suchen wir Erholung und Entspannung.\r\n</p><p>Unsere knapp bemessene Freizeit wollen wir sinnvoll gestalten und die Stunden am Wasser dazu nutzen, um wieder Kontakt mit der Natur zu knüpfen, der in der Hektik des Alltags verloren zu gehen droht.\r\n</p><p>Um diese Erwartungen erfüllen zu können, sollte sich jeder Angler am Gewässer und in der ihn umgebenden Landschaft so verhalten, als sei dieses Gebiet sein Eigentum, das er nach besten Kräften schonen, hegen und vor Beschädigung und Verunreinigung schützen muss.\r\n</p><p>Sie leisten damit auch einen erheblichen Beitrag zur Verwirklichung und Umsetzung eines unserer Leitziele, nämlich des Umweltschutzes.\r\n</p><p>Vielen Dank,\r\n</p><p>ihr Fischereiverein Altdorf</p><p><i>\r\n</i></p><p><i>\r\n</i></p><p><i>\r\n</i></p><p></p><style type=\"text/css\">\r\n\ttable.tableizer-table {\r\n\t\tfont-size: 12px;\r\n\t\tborder: 1px solid #000; \r\n\t\tfont-family: Arial, Helvetica, sans-serif;\r\n\t} \r\n\t.tableizer-table td {\r\n\t\tpadding: 4px;\r\n\t\tmargin: 3px;\r\n\t\tborder: 1px solid #000;\r\n\t}\r\n\t.tableizer-table th {\r\n\t\tbackground-color: #104E8B; \r\n\t\tcolor: #FFF;\r\n\t\tfont-weight: bold;\r\n\t}\r\n</style>","rules_files":[{"id":422233,"name":"haidenaab-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/56ca23bf1ec616c205a71d413179a32007a6d7ff/haidenaab-bestimmungen.pdf"}],"tickets":[{"name":"Tageskarte - Normalpreis inkl. Servicegebühr","price":"18,00 EUR","ticket_type_id":3026,"price_id":92301},{"name":"Tageskarte - Jugendpreis inkl. Servicegebühr","price":"10,50 EUR","ticket_type_id":3026,"price_id":92303}],"manager":{"id":1752,"name":"Fischereiverein Altdorf b. Nürnberg","street":"Altdorfer Str. 3","postal_code":"90559","city":"Burgthann","telephone":"","email":"tageskarte@fischereiverein-altdorf.de","website":"https://www.fischereiverein-altdorf.com","logo":"https://file.hejfish.com/image/r200x200/83/1e/831e4c7fc70d23db8e2cac4dc41f213d582abea0.jpeg","slug":"fischereiverein-altdorf-b-nuernberg"},"season_begin":"0001-01-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":false,"boat":false,"belly_boat":false,"digital_ticket":true,"night_fishing":true,"ice_fishing":false,"depth_map":false,"has_gauges":true},"location":{"city":{"id":34497,"name":"Etzenricht"},"district":{"id":450,"name":"Kreis Neustadt an der Waldnaab"},"state":{"id":10,"name":"Bayern","slug":"bayern"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"source_last_updated":"2026-05-07T11:42:06.577Z","error":false},"last_updated":"2026-05-07T11:42:06.577Z"}