; margin: 1px; border: 1px solid rgb(0, 0, 0);\">50 cm</td><td style=\"padding: 1px; margin: 1px; border: 1px solid rgb(0, 0, 0); text-align: center;\">--</td></tr><tr><td style=\"padding: 1px; margin: 1px; border: 1px solid rgb(0, 0, 0);\">Barsch</td><td style=\"padding: 1px; margin: 1px; border: 1px solid rgb(0, 0, 0);\">15 cm</td><td style=\"padding: 1px; margin: 1px; border: 1px solid rgb(0, 0, 0); text-align: center;\">--</td><td style=\"padding: 1px; margin: 1px; border: 1px solid rgb(0, 0, 0);\">Rotauge</td><td style=\"padding: 1px; margin: 1px; border: 1px solid rgb(0, 0, 0);\">20 cm</td><td style=\"padding: 1px; margin: 1px; border: 1px solid rgb(0, 0, 0); text-align: center;\">--</td></tr><tr><td style=\"padding: 1px; margin: 1px; border: 1px solid rgb(0, 0, 0);\">Brasse</td><td style=\"padding: 1px; margin: 1px; border: 1px solid rgb(0, 0, 0);\">25 cm</td><td style=\"padding: 1px; margin: 1px; border: 1px solid rgb(0, 0, 0); text-align: center;\">--</td><td style=\"padding: 1px; margin: 1px; border: 1px solid rgb(0, 0, 0);\">Rotfeder</td><td style=\"padding: 1px; margin: 1px; border: 1px solid rgb(0, 0, 0);\">20 cm</td><td style=\"padding: 1px; margin: 1px; border: 1px solid rgb(0, 0, 0); text-align: center;\">--</td></tr><tr><td style=\"padding: 1px; margin: 1px; border: 1px solid rgb(0, 0, 0);\">Döbel</td><td style=\"padding: 1px; margin: 1px; border: 1px solid rgb(0, 0, 0);\">25 cm</td><td style=\"padding: 1px; margin: 1px; border: 1px solid rgb(0, 0, 0); text-align: center;\">--</td><td style=\"padding: 1px; margin: 1px; border: 1px solid rgb(0, 0, 0);\">Schleie</td><td style=\"padding: 1px; margin: 1px; border: 1px solid rgb(0, 0, 0);\">25 cm</td><td style=\"padding: 1px; margin: 1px; border: 1px solid rgb(0, 0, 0); text-align: center;\">--</td></tr><tr><td style=\"padding: 1px; margin: 1px; border: 1px solid rgb(0, 0, 0);\">Forelle</td><td style=\"padding: 1px; margin: 1px; border: 1px solid rgb(0, 0, 0);\">28 cm</td><td style=\"padding: 1px; margin