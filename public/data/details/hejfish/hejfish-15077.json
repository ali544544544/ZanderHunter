.467829,"lng":6.679332},{"lat":51.468223,"lng":6.678783},{"lat":51.468458,"lng":6.67832},{"lat":51.468517,"lng":6.678084},{"lat":51.468504,"lng":6.677926},{"lat":51.468406,"lng":6.677854},{"lat":51.468301,"lng":6.677844},{"lat":51.467989,"lng":6.678287},{"lat":51.467746,"lng":6.678631},{"lat":51.467628,"lng":6.678937}],[{"lat":51.462012,"lng":6.681552},{"lat":51.462085,"lng":6.682047},{"lat":51.46216,"lng":6.682255},{"lat":51.462269,"lng":6.68249},{"lat":51.462359,"lng":6.68261},{"lat":51.46248,"lng":6.682729},{"lat":51.462648,"lng":6.682799},{"lat":51.462828,"lng":6.682405},{"lat":51.462886,"lng":6.681862},{"lat":51.462607,"lng":6.680898},{"lat":51.462331,"lng":6.67957},{"lat":51.462019,"lng":6.679464},{"lat":51.461796,"lng":6.679815},{"lat":51.46185,"lng":6.680571}]],"source":"hejfish_api_map_geojson","confidence":"high"},"links":{"source":"https://www.hejfish.com/d/15077-die-fliessende-niers-im-gemeindegebiet-weeze-los-46-mit-altarmen-gesselt-los-48-und-kalbeck-los-49","hejfish":"https://www.hejfish.com/d/15077-die-fliessende-niers-im-gemeindegebiet-weeze-los-46-mit-altarmen-gesselt-los-48-und-kalbeck-los-49","alleangeln":null,"image":"https://file.hejfish.com/image/cc1200x900/ae/64/ae6486a027d23341cf96dad01c2962a1f0e8f732.jpg"},"fish":["Aal","Brasse","Div. Weißfische","Döbel","Flussbarsch","Hecht","Wels","Zander","Schleie","Karpfen","Rapfen"],"metadata":{"platform":"hejfish","geocode_source":"hejfish_api_map_geojson","slug":"die-fliessende-niers-im-gemeindegebiet-weeze-los-46-mit-altarmen-gesselt-los-48-und-kalbeck-los-49","seo_name":"Fließende Niers bei Weeze","description":"<p><u><b>Die Niers:</b></u><br></p> <p>Die Niers erstreckt sich über etwa 12 Hektar auf der Fläche der Gemeinde Weeze. Der Fluss hat hier eine Breite von etwa 10 bis 14 Metern und ist ein sehr beliebtes Ziel bei Freizeitsportlern.</p> <p><u><b>Altarm Kalbeck:</b></u><br><br>Der Altarm Kalbeck ist ein Mündungsstück einer ehemaligen Flussschleife nord-östlich von Weeze. <br>Durch einen Pappelumsturz hat das Gewässer eine natürliche Verbindung zum Hauptfluss erhalten.<br>Somit können die Fischarten in den Altarm ein- und auswandern.<br>Neben Schmuckschildkröten kommt hier auch der Biber und der Nutria vor.<br>Eine Röhrrichtzone zwischen Hauptstrom und Altarm bietet vielen seltenen Vögeln einen Lebensraum.</p> <p><u><b>Altarm Gesselt:</b></u><br><br>Dieser Gewässerabschnitt liegt östlich von Weeze und grenzt an das Weezer Tiergehege. Der Altarm ist Teil des Naturschutzgebietes Gesseltschleife, eine ehemaliges Niersbett.<br>Bei Niedrigwasser fällt ein großer Teil des Abschnittes schon mal trocken. Eine Verlandung des Gebietes schreitet immer weiter voran.<br></p>","borders":"<h4><u><b>Beginn Los 46:</b></u></h4>\n\n<h4>Höhe Hüderath, Bartenhof, Gemeindegrenze Weeze </h4>\n\n<h4><br><u><b>Ende Los 46:</b></u></h4>\n\n<h4>Höhe Kalbeck, Niersbrücke Fortstrasse<br></h4>","techniques":["Ansitzangeln","Feedern","Friedfischangeln","Karpfenangeln","Spinnangeln","Stippangeln"],"rules_files":[{"id":594267,"name":"niers-los-46-mit-altarmen-gesselt-los-48-und-kalbeck-los-49-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/c5a5290c4ebc2ef16c2ccbf46846bd9450446211/niers-los-46-mit-altarmen-gesselt-los-48-und-kalbeck-los-49-bestimmungen.pdf"}],"tickets":[{"name":"Tagesschein - Normalpreis inklusive Gebühr","price":"8,00 EUR","ticket_type_id":7925,"price_id":102276},{"name":"Monatsschein - Normalpreis inklusive Gebühr","price":"28,00 EUR","ticket_type_id":7926,"price_id":102274},{"name":"Jahresschein - Normalpreis inklusive Gebühr","price":"55,00 EUR","ticket_type_id":7927,"price_id":102275}],"manager":{"id":2021,"name":"Angelsportverein Weeze 1972 e.V.","street":"Elisabethstraße 6","postal_code":"47652","city":"Weeze","telephone":" ","email":"info@asv-weeze.de","website":"https://sites.google.com/view/asv-weeze-1972","logo":"https://file.hejfish.com/image/r200x200/26/18/26180925d60cb2bec892c9207f5559b670b1aa9c.jpg","slug":"angelsportverein-weeze-1972-e-v"},"season_begin":"0001-01-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":false,"boat":false,"belly_boat":false,"digital_ticket":true,"night_fishing":true,"ice_fishing":false,"depth_map":false,"has_gauges":false},"location":{"city":{"id":19434,"name":"Weeze"},"district":{"id":266,"name":"Kreis Kleve"},"state":{"id":21,"name":"Nordrhein-Westfalen","slug":"nordrhein-westfalen"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"source_last_updated":"2026-05-07T11:45:08.550Z","error":false},"last_updated":"2026-05-07T11:45:08.550Z"}