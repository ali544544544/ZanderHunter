{"id":13250,"slug":"naab-bayerl-kick","url":"https://www.hejfish.com/d/13250-naab-bayerl-kick","name":"Naab Bayerl/Kick","seo_name":"Naab Bayerl/Kick","description":"<p>Es sind schnell fließende Abschnitte, sowie ruhige Abschnitte und zwei Altwasser vorhanden. Die Uferbeschaffenheit reicht von steil bis flach. Den Großteil des Gewässers erreicht man fast nur zu Fuß. An den Bayerl-Kiesgruben unterhalb des Wehrs in Luhe und an der Staatsstraße 2657 nach den Weich-Kiesgruben kann man die Naab mit dem Auto anfahren. Länge des Flussabschnittes ca. 2,5km.</p>","intro":"","details":"","borders":"<p>Flussabschnitt der Naab südlich von Luhe ab dem Wehr in Luhe bis zu der Ortschaft Grünau. Länge des Flussabschnittes ca. 2,5km. Grenztafeln/Beschilderungen am oberen und unteren Ende beachten.</p>","image":"https://file.hejfish.com/image/cc1200x900/9b/64/9b64254c066fbe8ed1ec0731d7cbede75e7d4189.jpeg","water_size_ha":null,"fish":["Karpfen","Wels","Zander","Hecht","Aal","Schleie","Rotauge","Rotfeder","Brasse"],"techniques":["Ansitzangeln","Feedern","Posenangeln","Spinnangeln"],"properties":[],"water_type":"See","rules_text":"","rules_files":[],"tickets":[],"ticket_types":[],"manager":{"id":1797,"name":"Sportanglerbund Wernberg-Köblitz e. V.","street":"Kärntnerstraße 8","postal_code":"92533","city":"Wernberg-Köblitz","telephone":"","email":"","website":"http://www.sab-wernberg.de","logo":"https://file.hejfish.com/image/r200x200/d3/66/d3668bd4f68a2349b79c3d2d5171b30ebf4a6a1c.jpeg","slug":"sportanglerbund-wernberg-koeblitz-e-v"},"season_begin":"0001-01-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":true,"boat":false,"belly_boat":false,"digital_ticket":true,"night_fishing":true,"ice_fishing":false,"depth_map":false,"has_gauges":false},"location":{"city":{"id":34504,"name":"Luhe-Wildenau"},"district":{"id":450,"name":"Kreis Neustadt an der Waldnaab"},"state":{"id":10,"name":"Bayern","slug":"bayern"},"country":{"id":2,"name":"Deutschland","code":"de","sl