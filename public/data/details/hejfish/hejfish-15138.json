lng":10.453019},{"lat":54.150291,"lng":10.45392},{"lat":54.150994,"lng":10.454731},{"lat":54.151944,"lng":10.454941},{"lat":54.153597,"lng":10.453409}]],"source":"hejfish_api_map_geojson","confidence":"high"},"links":{"source":"https://www.hejfish.com/d/15138-weiher-in-der-nauwies","hejfish":"https://www.hejfish.com/d/15138-weiher-in-der-nauwies","alleangeln":null,"image":"https://file.hejfish.com/image/cc1200x900/d0/53/d053e13ff0d2c04b7fcd7b68777fdf0391748c06.jpg"},"fish":["Aal","Div. Weißfische","Hecht","Schleie","Brasse","Karpfen","Flussbarsch","Rotauge","Rotfeder"],"metadata":{"platform":"hejfish","geocode_source":"hejfish_api_map_geojson","slug":"weiher-in-der-nauwies","seo_name":"Weiher \"In der Nauwies\"","description":"<p>Unser Vereinsweiher \"In der Nauwies\" liegt am Ortseingang von Eppelborn aus Richtung Dirmingen kommend. Umgeben von einem schönen Mischwald und der daneben fließenden Ill. In Richtung der Ortsmitte grenzt der Weiher an ein naturbelassenes Feuchtgebiet mit einer sehr artenreichen Pflanzen- und Tierwelt.</p> <p>Ein perfekter Ort für einen schönen und entspannenden Angeltag am Wasser.</p> <p>Wir freuen uns stets über neue Mitglieder, die sich aktiv am Vereinsleben beteiligen.</p> <p> Um bei uns Mitglied zu werden ist eine Aufnahmegebühr von €175,- zu entrichten. Als jährlichen Mitgliedsbeitrag sind €60,- festgelegt, welche zum 01.03 jeden Jahres bezahlt werden. Es gibt keine verpflichtenden Arbeitseinsätze, jedoch sind wir über jede helfende Hand bei unseren Veranstaltungen und Pflegeaktionen an der Weiheranalage dankbar.<br></p>","borders":"<p><u><b>Adresse:</b></u> </p>\n\n<p>Klingfloß </p>\n\n<p>66571 Eppelborn<br></p>","techniques":["Ansitzangeln","Friedfischangeln","Karpfenangeln","Fliegenfischen","Naturköderangeln","Stippangeln"],"rules_text":"<p>1. Die Fischerei geschieht auf eigenes Risiko. Der Verein übernimmt keinerlei Haftung.<br><br>2. Es dürfen nur 2 Angeln mit je 1 Haken benutzt werden.<br><br>3. Untermaßige Fische sind sofort schonend zurückzusetzen.<br><br>4. Den Anordnungen unserer Aufsicht ist unbedingt Folge zu leisten. Zuwiderhandlungen führen zum sofortigen Einzug der Gastkarte.<br><br>5. Fangbeschränkungen täglich: 1 Karpfen, 3 Forellen, 2 Schleien, jedoch nur 2,5 kg Gesamtgewicht<br><br>6. Achte bitte auf Sauberkeit an Deinem Angelplatz. Verlasse ihn so, wie Du ihn anzutreffen wünschst.<br></p><p><br></p><p>Für Mindestmaße und Schonzeiten gelten die Bestimmungen des Saarländischen Fischereigesetzes. Abweichungen siehe Bestimmungen.</p><p>Der Fischereiverein Eppelborn 1970 e.V. bedankt sich und wünscht Petri Heil!<br></p><p><br></p><br>","rules_files":[{"id":611757,"name":"weiher-in-der-nauwies-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/decd299ebd20d56670164532a71abf883bc64024/weiher-in-der-nauwies-bestimmungen.pdf"}],"tickets":[{"name":"Tageskarte - Normalpreis inkl. Gebühren","price":"15,00 EUR","ticket_type_id":8040,"price_id":102391}],"manager":{"id":2038,"name":"Fischereiverein Eppelborn 1970 e.V.","street":"Weiher \"In der Nauwies\" ","postal_code":"66571","city":"Eppelborn","telephone":"","email":"hejfish.fve@gmail.com","website":"","logo":"https://file.hejfish.com/image/r200x200/19/6d/196df4041d9041f110af4c7e44788234b6d9f5ff.png","slug":"fischereiverein-eppelborn-1970-e-v"},"season_begin":"0001-01-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":true,"boat":false,"belly_boat":false,"digital_ticket":false,"night_fishing":false,"ice_fishing":false,"depth_map":false,"has_gauges":false},"location":{"city":{"id":25622,"name":"Eppelborn"},"district":{"id":331,"name":"Kreis Neunkirchen"},"state":{"id":12,"name":"Saarland","slug":"saarland"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"source_last_updated":"2026-05-07T11:45:15.967Z","error":false},"last_updated":"2026-05-07T11:45:15.967Z"}