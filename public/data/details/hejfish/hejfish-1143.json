68,"lng":8.601858},{"lat":50.116679,"lng":8.601364},{"lat":50.116533,"lng":8.600906},{"lat":50.116426,"lng":8.600648},{"lat":50.116053,"lng":8.599682},{"lat":50.11574,"lng":8.59887},{"lat":50.115398,"lng":8.597982},{"lat":50.115276,"lng":8.597636},{"lat":50.115025,"lng":8.596579},{"lat":50.11472,"lng":8.595324},{"lat":50.114421,"lng":8.594052},{"lat":50.114259,"lng":8.59336}]],"source":"hejfish_api_map_geojson","confidence":"high"},"links":{"source":"https://www.hejfish.com/d/1143-nidda-frankfurt-roedelheim","hejfish":"https://www.hejfish.com/d/1143-nidda-frankfurt-roedelheim","alleangeln":null,"image":"https://file.hejfish.com/image/cc1200x900/9d/43/9d431932092948356da8ee352623beb0a7cd5068.jpeg"},"fish":["Hecht","Karpfen","Zander","Schleie","Barbe","Wels","Flussbarsch","Rotfeder","Aal","Div. Weißfische"],"metadata":{"platform":"hejfish","geocode_source":"hejfish_api_map_geojson","slug":"nidda-frankfurt-roedelheim","seo_name":"Nidda Frankfurt Rödelheim","description":"<p><b><u>An der Nidda finden momentan Baumaßnahmen zu Renaturierung statt, die Auswirkungen können verschiedene Gewässerabschnitte betreffen. Bitte informieren Sie sich auf folgender Seite der SEF Frankfurt:</u></b></p> <h4><a href=\"https://www.stadtentwaesserung-frankfurt.de/gewaesser.html\"><b>https://www.stadtentwaesserung-frankfurt.de/gewaesser.html</b></a></h4> <p>Die Nidda befindet sich im Frankfurter Grüngürtel und ist auf einem Großteil der Strecke beidseitig befischbar und über den angrenzenden Fußweg gut erreichbar.<br></p> <p>Der Fischbestand setzt sich aus Weißfischen, Barsch, Zander, Hecht, Aal, Wildkarpfen, Schleien, Barben und vereinzelten Beständen von Welsen zusammen.</p> <p>Der Mühlgraben ist eine Strecke auf der Forellen und Barben gut vertreten sind und befindet sich oberhalb des Brentano Parks.</p> <p>Angelkarten können ganzjährig erworben werden. Es sind alle erlaubten Angeltechniken gestattet.</p> <p><strong>Wir empfehlen zur eigenen Sicherheit die erworbene Gastkarte in ausgedruckter Form mitzuführen, da Handys nicht immer funktionieren oder als Nachweis anerkannt werden.</strong></p> <h4>Angelsaison</h4> <p>01. Jänner bis 31. Dezember</p>","borders":"<div>Die Gewässserstrecke beginnt unterhalb des Wehr Frankfurt/Praunheim und geht bis zur Autobahnbrücke A5/Frankfurt-Nied. Weitere Informationen zur Strecke entnehmen Sie bitte der beigefügten Skizze.</div>","techniques":["Spinnangeln","Ansitzangeln","Feedern","Stippangeln","Posenangeln"],"rules_text":"<h4 style=\"color: rgb(51, 51, 51); font-family: &quot;Source Sans Pro&quot;, sans-serif; font-size: 20px; margin-top: 11px; margin-bottom: 11px;\"><strong>Am Angelplatz darf maximal nur mit zwei Ruten gefischt werden.</strong></h4><p style=\"color: rgb(51, 51, 51); line-height: 22.85px; font-family: &quot;Source Sans Pro&quot;, sans-serif; font-size: 16px; margin-bottom: 11px;\"><strong>Wir empfehlen zur eigenen Sicherheit die erworbene Gastkarte in ausgedruckter Form mitzuführen, da Handys nicht immer funktionieren oder als Nachweis anerkannt werden.</strong></p><h4 style=\"color: rgb(51, 51, 51); font-family: &quot;Source Sans Pro&quot;, sans-serif; font-size: 20px; margin-top: 11px; margin-bottom: 11px;\"><strong>Folgende Fangbeschränkungen gelten :</strong></h4><h4 style=\"color: rgb(51, 51, 51); font-family: &quot;Source Sans Pro&quot;, sans-serif; font-size: 20px; margin-top: 11px; margin-bottom: 11px;\">Karpfenartige (Cypriniformes) &nbsp;:&nbsp;2 Fische pro Angeltag<br>Barben : maximal 1 Fisch pro Angeltag<br>Forellenartige (Salmoniden) : 4 Fische pro Angeltag aber nicht mehr als 8<br>innerhalb einer Woche</h4><div style=\"color: rgb(51, 51, 51); line-height: 22.85px; font-family: &quot;Source Sans Pro&quot;, sans-serif; font-size: 16px;\"><strong>Es gelten die Bestimmungen der&nbsp;hessischen Fischereiverordnung und des hessischen Fischereigesetzes.</strong></div><div style=\"color: rgb(51, 51, 51); line-height: 22.85px; font-family: &quot;Source Sans Pro&quot;, sans-serif; font-size: 16px;\"><p style=\"margin-bottom: 11px;\"><u>1.&nbsp;Hessisches Fischereigesetz-HFischG- vom 17. November 2022</u></p><p style=\"margin-bottom: 11px;\"><b>Jeder Angler ist verpflichtet sich selbsttätig über die geltenden gesetzlichen Bestimmung vor Antritt seines Angeltages zu informieren!</b></p></div>","rules_files":[{"id":27686,"name":"nidda-frankfurt-roedelheim-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/082442c033eb5e2735ed03f77725258e1de6ae71/nidda-frankfurt-roedelheim-bestimmungen.pdf"}],"tickets":[{"name":"Tageskarte - Normalpreis","price":"11,00 EUR","ticket_type_id":285,"price_id":92896},{"name":"7-Tageskarte - Normalpreis","price":"25,00 EUR","ticket_type_id":286,"price_id":92897},{"name":"Monatskarte - Normalpreis","price":"40,00 EUR","ticket_type_id":287,"price_id":92898},{"name":"Jahreskarte - Normalpreis","price":"160,00 EUR","ticket_type_id":288,"price_id":92899}],"manager":{"id":40,"name":"Sportanglerklub \"Anker\" e.V.","street":"Ludwig-Landmann-Str. 326","postal_code":"60487","city":"Frankfurt/Main","telephone":"","email":"vorstand@sak-anker.de","website":"https://sportanglerklub.de/","logo":"https://file.hejfish.com/image/r200x200/86/32/8632eb197ed6f256c787ee68e8adeeb5d2baae0d.png","slug":"sportanglerklub-anker-e-v"},"season_begin":"0001-01-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":true,"boat":false,"belly_boat":false,"digital_ticket":false,"night_fishing":true,"ice_fishing":false,"depth_map":true,"has_gauges":true},"location":{"city":{"id":23858,"name":"Frankfurt am Main"},"district":{"id":312,"name":"Frankfurt am Main"},"state":{"id":14,"name":"Hessen","slug":"hessen"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"source_last_updated":"2026-05-07T11:37:13.949Z","error":false},"last_updated":"2026-05-07T11:37:13.949Z"}