{"id":12779,"slug":"grosses-meer","url":"https://www.hejfish.com/d/12779-grosses-meer","name":"Großes Meer","seo_name":"Großes Meer","description":"<p>Das Große Meer (Holter Meer) liegt in der Gesamtgemeinde Barnstorf und im Landkreis Diepholz. Der Angler findet auf diesem 15.36 Ha großen Gewässer ideale Fischgründe. Kapitale Hechte und Zander, große Karpfen, Schleien, Brassen, Aale sowie Weißfische. Sie lassen das Anglerherz vor Freude springen. Das Große Meer liegt in einem Naturschutzgebiet und kann aufgrund seines Uferbewuchses nur mit Booten befischt werden.</p>","intro":"","details":"","borders":"<p>Gewässer-Grenzen siehe Bestimmungen.</p>","image":"https://file.hejfish.com/image/cc1200x900/91/d0/91d08be05de8b6494cdbf8f096b29862c94617fd.jpeg","water_size_ha":null,"fish":["Aal","Hecht","Zander","Flussbarsch","Kaulbarsch","Wels","Aland","Schleie","Karpfen","Brasse","Güster","Rotauge","Rotfeder","Gründling","Hasel","Laube"],"techniques":["Ansitzangeln","Spinnangeln","Posenangeln","Raubfischangeln","Friedfischangeln"],"properties":[],"water_type":"See","rules_text":"","rules_files":[],"tickets":[],"ticket_types":[],"manager":{"id":1662,"name":"Fischereiverein Barnstorf e.V.","street":"Postfach 1116","postal_code":"49402","city":"Barnstorf","telephone":"015120285129","email":"info@fv-barnstorf.de","website":"http://www.fv-barnstorf.de/","logo":"https://file.hejfish.com/image/r200x200/09/b8/09b8acfc2e4708bf7f8d1c151e25d64720a639c0.jpeg","slug":"fischereiverein-barnstorf-e-v"},"season_begin":"0001-01-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":false,"boat":false,"belly_boat":false,"digital_ticket":false,"night_fishing":false,"ice_fishing":false,"depth_map":false,"has_gauges":false},"location":{"city":{"id":12607,"name":"Eydelstedt"},"district":{"id":186,"name":"Kreis Diepholz"},"state":{"id":22,"name":"Niedersachsen","slug":"niedersachsen"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"products":[],"poi