":50.375563,"lng":11.841449},{"lat":50.375289,"lng":11.841502},{"lat":50.375084,"lng":11.841373},{"lat":50.374995,"lng":11.841073},{"lat":50.374776,"lng":11.840494},{"lat":50.374481,"lng":11.840172}]],"source":"hejfish_api_map_geojson","confidence":"high"},"links":{"source":"https://www.hejfish.com/d/12669-saale-teilstueck-3-unterkotzau-joditz","hejfish":"https://www.hejfish.com/d/12669-saale-teilstueck-3-unterkotzau-joditz","alleangeln":null,"image":"https://file.hejfish.com/image/cc1200x900/c5/47/c547b4b93e2e7602e538da4469c273fb807f30b2.jpeg"},"fish":["Aal","Zander","Hecht","Karpfen","Forelle","Äsche","Div. Weißfische"],"metadata":{"platform":"hejfish","geocode_source":"hejfish_api_map_geojson","slug":"saale-teilstueck-3-unterkotzau-joditz","seo_name":"Saale - Teilstück 3 (Unterkotzau - Joditz)","description":"<h4>Angelkarte berechtigt zusätzlich zum Fischen in den Saaleteilstücken 1,2,4 + Quellitzsee (mit Regnitz) + Sinkteich</h4> <p>Ab Unterkotzau beginnt das Teilstück drei, das sich, unterbrochen von einer Fischschutzzone bei der Rietschenmühle, bis zum Ausflugslokal Fattigsmühle in landschaftlich sehr reizvoller Umgebung fortsetzt (einschl. zweier Altarme). Ein weiterer Teil beginnt dann oberhalb von Joditz im Landkreis Hof und zieht sich mit Außnahme des Mühlgrabens in Joditz bis unterhalb des Auensees. In diesem Bereich kommen die Forellen- und Äschenfreunde unter den Anglern auf ihre Kosten. Auch zum Fliegenfischen ist diese Strecke sehr gut geeignet.<br></p>","borders":"<p>Von der Straßenbrücke in Unterkotzau bis zum Schild an einem Baum etwa 200 m vor der gegenüber liegenden Straßenabzweigung nach Siebenhitz – einschließlich der Altarme (Waldenfelslache und Bärenlache). Weiter die Strecke ab dem Schild an der Mündung des Grabens auf Höhe der Abzweigung nach Siebenhitz bis zum Wehr in Joditz. Sodann vom Einfluss des Mühlgrabens in die Saale in Joditz bis zum Schild nach der Brücke unterhalb des Auensees.</p>","techniques":["Fliegenfischen","Naturköderangeln","Spinnangeln","Posenangeln","Raubfischangeln","Friedfischangeln"],"rules_text":"<p><b>Die Bestimmungen entnehmen Sie bitte der PDF-Datei im Anhang!</b><br></p>","rules_files":[{"id":1452726,"name":"tageskarte-fuer-die-gewaesser-des-fv-obere-saale-e-v-hof-saale-teilstuecke-1-4-quellitzsee-mit-regnitz-sinkteich-bad-steben-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/1f2e7b31a81ba1cef64d2e72d6c9cbcf35f5b7dd/tageskarte-fuer-die-gewaesser-des-fv-obere-saale-e-v-hof-saale-teilstuecke-1-4-quellitzsee-mit-regnitz-sinkteich-bad-steben-bestimmungen.pdf"}],"tickets":[{"name":"Tageskarte für die Gewässer des FV Obere Saale e.V. Hof: Saale Teilstücke 1 - 4, Quellitzsee mit Regnitz, Sinkteich Bad Steben - Normalpreis inkl. Servicegebühr","price":"18,00 EUR","ticket_type_id":2272,"price_id":94244}],"manager":{"id":1633,"name":"Fischereiverein Obere Saale e. V. Hof","street":"Alexander-von-Humboldt-Str. 49a","postal_code":"95032","city":"Hof","telephone":"0049 92 81 / 14 26 86","email":"post@obere-saale.de","website":"http://www.obere-saale.de/","logo":"https://file.hejfish.com/image/r200x200/bc/6d/bc6d0bf7e0b925e43e713892b58c33816a533d61.png","slug":"fischereiverein-obere-saale-e-v-hof"},"season_begin":"0001-05-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":true,"boat":false,"belly_boat":false,"digital_ticket":false,"night_fishing":true,"ice_fishing":false,"depth_map":false,"has_gauges":true},"location":{"city":{"id":35137,"name":"Hof (Saale)"},"district":{"id":465,"name":"Hof"},"state":{"id":10,"name":"Bayern","slug":"bayern"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"source_last_updated":"2026-05-07T11:41:32.882Z","error":false},"last_updated":"2026-05-07T11:41:32.882Z"}