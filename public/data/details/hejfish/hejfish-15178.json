t":51.66993,"lng":6.55362},{"lat":51.669308,"lng":6.549801},{"lat":51.668267,"lng":6.544627},{"lat":51.667813,"lng":6.541539},{"lat":51.667441,"lng":6.536816},{"lat":51.66754,"lng":6.536143},{"lat":51.667019,"lng":6.53208},{"lat":51.666918,"lng":6.53078}]],"source":"hejfish_api_map_geojson","confidence":"high"},"links":{"source":"https://www.hejfish.com/d/15178-fluerener-altrhein","hejfish":"https://www.hejfish.com/d/15178-fluerener-altrhein","alleangeln":null,"image":"https://file.hejfish.com/image/cc1200x900/0c/a9/0ca9ab4464a6cdb6605a8f1401b1265b50a69160.jpg"},"fish":["Aal","Div. Weißfische","Flussbarsch","Hecht","Wels","Zander","Karpfen"],"metadata":{"platform":"hejfish","geocode_source":"hejfish_api_map_geojson","slug":"fluerener-altrhein","seo_name":"Flürener Altrhein","description":"<p>Der <b>Flürener Altrhein </b>ist ein toter Rheinnebenarm, gelegen in der Nähe von Wesel, der nur bei Hochwasser mit dem Rhein verbunden ist. Dies geschieht 2 bis 3x im Jahr.</p> <p>Das Gewässer gilt als fischreich. <br></p>","borders":"<p>Der<b> Flührener Altrhein</b> grenzt an den <b>Campingplatz Grav-Insel</b> und an eine Landwirtschaftlich genutzte Wiese. Beangelt werden darf er <b>bis zu den Bojen </b>in der Mitte des Gewässers.</p>\n\n<p><b>Siehe auch anhängende Karte der Gewässergrenzen!<br></b><br></p>\n\n<p><b>Der Erlaubnisschein gilt von 7:00 bis 23:00 Uhr.</b><br></p>","techniques":["Ansitzangeln","Fliegenfischen","Friedfischangeln","Oberflächenangeln","Posenangeln","Spinnangeln"],"rules_text":"<h4><u><b>Bestimmungen:</b></u></h4><p> <b>Erlaubnis zum Fischfang mit folgenden Geräten:</b></p><p>1 Fliegenrute oder 1 Spinnrute oder 2 Angelruten mit jeweils 1 Haken&nbsp; (Grund oder Posenmontage)<br></p><h4><u><b>Gewässerstrecke:</b></u></h4><p>Flürener- Altrhein A1 im Bereich des Tagesplatzes und gegenüberliegendem Ufer<br>&nbsp;vor den Bojen. <b><br></b></p><p><b>Es gelten die gesetzlichen Artenschonzeiten und Mindestmaße des Landes NRW.</b></p><p><b><br></b>Spinnfischverbot von 01.04. bis 01.06.<br><br>Störe dürfen dem Gewässer nicht entnommen werden<br><br>Mit den <b>besonderen Bedingungen</b> erkläre ich mich <b>einverstanden</b>. <br><br>&nbsp;&nbsp;&nbsp; <b>die Hinweise zu Fischereiverbotszonen sind zu beachten</b>.&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; <br>&nbsp;&nbsp;&nbsp; <b>Der Erlaubnisschein gilt von 7:00 bis 23:00 Uhr.</b><br><br><b>Der Angelplatz ist sauber zu halten. </b></p><p><b><u>Fangliste:</u></b></p><p>Die Fänge sind nach Zahl und Länge zum Ende des Fischfangs auf hejfish.com <b>einzutragen.<br><br><u>Fangbegrenzung:</u></b></p><p><b>Aale, Hechte, Karpfen, Zander: höchstens 3 Stück pro Art und Tag.<br>Forellen: 3 Stück pro Tag, jedoch nicht mehr als 5 die Woche.</b></p><p>Es gelten die Vorschriften des Landesfischereigesetzes und der Landesfischereiverordnung NRW in der jeweils aktuellen Fassung, insbesondere hinsichtlich der<b> Schonzeiten und Mindestmaße. <br><br></b>Die Verwendung von<b> Setzkeschern, Köderfischsenken </b>sowie<b> lebenden Köderfischen ist verboten. <br><br></b>Der Erlaubnisschein berechtigt<b> nicht</b> zum <b>Fahren und Parken</b> auf dem Gelände des Campingplatzes der Grav-Insel GmbH.<br><b><br></b>Für die dauernde und uneingeschränkte Möglichkeit der Fischereiausübung leistet der Fischereiverein Grav-Insel e.V.<b> keine Gewähr. <br><br><br></b>Eine <b>Gebührenerstattung</b> kann nicht geltend gemacht werden.<b><br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; &nbsp;<br><br>Fischereiverein Grav-Insel e.V.<br><br></b><br></p>","rules_files":[{"id":616417,"name":"fluerener-altrhein-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/7afb6e9f9acd7eca024df1276a6ceeeb6140e978/fluerener-altrhein-bestimmungen.pdf"}],"tickets":[{"name":"Tageskarte - Normalpreis inkl. Servicegebühr","price":"11,50 EUR","ticket_type_id":8059,"price_id":102408}],"manager":{"id":2046,"name":"Fischereiverein Grav-Insel e.V.","street":"Gravinsel 1 ","postal_code":"46487","city":"Wesel","telephone":"0171/5106183","email":"fischereiverein-gravinsel@web.de","website":"https://www.fischereiverein-gravinsel.de","logo":"https://file.hejfish.com/image/r200x200/07/aa/07aa8ae1a6a4ee04137d0a11e420acbb31f98c16.jpg","slug":"fischereiverein-grav-insel-e-v"},"season_begin":"0001-01-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":false,"boat":false,"belly_boat":false,"digital_ticket":true,"night_fishing":false,"ice_fishing":false,"depth_map":true,"has_gauges":false},"location":{"city":{"id":19462,"name":"Wesel am Rhein"},"district":{"id":267,"name":"Kreis Wesel"},"state":{"id":21,"name":"Nordrhein-Westfalen","slug":"nordrhein-westfalen"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"source_last_updated":"2026-05-07T11:45:20.431Z","error":false},"last_updated":"2026-05-07T11:45:20.431Z"}