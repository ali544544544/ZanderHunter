33,"lng":8.327609},{"lat":48.967193,"lng":8.327975},{"lat":48.966977,"lng":8.328304},{"lat":48.966736,"lng":8.328664},{"lat":48.966544,"lng":8.328838},{"lat":48.966284,"lng":8.328934},{"lat":48.966119,"lng":8.328922},{"lat":48.966016,"lng":8.328952},{"lat":48.965914,"lng":8.328964},{"lat":48.965776,"lng":8.328934},{"lat":48.965635,"lng":8.32885},{"lat":48.965481,"lng":8.328832}],[{"lat":48.96121,"lng":8.329442},{"lat":48.961147,"lng":8.32918},{"lat":48.9611,"lng":8.328832},{"lat":48.961131,"lng":8.328236},{"lat":48.961124,"lng":8.327416},{"lat":48.961268,"lng":8.326924},{"lat":48.96164,"lng":8.325865},{"lat":48.961595,"lng":8.325669},{"lat":48.961652,"lng":8.325463},{"lat":48.961726,"lng":8.325191}],[{"lat":48.961955,"lng":8.322106},{"lat":48.961812,"lng":8.322307}],[{"lat":48.961726,"lng":8.325185},{"lat":48.961876,"lng":8.324721},{"lat":48.961627,"lng":8.324552},{"lat":48.961587,"lng":8.32433},{"lat":48.961414,"lng":8.324113},{"lat":48.961373,"lng":8.323972},{"lat":48.961455,"lng":8.323514},{"lat":48.961428,"lng":8.323278},{"lat":48.961491,"lng":8.323168},{"lat":48.961592,"lng":8.322906},{"lat":48.961812,"lng":8.322307}]],"polygons":[[{"lat":48.967752,"lng":8.327851},{"lat":48.967273,"lng":8.329675},{"lat":48.966977,"lng":8.33034},{"lat":48.966611,"lng":8.330619},{"lat":48.966139,"lng":8.330812},{"lat":48.965709,"lng":8.331124},{"lat":48.966829,"lng":8.331842},{"lat":48.967386,"lng":8.330802},{"lat":48.967463,"lng":8.330458},{"lat":48.967611,"lng":8.330201},{"lat":48.967801,"lng":8.330158},{"lat":48.968182,"lng":8.3296},{"lat":48.968576,"lng":8.328677}]],"source":"hejfish_api_map_geojson","confidence":"high"},"links":{"source":"https://www.hejfish.com/d/14472-epplesee-rheinstetten","hejfish":"https://www.hejfish.com/d/14472-epplesee-rheinstetten","alleangeln":null,"website":null,"image":"https://file.hejfish.com/image/cc1200x900/26/1a/261a8ecc7e6f2fbd1f856022e840050a245a353c.jpeg"},"fish":["Div. Weißfische","Karpfen","Flussbarsch","Hecht","Zander","Aal","Regenbogenforelle","Schleie"],"metadata":{"platform":"hejfish","geocode_source":"hejfish_api_map_geojson","slug":"epplesee-rheinstetten","seo_name":"Epplesee Rheinstetten","description":"<p><b>Großer Baggersee mit ca. 30 ha und einer Tiefe bis 45m.</b></p> <p><b>Kunstköder- und Köderfischverbot: 15.02. – 15.05.</b></p> <p><b>Raubfische</b>:<br>Zu den begehrtesten Fischen zählt der Hecht und Zander. Beide sind im Epplesee zahlreich vorhanden und sind die Hauptbeute der Raubfischangler. Es besteht allerdings auch ein ausgezeichneter Bestand an Barschen, Aalen und Forellen</p> <p><b>Friedfisch</b>:<br>Vorzüglicher Bestand an Karpfen und Schleien. Boilie-Angler erfreuen sich regelmäßig über Spiegel - und Schuppenkarpfen. Wer lieber mit der Match- oder Feederrute sein Glück versuchen möchte, kann sich an den enormen Weißfischbeständen versuchen.</p>","borders":"<p><b>Gewässergrenzen und Sperrzonen siehe Detailkarte im Anhang !</b></p>","techniques":["Ansitzangeln","Naturköderangeln","Posenangeln","Spinnangeln"],"rules_text":"<p><b><u>Gewässerordnung und Allgemeine Richtlinien:</u></b></p><p>Diese Tageserlaubnis ist nur in Verbindung mit einem staatlichen Fischereischein gültig. Eine Übertragung auf Dritte ist\r\nausgeschlossen.\r\nDie Tageserlaubnis und der staatliche Fischereischein sind bei der Ausübung der Fischerei stets bei sich zu tragen. Bei Verlangen\r\nsind diese den entsprechenden Aufsichtsbeamten und Mitgliedern des Sportfischerverein Rheinstetten e.V. umgehend\r\nvorzuzeigen.</p><ul><li>\r\nDas Angeln von Booten, Bellybooten, Kajaks etc. ist mit der Tageserlaubnis nicht gestattet.\r\n</li><li>Es dürfen keine Angelzelte aufgestellt werden.\r\nDas Angeln über Nacht ist nicht gestattet.</li><li> Es gelten die gesetzlichen Bestimmungen des Landes Baden-Württemberg.\r\n</li><li>In der Zeit vom 15.02. bis einschließlich 15.05. ist das Angeln auf Raubfische mit künstlichen Ködern, so wie mit Köderfischen\r\nverboten.</li><li>\r\nDas Legen von Nachtschnüren und Köderleinen ist strengstens verboten.</li></ul><p>Es darf gleichzeitig höchstens mit 2 Angelgeräten geangelt werden. Als Angelgerät zählt die Handangel und der Köderhamen.\r\n(Definition Handangel: Posen-, Grund-, Spinn- und Fliegenangel)\r\n<br>Jede Handangel darf über höchstens zwei Anbissstellen verfügen. (Drillinge zählen als eine Anbissstelle)\r\n</p><p>Der Inhaber dieser Genehmigung verpflichtet sich am Wasser umweltbewusst zu handeln und Beschädigungen an Ufervegetation\r\nund Störungseinflüsse weitgehend zu vermeiden. Nach dem Angeln ist der Angelplatz sauber zu verlassen!\r\n</p><p>Bei Nichteinhaltung ist er Inhaber dieser Genehmigung selbst verantwortlich. Der Sportfischerverein Rheinstetten e.V. übernimmt\r\nin keiner Weise eine Verantwortung.</p><div><b><br></b></div><div><u style=\"\"><b>Schonzeiten und Mindestmaße:&nbsp;</b></u></div><div><u style=\"\"><b><br></b></u></div><font face=\"Arial, Helvetica, sans-serif\" size=\"1\"><style type=\"text/css\">\r\n\ttable.tableizer-table {\r\n\t\tfont-size: 9px;\r\n\t\tborder: 1px solid #000; \r\n\t\tfont-family: Arial, Helvetica, sans-serif;\r\n\t} \r\n\t.tableizer-table td {\r\n\t\tpadding: 1px;\r\n\t\tmargin: 1px;\r\n\t\tborder: 1px solid #000;\r\n\t}\r\n\t.tableizer-table th {\r\n\t\tbackground-color: #00C1D6; \r\n\t\tcolor: #000;\r\n\t\tfont-weight: bold;\r\n\t}\r\n</style>\r\n<table class=\"tableizer-table\">\r\n<thead><tr class=\"tableizer-firstrow\"><th>Fischart</th><th>Mindestmaße</th><th>Schonzeiten</th></tr></thead><tbody>\r\n <tr><td>Aal </td><td>50 cm</td><td>-</td></tr>\r\n <tr><td>Barsch&nbsp;</td><td>-</td><td>-</td></tr>\r\n <tr><td>Brachse&nbsp;</td><td>-</td><td>-</td></tr>\r\n <tr><td>Güster&nbsp;</td><td>-</td><td>-</td></tr>\r\n <tr><td>Hecht&nbsp;</td><td>50 cm&nbsp;</td><td>15.02.-15.05.&nbsp;</td></tr>\r\n <tr><td>Karpfen&nbsp;</td><td>40 cm&nbsp;</td><td>-</td></tr>\r\n <tr><td>Forelle&nbsp;</td><td>35 cm&nbsp;</td><td>01.10.-28.02.&nbsp;</td></tr>\r\n <tr><td>Rotauge&nbsp;</td><td>-</td><td>-</td></tr>\r\n <tr><td>Rotfeder&nbsp;</td><td>-</td><td>-</td></tr>\r\n <tr><td>Schleie&nbsp;</td><td>30 cm&nbsp;</td><td>15.05.-30.06.&nbsp;</td></tr>\r\n <tr><td>Zander&nbsp;</td><td>45 cm&nbsp;</td><td>15.02.-15.05.</td></tr>\r\n</tbody></table></font><br><div><b>Zusätzliche Entnahmeregelungen:</b></div><div><b><br></b></div><div>Für die nachfolgend aufgeführten Fischarten gilt eine maximale Entnahmemenge von 3 Stück pro Tag.</div><div><br></div><div>- Aal</div><div>- Barsch</div><div>- Forelle</div><div>- Hecht</div><div>- Karpfen</div><div>- Schleie</div><div>- Zander</div><div><br></div><div>Für alle nicht aufgeführten Fischarten gelten die gesetzlichen\r\nSchonzeiten und Mindestmaße des Landes Baden-Württemberg!\r\nFische die dem Schonmaß und oder dem Mindestmaß unterliegen\r\nsind besonders schonend zu behandeln und nach dem Fang\r\numgehend zurückzusetzen.<br></div><div><u><b><br></b></u></div><div><u><b>\r\nBefahrungsregelung für Inhaber einer Tageserlaubnis:</b></u></div><div><u><b><br></b></u>Zum Parken mit dem Zweck der Angelfischerei, darf nur der große\r\nöffentliche Parkplatz im nördlichen Teil des Sees benutzt werden.\r\nZufahrt über K3581 via „Messekreisel“\r\n</div><div><b><u>Diese Erlaubniskarte gilt für das Ausstellungsdatum gleichzeitig\r\nals Parkticket.</u></b><br></div><div>(keine Gewähr bei überfülltem oder geschlossenem Parkplatz)</div><p></p>","rules_files":[{"id":777235,"name":"epplesee-rheinstetten-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/6601193262e0daeaf1aab671253c044608b6a4df/epplesee-rheinstetten-bestimmungen.pdf"}],"tickets":[{"name":"Tageskarte - Normalpreis inkl. Servicegebühr","price":"18,50 EUR","ticket_type_id":7140,"price_id":101594}],"manager":{"id":1901,"name":"Sportfischerverein Rheinstetten-Forchheim e.V.","street":"Rösselsbrünnlestr. 6","postal_code":"76287","city":"Rheinstetten","telephone":"","email":"info@sportfischerverein-rheinstetten.de","website":"http://www.sportfischerverein-rheinstetten.de","logo":"https://file.hejfish.com/image/r200x200/67/98/67985d8f94b3783fa626651ad9a8fe6bc3ced7f4.png","slug":"sportfischerverein-rheinstetten-forchheim-e-v"},"season_begin":"0001-01-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":false,"boat":false,"belly_boat":false,"digital_ticket":true,"night_fishing":false,"ice_fishing":false,"depth_map":true,"has_gauges":false},"location":{"city":{"id":26800,"name":"Rheinstetten"},"district":{"id":350,"name":"Kreis Karlsruhe"},"state":{"id":11,"name":"Baden-Württemberg","slug":"baden-wuerttemberg"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"source_last_updated":"2026-05-07T11:44:30.435Z","error":false},"last_updated":"2026-05-07T11:44:30.435Z"}