en Fischereiverband von 1880 e.V. und der Rheinfischereigenossenschaft im Lande NRW und gilt an folgenden Gewässern: </p> <p>1. Rhein in NRW </p> <p>2. Tenderingsee </p> <p>3. Xantener Nord- und Südsee </p> <p>4. Volksgartenweiher </p> <p>5. Schwanenspiegel/Kaiserteich </p> <p>6. Düsseldorfer Hafen </p> <p><b><u>Informationen zum Gewässer</u></b><br></p> <p>0,5 bis 3 Meter tief. </p> <p>Fische: Rotaugen, Barsch, Karpfen, Schleien, Brassen, Hecht, </p> <p>Zander, Aal. </p> <p>Vereinzelt: Rapfen, Döbel, Karauschen.</p>","borders":"<p>Gewässer-Grenzen: Ufer</p>","techniques":["Ansitzangeln","Fliegenfischen","Spinnangeln","Posenangeln"],"manager":{"id":1983,"name":"Ferienkarte Rheinischer Fischereiverband von 1880 e.V. / Rheinfischereigenossenschaft im Lande NRW","street":"Wahnbachtalstrasse 13a","postal_code":"53721 ","city":"Siegburg","telephone":"","email":"Info@rhfv.de","website":"","logo":"https://file.hejfish.com/image/r200x200/d7/23/d7236a5b65fd41f01fc9fa04541d468756e41477.jpg","slug":"ferienkarte-rheinischer-fischereiverband-von-1880-e-v-rheinfischereigenossenschaft-im-lande-nrw"},"season_begin":"0001-04-12","season_end":"0001-04-27","features":{"accessible":false,"public_transport":true,"boat":false,"belly_boat":false,"digital_ticket":false,"night_fishing":true,"ice_fishing":false,"depth_map":true,"has_gauges":false},"location":{"city":{"id":17049,"name":"Düsseldorf"},"district":{"id":243,"name":"Düsseldorf"},"state":{"id":21,"name":"Nordrhein-Westfalen","slug":"nordrhein-westfalen"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"source_last_updated":"2026-05-07T11:46:43.582Z","error":false},"last_updated":"2026-05-07T11:46:43.582Z"}