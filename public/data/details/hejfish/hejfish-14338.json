t":52.071171,"lng":11.688155},{"lat":52.071448,"lng":11.688251},{"lat":52.071672,"lng":11.688219},{"lat":52.071811,"lng":11.688251},{"lat":52.072028,"lng":11.688273},{"lat":52.072121,"lng":11.688488},{"lat":52.071936,"lng":11.689088},{"lat":52.07187,"lng":11.689968},{"lat":52.071969,"lng":11.690612},{"lat":52.072101,"lng":11.691138},{"lat":52.072384,"lng":11.691449}],[{"lat":52.071161,"lng":11.685247},{"lat":52.070699,"lng":11.685795},{"lat":52.070314,"lng":11.68609},{"lat":52.070159,"lng":11.686567},{"lat":52.070033,"lng":11.686803},{"lat":52.069865,"lng":11.6869},{"lat":52.069753,"lng":11.6869},{"lat":52.069558,"lng":11.686975},{"lat":52.069611,"lng":11.687082},{"lat":52.069657,"lng":11.687141},{"lat":52.069737,"lng":11.687184},{"lat":52.069812,"lng":11.687205},{"lat":52.069753,"lng":11.687495},{"lat":52.069822,"lng":11.687565},{"lat":52.069957,"lng":11.687624},{"lat":52.070132,"lng":11.687431},{"lat":52.070294,"lng":11.686744},{"lat":52.070366,"lng":11.686497},{"lat":52.070541,"lng":11.686395},{"lat":52.070666,"lng":11.68624},{"lat":52.07129,"lng":11.685542},{"lat":52.071398,"lng":11.685258},{"lat":52.071283,"lng":11.685231}]],"source":"hejfish_api_map_geojson","confidence":"high"},"links":{"source":"https://www.hejfish.com/d/14338-steinfoehr-bei-randau","hejfish":"https://www.hejfish.com/d/14338-steinfoehr-bei-randau","alleangeln":null,"image":null},"fish":["Aal","Hecht","Karpfen","Schleie","Zander","Flussbarsch","Brasse","Giebel","Güster","Karausche","Rotauge","Rotfeder","Laube"],"metadata":{"platform":"hejfish","geocode_source":"hejfish_api_map_geojson","slug":"steinfoehr-bei-randau","seo_name":"Steinföhr bei Randau","description":"<p><b>13 - 280 - 34 Steinför bei Randau</b></p> <div><b>Lage</b>:</div> <div>Steinför liegt im Südosten von Magdeburg in Höhe von Salbke östlich der Elbe in deren Überflutungsgebiet <br>(Geotag 52.070833, 11.700556)</div> <div><br></div> <div><b>Besonderheiten</b>:</div> <div>Steinför ist ein Rest eines früheren Elbarmes, der keine Verbindung mehr zur Elbe hat. Die Wasserfläche von Steinför beträgt ca. 1,7 ha, die Länge beträgt ca. 600 m und die durchschnittliche Breite ca. 40 m. Das Gewässer ist überwiegend von Wiesen umgeben, die von Frühjahr bis Herbst als Rinderweide genutzt werden und durch Elektrozäune oft bis dicht ans Ufer eingezäunt sind. Die Ufer sind 1 - 2 m hoch und führen meist steil ins Wasser. Die Wassertiefe beträgt bis zu 4 m. Teilweise säumen Bäume und Büsche die Ufer.<br></div> <div><b>Im Nordwesten ist Steinför mit Kuhlenhagen verbunden. <u>Im Kuhlenhagen ist Angeln aber verboten!</u></b></div> <div><br></div> <div><b>Erreichbarkeit</b>:</div> <div>Man erreicht das Gewässer am besten zu Fuß oder mit dem Fahrrad, entweder von Salbke mit der Gierfähre oder von Prester bzw. Schönebeck über den Elbdamm auf dem Elberadweg.</div> <div>Mit dem Kraftfahrzeug fährt man, von Magdeburg-Prester oder von Schönebeck-Elbenau kommend, auf der <i><b>Calenberger Straße</b></i>, dann auf der Straße <i><b>An der Elbaue </b></i>nach Randau, dort weiter auf der Hauptstraße bis fast zum Ende der Straße <i><b>An der Kreuzhorst</b></i>. Links zweigt dort der Fahrweg <i><b>Prinzenwiese </b></i>ab, wo nach ca. 550 m hinter den Stallanlagen rechts ein unbenannter Betonschwellenweg an der Kreuzhorst entlang bis kurz vor den Elbdamm führt. Von der Brücke über den Franzosengraben geht es nur zu Fuß oder per Rad weiter über den Elbdamm zum Gewässer.</div> <div><br></div> <div><b>Beangelbare Fischarten:</b></div> <div>Hauptfischarten sind Aal, Hecht, Karpfen, Schleie, Zander,</div> <div>Weitere Arten: Barsch, Blei (Brasse), Giebel, Güster, Karausche, Plötze, Rotfeder, Ukelei.</div>","borders":"<p><b>Im Nordwesten ist Steinför mit Kuhlenhagen verbunden. <u>Im Kuhlenhagen ist Angeln verboten!</u></b><br></p>","techniques":["Ansitzangeln","Feedern","Posenangeln","Spinnangeln","Friedfischangeln","Naturköderangeln","Raubfischangeln","Stippangeln"],"manager":{"id":1875,"name":"Magdeburger Anglerverein e. V. - INAKTIV","street":"Beimsstr. 89 a ","postal_code":"39110","city":"Magdeburg","telephone":"+49 391 8113033","email":"info@magdeburger-anglerverein.de","website":"https://www.magdeburger-anglerverein.de/","logo":"https://file.hejfish.com/image/r200x200/63/1a/631a65e4dfec68285fa47ba582239e084f563a01.jpeg","slug":"magdeburger-anglerverein-e-v-inaktiv"},"season_begin":"0001-01-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":false,"boat":false,"belly_boat":false,"digital_ticket":true,"night_fishing":true,"ice_fishing":false,"depth_map":true,"has_gauges":false},"location":{"city":{"id":16881,"name":"Magdeburg"},"district":{"id":239,"name":"Magdeburg"},"state":{"id":17,"name":"Sachsen-Anhalt","slug":"sachsen-anhalt"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"source_last_updated":"2026-05-07T11:44:17.638Z","error":false},"last_updated":"2026-05-07T11:44:17.638Z"}