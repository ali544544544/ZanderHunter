57,"lng":9.060099},{"lat":51.183619,"lng":9.060016},{"lat":51.18353,"lng":9.060129},{"lat":51.183153,"lng":9.060707},{"lat":51.182679,"lng":9.061337},{"lat":51.182534,"lng":9.061837}]],"source":"hejfish_api_map_geojson","confidence":"high"},"links":{"source":"https://www.hejfish.com/d/12004-affolderner-see","hejfish":"https://www.hejfish.com/d/12004-affolderner-see","alleangeln":null,"image":"https://file.hejfish.com/image/cc1200x900/4a/d1/4ad1d3f04f6039954f3d3509bb629df3d1e52193.jpeg"},"fish":["Bachforelle","Flussbarsch","Hecht","Regenbogenforelle"],"metadata":{"platform":"hejfish","geocode_source":"hejfish_api_map_geojson","slug":"affolderner-see","seo_name":"Affolderner See","description":"<h2>Das erwartet dich am Affolderner See</h2> <p>Der Affolderner See ist ein Salmonidengewässer und künstlich angelegter See. Angeln kannst du hier nördlich des Zwischendamms und im anschließenden Ederlauf, die Details zu den Grenzen findest du weiter unten. Der südliche Teil des Sees hingegen ist ein Naturschutzgebiet. Dennoch bleiben dir rund 90 Hektar Angelfläche am Affolderner See und 16 Hektar am Ederlauf, ideal für Fliegenfischer. Die Angelsaison beginnt am 01.04. und endet am 15.12. eines Jahres.<br></p> <p>Da eine möglichst ökologische Bewirtschaftung angestrebt wird, ist der vierteljährliche Besatz mit Bach- und Regenbogenforellen erforderlich.</p> <h3>So angelst du am Affolderner See</h3> <p><b>Fangbegrenzungen:</b> Pro Angeltag darfst du maximal 3 Stück Bach- oder Regenbogenforellen entnehmen. Für Jahresscheininhaber gilt eine Begrenzung von 50 Stück pro Jahr. </p> <p>Keinen Fangbegrenzungen unterliegen folgende: Barsch, Wels, Brachse, Döbel, Giebel, Güster, Kaulbarsch, Hasel, Rapfen, Rotauge und Ukelei. </p> <div><br></div> <p><b>Schonzeiten und Mindestmaße:<br></b><strong>Hecht:</strong> Schonzeit vom 01.02 bis 15.04., Mindestmaß 50 cm<br><strong>Karpfen:</strong> Schonzeit vom 15.03. bis 31.05., Mindestmaß 45 cm<br><strong>Bachforelle:</strong> Schonzeit vom 15.10. bis 31.03., Mindestmaß 25 cm<br><strong>Schleie:</strong> Schonzeit vom 01.05. bis 30.06., Mindestmaß 25 cm<br><strong>Zander:</strong> Schonzeit vom 15.03. bis 31.05., Mindestmaß 50 cm<br><strong>Aal:</strong> Schonzeit vom 01.10. bis 01.03., Mindestmaß 50 cm<br><strong>Äsche:</strong> Schonzeit vom 01.03. bis 15.05, Mindestmaß 30 cm<br><strong>Barbe:</strong> Schonzeit vom 01.05. bis 15.06., Mindestmaß 38 cm<br><strong>Gründling:</strong> Schonzeit vom 15.04. bis 30.06<br><strong>Rotfeder:</strong> Schonzeit vom 15.03. bis 31.05., Mindestmaß 20 cm</p>","borders":"<p>Für den Affolderner See auf dem nördlich des Zwischendammes zur Straße gelegenen Gewässerteil und im anschließenden Ederlauf, flussaufwärts bis zur Betriebsbrücke vor der Sperrmauer. Achtung: gelb markierte Fließstrecke nach dem Kraftwerk ist eine reine Fliegenstrecke! <br></p>","techniques":["Fliegenfischen","Spinnangeln"],"rules_text":"<h3>Siehe Bestimmungen im Anhang.</h3>","rules_files":[{"id":1432007,"name":"affolderner-see-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/bab2b26f001afd49a05dcb8323851c6518bd24fc/affolderner-see-bestimmungen.pdf"}],"tickets":[{"name":"1 - Tagesschein - Tagesschein","price":"16,00 EUR","ticket_type_id":902,"price_id":91966},{"name":"2 - Tagesschein - Normalpreis","price":"24,00 EUR","ticket_type_id":903,"price_id":91967},{"name":"3 - Tagesschein - Normalpreis","price":"30,00 EUR","ticket_type_id":904,"price_id":91974},{"name":"4 - Tagesschein - Normalpreis","price":"36,00 EUR","ticket_type_id":905,"price_id":91975},{"name":"5 - Tagesschein - Normalpreis","price":"41,00 EUR","ticket_type_id":906,"price_id":91976},{"name":"5 - Tagesschein - Normalpreis POS","price":"41,00 EUR","ticket_type_id":906,"price_id":91996},{"name":"6 - Tagesschein - Normalpreis","price":"45,00 EUR","ticket_type_id":907,"price_id":91977},{"name":"Wochenschein - Normalpreis","price":"48,00 EUR","ticket_type_id":908,"price_id":91978},{"name":"Saisonschein - Normalpreis","price":"184,00 EUR","ticket_type_id":909,"price_id":91960}],"manager":{"id":42,"name":"Naturpark Kellerwald-Edersee","street":"Langemarckstraße 19","postal_code":"34537","city":"Bad Wildungen","telephone":"05621/969460","email":"info@naturpark-kellerwald-edersee.de","website":"http://www.naturpark-kellerwald-edersee.de/","logo":"https://file.hejfish.com/image/r200x200/c5/3f/c53feb031acfb72ae88cc7aedf81f858b9f765be.png","slug":"naturpark-kellerwald-edersee"},"season_begin":"0001-04-01","season_end":"0001-11-30","features":{"accessible":false,"public_transport":false,"boat":true,"belly_boat":true,"digital_ticket":true,"night_fishing":false,"ice_fishing":false,"depth_map":false,"has_gauges":true},"location":{"city":{"id":15442,"name":"Waldeck"},"district":{"id":218,"name":"Kreis Waldeck-Frankenberg"},"state":{"id":14,"name":"Hessen","slug":"hessen"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"source_last_updated":"2026-05-07T11:37:16.096Z","error":false},"last_updated":"2026-05-07T11:37:16.096Z"}