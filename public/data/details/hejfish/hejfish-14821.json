>4 Edelfische, davon nicht mehr als 2 Karpfen, 3 Forellen, entweder 1 Hecht oder 1 Zander</p><p><br></p>","rules_files":[{"id":449922,"name":"rems-bei-schorndorf-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/abfebbbbfa33947d2c0302c1645706e2e658fab5/rems-bei-schorndorf-bestimmungen.pdf"}],"tickets":[{"name":"Tageskarte - Normalpreis inkl. Servicegebühr","price":"18,00 EUR","ticket_type_id":7400,"price_id":101758},{"name":"Wochenkarte - Normalpreis inkl. Servicegebühr","price":"44,00 EUR","ticket_type_id":8390,"price_id":101760},{"name":"Monatskarte - Normalpreis inkl. Servicegebühr","price":"82,50 EUR","ticket_type_id":8391,"price_id":101759}],"manager":{"id":1936,"name":"Hege- und Fischereiverein Schorndorf e.V.","street":"Fischerweg ","postal_code":"73660 ","city":"Urbach","telephone":"","email":"hfv-schorndorf@outlook.de","website":"","logo":"https://file.hejfish.com/image/r200x200/d0/0b/d00bdc5a9c486067c3a02f64ea29ab2f1d3e98bf.jpeg","slug":"hege-und-fischereiverein-schorndorf-e-v"},"season_begin":"0001-01-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":false,"boat":false,"belly_boat":false,"digital_ticket":true,"night_fishing":true,"ice_fishing":false,"depth_map":false,"has_gauges":false},"location":{"city":{"id":27420,"name":"Schorndorf (Württemberg)"},"district":{"id":354,"name":"Rems-Murr-Kreis"},"state":{"id":11,"name":"Baden-Württemberg","slug":"baden-wuerttemberg"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"source_last_updated":"2026-05-07T11:44:39.147Z","error":false},"last_updated":"2026-05-07T11:44:39.147Z"}