82698}]],"polygons":[],"source":"hejfish_api_map_geojson","confidence":"high"},"links":{"source":"https://www.hejfish.com/d/14846-leine-mit-altarmen-brucht-iburg-wasserwerk-limmer-und-wettense","hejfish":"https://www.hejfish.com/d/14846-leine-mit-altarmen-brucht-iburg-wasserwerk-limmer-und-wettense","alleangeln":null,"website":null,"image":"https://file.hejfish.com/image/cc1200x900/64/74/6474ccb16ae140dbda6b151ce98129e6d0b8fa54.jpeg"},"fish":["Schleie","Äsche","Aal","Bachforelle","Regenbogenforelle","Flussbarsch","Hecht","Zander","Barbe","Rotauge","Brasse","Döbel","Karpfen"],"metadata":{"platform":"hejfish","geocode_source":"hejfish_api_map_geojson","slug":"leine-mit-altarmen-brucht-iburg-wasserwerk-limmer-und-wettense","seo_name":"Leine mit Altarmen","description":"<p>Länge: 12km <br>Breite: bis 20m</p> <p>Diese Leinestrecke fängt zwischen Meimerhausen und der Einmündung der Wispe bei Wispenstein an und endet bei Dehnsen an der Einmündung der Glene.</p>","borders":"<p>Gewässergrenzen: Leine von der Mündung der Wispe bis zur  Mündung der Glene</p>","techniques":["Ansitzangeln","Feedern","Posenangeln","Spinnangeln"],"rules_text":"<p class=\"p1\" style=\"margin-bottom: 0px; font-variant-numeric: normal; font-variant-east-asian: normal; font-stretch: normal; line-height: normal;\">Hiermit wird die Erlaubnis zum Angeln mit <span class=\"s1\" style=\"font-variant-numeric: normal; font-variant-east-asian: normal; font-stretch: normal; line-height: normal;\">2 Handangeln </span>erteilt.</p><p class=\"p1\" style=\"margin-bottom: 0px; font-variant-numeric: normal; font-variant-east-asian: normal; font-stretch: normal; line-height: normal;\">Die Angelerlaubnis ist gültig für folgende Vereinsgewässer: Leine mit Altarmen und Duinger Seen.</p><p class=\"p1\" style=\"margin-bottom: 0px; font-variant-numeric: normal; font-variant-east-asian: normal; font-stretch: normal; line-height: normal;\"><b>Bruchsee, Ententeich sind vom <span class=\"s1\" style=\"font-variant-numeric: normal; font-variant-east-asian: normal; font-stretch: normal; line-height: normal;\">01.05. – 15.07. gesperrt.</span></b></p><p class=\"p1\" style=\"margin-bottom: 0px; font-variant-numeric: normal; font-variant-east-asian: normal; font-stretch: normal; line-height: normal;\">Die gekennzeichneten Angelplätze sind einzuhalten. <br><span class=\"s1\" style=\"font-variant-numeric: normal; font-variant-east-asian: normal; font-stretch: normal; line-height: normal;\">Die </span>Saale, die Warne und die Glene und die gestrichelten Sperrbezirke und die Kiesseen in Godenau sind von der Erlaubnis ausgenommen <span class=\"s2\" style=\"font-variant-numeric: normal; font-variant-east-asian: normal; font-stretch: normal; line-height: normal;\">/ siehe Anlage Gewässerkarte.</span></p><p class=\"p2\" style=\"margin-bottom: 0px; font-variant-numeric: normal; font-variant-east-asian: normal; font-stretch: normal; line-height: normal;\">Das Angeln mit lebenden Köderfischen ist nicht erlaubt.</p><p class=\"p2\" style=\"margin-bottom: 0px; font-variant-numeric: normal; font-variant-east-asian: normal; font-stretch: normal; line-height: normal;\"><b>Dem Angler ist die Benutzung eines Wetterschutzes (Schirm / Schirmzelt) erlaubt.</b> <b>Die Verwendung von Zelten / Brollys oder Camping ist nicht gestattet. </b></p><p class=\"p2\" style=\"margin-bottom: 0px; font-variant-numeric: normal; font-variant-east-asian: normal; font-stretch: normal; line-height: normal;\"><br></p><p class=\"p2\" style=\"margin-bottom: 0px; font-variant-numeric: normal; font-variant-east-asian: normal; font-stretch: normal; line-height: normal;\"><u>Gewässergrenze der Leine mit Altarmen Brucht, Iburg, Wasserwerk, Limmer und Wettense:</u><br></p><p class=\"MsoNormal\" style=\"margin: 0cm;\"><span lang=\"DE\" style=\"\">Leine von der Mündung der Wispe bis zur  Mündung der Glene (siehe Umgebungskarte in den PDF-Bestimmungen)<font face=\"Calibri, sans-serif\"><span style=\"font-size: 12pt;\"><o:p></o:p></span></font></span></p><p class=\"MsoNormal\" style=\"margin: 0cm; font-size: 10pt; font-family: \" times=\"\" new=\"\" roman\",=\"\" serif;\"=\"\"><span lang=\"DE\" style=\"font-size: 12pt; font-family: Calibri, sans-serif;\"> </span></p><p class=\"p2\" style=\"margin-bottom: 0px; font-variant-numeric: normal; font-variant-east-asian: normal; font-stretch: normal; line-height: normal;\"><br></p><p class=\"p2\" style=\"margin-bottom: 0px; font-variant-numeric: normal; font-variant-east-asian: normal; font-stretch: normal; line-height: normal;\"><br></p><p class=\"p2\" style=\"margin-bottom: 0px; font-variant-numeric: normal; font-variant-east-asian: normal; font-stretch: normal; line-height: normal;\"></p><div class=\"row\"></div>","rules_files":[{"id":1383519,"name":"asv-alfeld-e-v-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/d476695208f75a9438570650dfc1b8fe18939e09/asv-alfeld-e-v-bestimmungen.pdf"},{"id":1383520,"name":"asv-alfeld-e-v-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/4ca58a70a75e694ff01b934030d9086b4765d9a3/asv-alfeld-e-v-bestimmungen.pdf"}],"tickets":[{"name":"Kombi-Tageskarte der Gewässer des ASV Alfeld - Normalpreis inkl. Servicegebühr","price":"13,00 EUR","ticket_type_id":7425,"price_id":91673},{"name":"Kombi-Wochenkarte der Gewässer des ASV Alfeld - Normalpreis inkl. Servicegebühr","price":"28,00 EUR","ticket_type_id":7426,"price_id":91674},{"name":"Kombi-Monatskarte der Gewässer des ASV Alfeld - Normalpreis inkl. Servicegebühr","price":"38,50 EUR","ticket_type_id":7427,"price_id":91672}],"manager":{"id":1942,"name":"ASV Alfeld e.V.","street":"Mörick 4","postal_code":"30161","city":"Alfeld (Leine)","telephone":"05181 - 254 28","email":"angelsportvereinalfeld@t-online.de","website":"https://asvalfeld.de/","logo":"https://file.hejfish.com/image/r200x200/ca/8b/ca8b76d6a3e47d078816401b796cf0ed02a32301.jpeg","slug":"asv-alfeld-e-v"},"season_begin":"0001-01-01","season_end":"0001-12-31","features":{"