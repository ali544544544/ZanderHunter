g":11.454492},{"lat":49.156618,"lng":11.454492},{"lat":49.155131,"lng":11.454213},{"lat":49.153643,"lng":11.453869},{"lat":49.152843,"lng":11.453891},{"lat":49.15165,"lng":11.453891},{"lat":49.151131,"lng":11.453912},{"lat":49.150696,"lng":11.453826},{"lat":49.149714,"lng":11.453526},{"lat":49.145868,"lng":11.452067},{"lat":49.13899,"lng":11.449513},{"lat":49.135887,"lng":11.448548},{"lat":49.133528,"lng":11.447797},{"lat":49.13277,"lng":11.447368},{"lat":49.132419,"lng":11.447539},{"lat":49.131521,"lng":11.447132},{"lat":49.130749,"lng":11.44666},{"lat":49.127589,"lng":11.445265},{"lat":49.12662,"lng":11.444921},{"lat":49.125946,"lng":11.444771}]],"polygons":[],"source":"hejfish_api_map_geojson","confidence":"high"},"links":{"source":"https://www.hejfish.com/d/14889-ludwig-donau-main-kanal-bei-neumarkt","hejfish":"https://www.hejfish.com/d/14889-ludwig-donau-main-kanal-bei-neumarkt","alleangeln":null,"website":null,"image":"https://file.hejfish.com/image/cc1200x900/20/84/20847c2de7e71e71e49ba6c0219c032279bcd762.jpg"},"fish":["Schleie","Div. Weißfische","Flussbarsch","Wels","Aal","Forelle","Schuppenkarpfen","Spiegelkarpfen","Hecht","Zander"],"metadata":{"platform":"hejfish","geocode_source":"hejfish_api_map_geojson","slug":"ludwig-donau-main-kanal-bei-neumarkt","seo_name":"Ludwig-Donau-Main-Kanal bei Neumarkt","description":"<p>Der Ludwig-Donau-Main-Kanal oder auch „alter Kanal“ genannt, schlängelt sich durch ganz Neumarkt und ist einer unsere ältesten und fischreichsten Gewässer in der Region. Die etlichen Brücken, Schleusen und Seerosenfelder bieten immer einen super Unterstand für unsere Wassertiere und gehören außerdem zu den absoluten Hot Spots des Gewässers. </p>","intro":"<p>Für Inhabe von Jugendkarten ist das Angeln nur mit einer Handangel erlaubt.</p>","borders":"<p>Zwischen Rappersdorfer\nBrücke und Ende Ölsbacher Einschnitt, innerhalb der\ndurch Tafeln gekennzeichneten Grenzen (siehe Anhang).<br></p>","techniques":["Ansitzangeln","Posenangeln","Feedern","Friedfischangeln","Karpfenangeln"],"rules_text":"<p><b><u>Auflagen und Beschränkungen</u></b></p><ul><li>\r\nErlaubt sind 2 Handangeln mit je einem Vorfach.\r\n</li><li>Blinkern verboten.&nbsp;</li><li><b><u>Der Fang von Raubfischen, wie Hecht, Zander und Waller ist untersagt.\r\n</u></b></li><li>Alle gefangenen Fische sind unverzüglich nach der Anlandung und ordnungsgemäßen Versorgung in die Fangliste einzutragen. <b>Nur eine aussagekräftige Statistik dient einer sinnvollen Bewirtschaftung und Besatzmaßnahmen.</b></li><li>Die bei der <b>Ausgabe </b>über eine<b> Ausgabestelle</b>&nbsp; erhobene Pfandgebühr von <b>3,- €</b> wird bei der <b>Rückgabe </b>der&nbsp; Tageskarte mit Fangmeldung wieder vollständig rückerstattet.<b></b></li><li>Das Befahren der Ziehwege beidseitig des Kanals ist verboten.</li><li>\r\nDen Aufsichtsorganen ist Folge zu leisten.\r\n</li><li>Für Schäden haftet der Erlaubnisscheininhaber persönlich.</li></ul><p><b>\r\nAchtung:&nbsp;</b>Bei Fischsterben und Gewässerverschmutzungen bitte unverzüglich die Vereinsverwaltung, Handy: 015151119102, Email: verwaltung@fv-nm.de oder die Polizeiinspektion Neumarkt, Tel.: 09181-48850, verständigen!</p><p><b>Tagesfangbegrenzung:\r\n</b></p><p>2 Karpfen, 4 Schleien, 3 Aale, 2 Forellen,\r\nsonstige keine Begrenzung</p><p><b>\r\nFangmaße und Schonzeiten:</b></p><ul><li>Karpfen: 35 cm // -&nbsp;</li><li>Schleien: 30 cm // 01.05. - 30.06.<br></li><li>Aale: 50 cm // 01.11. - 28.02.\r\n</li><li>Forelle: 26 cm // 01.10. - 30.04.</li></ul><p><br></p><h4>Für Inhaber von Jugendkarten ist das Angeln nur mit <b><u>einer</u></b> Handangel erlaubt.</h4>","rules_files":[{"id":461435,"name":"ludwig-donau-main-kanal-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/40d1aaab5186bc16d3306b08e76fd0950e2b406b/ludwig-donau-main-kanal-bestimmungen.pdf"},{"id":1441252,"name":"tageskarte-jugend-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/9f45f5ec8fa001222eca7fdc61cbbb18546b54b7/tageskarte-jugend-bestimmungen.pdf"}],"tickets":[{"name":"Tageskarte - Normalpreis inkl. Servicegebühr","price":"18,00 EUR","ticket_type_id":7503,"price_id":92080},{"name":"Tageskarte (Jugend) - Jugendpreis inkl. Servicegebühr","price":"12,00 EUR","ticket_type_id":7504,"price_id":92081}],"manager":{"id":1957,"name":"Fischereiverein Neumarkt e.V. ","street":"Max-Bögl-Straße 40","postal_code":"92369","city":"Sengenthal","telephone":"0171-5527534","email":"verwaltung@fv-nm.de","website":"https://fv-nm.de","logo":"https://file.hejfish.com/image/r200x200/19/f5/19f5715af115cf52bc8e84a2a14b5d980f37cc62.png","slug":"fischereiverein-neumarkt-e-v"},"season_begin":"0001-01-01","season_end":"0001-11-01","features":{"accessible":false,"public_transport":true,"boat":false,"belly_boat":false,"digital_ticket":false,"night_fishing":true,"ice_fishing":false,"depth_map":false,"has_gauges":true},"location":{"city":{"id":34140,"name":"Neumarkt in der Oberpfalz"},"district":{"id":443,"name":"Kreis Neumarkt in der Oberpfalz"},"state":{"id":10,"name":"Bayern","slug":"bayern"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"source_last_updated":"2026-05-07T11:44:48.729Z","error":false},"last_updated":"2026-05-07T11:44:48.729Z"}