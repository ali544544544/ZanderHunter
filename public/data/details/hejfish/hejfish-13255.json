-koeblitz-e-v"},"season_begin":"0001-01-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":false,"boat":false,"belly_boat":false,"digital_ticket":true,"night_fishing":true,"ice_fishing":false,"depth_map":false,"has_gauges":false},"location":{"city":{"id":34504,"name":"Luhe-Wildenau"},"district":{"id":450,"name":"Kreis Neustadt an der Waldnaab"},"state":{"id":10,"name":"Bayern","slug":"bayern"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"source_last_updated":"2026-05-07T11:42:21.220Z","error":false},"last_updated":"2026-05-07T11:42:21.220Z"}