4.326448,"lng":9.273614},{"lat":54.326979,"lng":9.271147},{"lat":54.327205,"lng":9.269977},{"lat":54.327511,"lng":9.26774},{"lat":54.328071,"lng":9.265831},{"lat":54.328459,"lng":9.264822},{"lat":54.329557,"lng":9.262918},{"lat":54.330442,"lng":9.261839},{"lat":54.331515,"lng":9.260922},{"lat":54.332429,"lng":9.260514},{"lat":54.333151,"lng":9.260305},{"lat":54.333817,"lng":9.260209},{"lat":54.334515,"lng":9.260257},{"lat":54.335231,"lng":9.260659},{"lat":54.335975,"lng":9.261453},{"lat":54.336745,"lng":9.262692},{"lat":54.33758,"lng":9.264253},{"lat":54.338149,"lng":9.26538},{"lat":54.338775,"lng":9.266657},{"lat":54.3391,"lng":9.267021},{"lat":54.339381,"lng":9.267172},{"lat":54.339656,"lng":9.267156},{"lat":54.339847,"lng":9.266968}]],"polygons":[],"source":"hejfish_api_map_geojson","confidence":"high"},"links":{"source":"https://www.hejfish.com/d/14806-eider-bei-delve-km-53-0-km-57-7","hejfish":"https://www.hejfish.com/d/14806-eider-bei-delve-km-53-0-km-57-7","alleangeln":null,"image":"https://file.hejfish.com/image/cc1200x900/6c/09/6c0979885cf8b8080dfc2b0ec215a18c3851cbc1.jpeg"},"fish":["Aal","Aland","Flussbarsch","Brasse","Hecht","Karpfen","Rapfen","Rotauge","Rotfeder","Schleie","Wels","Zander","Meerforelle","Atlantischer Lachs"],"metadata":{"platform":"hejfish","geocode_source":"hejfish_api_map_geojson","slug":"eider-bei-delve-km-53-0-km-57-7","seo_name":"Eider bei Delve (KM 53,0 - KM 57,7)","description":"<h3><b>Zur Bestandsschonung ist das Angeln mit Kunstködern sowie totem Köderfisch vom 01.01. bis einschließlich 15.05. untersagt.</b></h3> <p><b>Gewässerbeschreibung:</b></p> <p>Fließgewässer mit wechselnder, unterschiedlich starker Strömung. Gewässerbreite zwischen 80m-120m.</p> <p><b>Gewässertiefe</b>:<br>Flache Uferzone bis Fahrwasser durchschnittlich ca. 5m-6m mit Tiefenlöchern bis 16m.</p> <p>Ufer mit natürlichem Bewuchs Bäume, Büsche , Binsen, Gras </p>","borders":"<p>KM 53 durch Kilometerstein auf der südlichen Eiderseite und roter Fahrwassertonne (54.308516, 9.272358)<br>KM57,7 durch ein Großes Schöpfwerk ( Steinschleuse) auf der nördlichen Eiderseite (54.339999, 9.268830) <br></p>","techniques":["Ansitzangeln","Fliegenfischen","Oberflächenangeln","Spinnangeln","Stippangeln","Vertikal"],"rules_text":"<p style=\"margin: 0px;\" align=\"left\"><b>Der Erlaubnisschein ist nur gültig in Verbindung mit einem Fischereischein mit gültiger Fischereiabgabe-Marke!\r\n</b></p><p style=\"margin: 0px;\" align=\"left\"><b>Die/der Scheininhaber*in erhält die Erlaubnis erteilt, den Fischfang mit 3 Handangeln und einer Köderfischsenke von 1 x 1 m auszuüben.</b></p><p style=\"margin: 0px;\" align=\"left\"><b><br></b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\"><b>Es ist verboten:</b></p><p style=\"margin: 0px;\" align=\"left\"><b><br></b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\">1.\tmit mehr als 3 Angeln mit max. 2 Haken pro Angel zu fischen,\r\n</p><p style=\"margin: 0px;\" align=\"left\">2.\tdie Schleppangelei zu betreiben&nbsp; (Boote, auch Bellyboote u.ä. Fahrzeuge, müssen während des Angelns festgelegt sein, die Verwendung von E-Motoren mit GPS-Ankerfunktion ist <u>nicht </u>erlaubt!)</p><p style=\"margin: 0px;\" align=\"left\">3.\tin Schöpfwerksausläufen, an / von Brücken zu fischen.<br>4. beim Fischfang elektronische Hilfsmittel (z.B. Fischfinder, Live-Sonar-Technologie o.ä.) zu verwenden, die Verwendung von Bissanzeigern ist erlaubt.&nbsp;</p><p style=\"margin: 0px;\" align=\"left\"><b><br></b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\"><b>Zur Bestandsschonung ist das Angeln mit Kunstködern sowie totem Köderfisch vom 01.01. bis einschließlich 15.05. untersagt.</b></p><p style=\"margin: 0px;\" align=\"left\"><b><br></b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\"><b>Mindestmaße und Schonzeiten:\r\n</b></p><p style=\"margin: 0px;\" align=\"left\">Aal: 50 cm, Karpfen: 35 cm, Rapfen: 50 cm, Schleie: 25 cm\r\n</p><p style=\"margin: 0px;\" align=\"left\">Zander:\t45 cm (15.03.– 15.05.)\r\n</p><p style=\"margin: 0px;\" align=\"left\">Hecht:\t45 cm (15.02.– 15.04.)\r\n</p><p style=\"margin: 0px;\" align=\"left\">Meerforelle: 40 cm (01.10.– 28.02.)\r\n</p><p style=\"margin: 0px;\" align=\"left\">Lachs:\t60 cm (01.10.– 28.02.)\r\n</p><p style=\"margin: 0px;\" align=\"left\">Es gilt immer die aktuellste Fassung des Landesfischereigesetzes Schleswig-Holstein und weiter die in der schleswig-holsteinischen Binnenfischereiverordnung (BiFVO) festgelegten Mindestmaße und Schonzeiten.</p><p style=\"margin: 0px;\" align=\"left\"><br></p><p style=\"margin: 0px;\" align=\"left\">\r\n</p><p style=\"margin: 0px;\" align=\"left\"><b>Fangbegrenzung für Zander: 3 Stück pro Tag</b></p><p style=\"margin: 0px;\" align=\"left\"><b><br></b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\">Das Kontingent ist nicht übertragbar oder anrechenbar auf andere Angler. Darüber hinaus müssen grundsätzlich alle gefangenen Fische, die das vorgeschriebene Mindestmaß erreicht haben, mitgenommen werden.</p><p style=\"margin: 0px;\" align=\"left\"><b><br></b></p><p style=\"margin: 0px;\" align=\"left\">Der/die<b> Inhaber*in</b> <b>ist verpflichtet</b>, eine <b>Fangmeldung </b>sorgfältig und vollständig zu erstellen und spätestens am Jahresende an den Pächter <b>zurückzugeben</b>!</p><p style=\"margin: 0px;\" align=\"left\"><b><br></b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\">Die Fangmeldung ist die   wichtigste Grundlage für den Besatz und für die Beweisführung in Schadensfällen.\r\n</p><p style=\"margin: 0px;\" align=\"left\"><b><br></b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p>","rules_files":[{"id":889129,"name":"eider-bei-delve-km-53-0-km-57-7-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/6ed34a39cebc1242d0332ab8cca3ab5846f1f3e4/eider-bei-delve-km-53-0-km-57-7-bestimmungen.pdf"},{"id":889130,"name":"eider-bei-delve-km-53-0-km-57-7-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/2952f55abe080325cd0481476dc9c3f616eac8be/eider-bei-delve-km-53-0-km-57-7-bestimmungen.pdf"},{"id":889131,"name":"eider-bei-delve-km-53-0-km-57-7-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/25da0b2ad991cf6b12ebbc21179709d4a620fe6b/eider-bei-delve-km-53-0-km-57-7-bestimmungen.pdf"}],"tickets":[{"name":"7-Tage-Erlaubnisschein mit Boot - Jugendpreis inkl. 3,00€ Servicegebühr","price":"12,00 EUR","ticket_type_id":7362,"price_id":101714},{"name":"7-Tage-Erlaubnisschein mit Boot - Normalpreis inkl. 3,00€ Servicegebühr","price":"21,00 EUR","ticket_type_id":7362,"price_id":101715},{"name":"7-Tage-Erlaubnisschein ohne Boot - Jugendpreis inkl. 3,00€ Servicegebühr","price":"9,00 EUR","ticket_type_id":7363,"price_id":101716},{"name":"7-Tage-Erlaubnisschein ohne Boot - Normalpreis inkl. 3,00€ Servicegebühr","price":"15,00 EUR","ticket_type_id":7363,"price_id":101717},{"name":"Jahresschein mit Boot - Jugendpreis inkl. 4,50€ Servicegebühr","price":"49,50 EUR","ticket_type_id":7364,"price_id":101718},{"name":"Jahresschein mit Boot - Normalpreis inkl. 9,00€ Servicegebühr","price":"99,00 EUR","ticket_type_id":7364,"price_id":101719},{"name":"Jahresschein ohne Boot - Jugendpreis inkl. 3,00€ Servicegebühr","price":"33,00 EUR","ticket_type_id":7365,"price_id":101720},{"name":"Jahresschein ohne Boot - Normalpreis inkl. 6,00€ Servicegebühr","price":"66,00 EUR","ticket_type_id":7365,"price_id":101721},{"name":"Ta