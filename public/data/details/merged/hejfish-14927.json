},{"lat":51.817869,"lng":6.70445},{"lat":51.817776,"lng":6.704034},{"lat":51.817718,"lng":6.70364},{"lat":51.817682,"lng":6.703224},{"lat":51.817665,"lng":6.702784},{"lat":51.817667,"lng":6.702492},{"lat":51.817684,"lng":6.702187}],[{"lat":51.822318,"lng":6.722474},{"lat":51.822404,"lng":6.723043},{"lat":51.822497,"lng":6.724159},{"lat":51.822616,"lng":6.727077},{"lat":51.822715,"lng":6.729555},{"lat":51.822755,"lng":6.730413},{"lat":51.822755,"lng":6.731207},{"lat":51.822682,"lng":6.732377},{"lat":51.822583,"lng":6.733375},{"lat":51.822576,"lng":6.733932},{"lat":51.822576,"lng":6.734372},{"lat":51.822649,"lng":6.734759},{"lat":51.823067,"lng":6.736025},{"lat":51.823153,"lng":6.7364},{"lat":51.823213,"lng":6.73669},{"lat":51.823292,"lng":6.737376},{"lat":51.823551,"lng":6.739447}]],"polygons":[],"source":"hejfish_api_map_geojson","confidence":"high"},"links":{"source":"https://www.hejfish.com/d/14927-bocholter-aa-im-gebiet-der-stadt-rhede","hejfish":"https://www.hejfish.com/d/14927-bocholter-aa-im-gebiet-der-stadt-rhede","alleangeln":"https://www.alleangeln.de/gewaesser/bocholter-aa-rhede","website":"http://www.ranv.de/gastangler","image":"https://file.hejfish.com/image/cc1200x900/f6/db/f6dba770680ff425c945b3bd763eb18dce1cbd17.jpg"},"fish":["Aal","Aland","Flussbarsch","Hecht","Zander","Wels","Schleie","Rapfen","Döbel","Brasse","Rotauge","Rotfeder","Güster","Karpfen","Brachse","Kessler-Grundel","2 weitere Fischarten"],"metadata":{"merged_fields":{"center":"hejfish","fish":["hejfish","alleangeln"],"description":"hejfish","geometry":"hejfish","water_type":"hejfish"},"sources":{"hejfish":{"platform":"hejfish","geocode_source":"hejfish_api_map_geojson","slug":"bocholter-aa-im-gebiet-der-stadt-rhede","seo_name":"Bocholter Aa im Gebiet der Stadt Rhede","description":"<p><b>Durchschnittstiefe: </b>2 m</p> <p><b>Länge:</b> 6,20 km</p>","borders":"<p>Oberlauf im Osten bis zum NSG Versunken Bokelt. Unterlauf im Westen bis zur Einmündung Kettelerbach. <br><b>Angeln an Stauwehr &amp; Fischtreppe in Krechting ist verboten!  Siehe Karte!</b></p>","techniques":["Ansitzangeln","Posenangeln","Raubfischangeln","Spinnangeln"],"rules_text":"<p><b><u>Bedingungen:</u></b></p><p>Der Erlaubnisscheininhaber erkennt die nachfolgenden <b>Bedingungen und Rechtsgrundlagen bzw. Folgen</b> an.\r\n</p><ul><li>Der Erwerber muss im Besitz eines gültigen Jahresfischereischeines sein.\r\n</li><li>Das Angeln von Brücken, vom Stauwehr und an der Fischtreppe ist verboten.\r\n</li><li>Untermaßige Fische sind schonend zurückzusetzen.\r\n</li><li>Es ist verboten, mit Köderfischen zu angeln, die nicht aus der Aa stammen.\r\n</li><li>Der Fang von Friedfischen mit Mehrfachhaken, so wie das Fischen mit mehr als einem Haken pro Rute, ist verboten.\r\n</li><li>Im übrigen gilt das Landesfischereigesetz NRW in der jeweiligen Fassung.\r\n</li><li>Der Angelplatz ist sauber zu verlassen. Verunreinigungen werden auf Kosten des Verursachers beseitigt.\r\n</li><li>Zelten, Grill- und Lagerfeuer sind verboten, ebenso das Befahren nichtöffentlicher Straßen.\r\n</li><li>Der Erlaubnisscheingeber schließt jede Haftung für Unglücksfälle, Verletzungen, Sachschaden und Ersatzansprüche aus.\r\n</li><li>Beschwerden sind schriftlich mit eingehender Begründung an den Erlaubnisscheingeber zu richten.\r\n</li><li>Der Erlaubnisschein ist ausgefüllt (siehe Fangtabelle) auch bei Nichtfang, dem Aussteller zurückzugeben.</li></ul><p><b>Art und Anzahl der erlaubten Fanggeräte</b></p><p>2 Handangeln (davon 1 mit totem Köderfisch). Bei Ausübung der Angelfischerei müssen die Handangeln unter ständiger Aufsicht sein. Setzkescher dürfen nicht verwendet werden.<br>Das Hältern der gefangenen Fische ist verboten. Der Inhaber dieser Erlaubnis darf alle Angelgeräte nur selbst führen und sie keinem anderen überlassen.</p><p><b>Mindestmaße, Schonzeiten und Fangbegrenzungen</b><br></p><p>Es gelten die Bestimmungen des Landesfischerei- gesetzes NRW in seiner jeweils gültigen Fassung - siehe Anhang.</p><p><b>Kontakt:<br></b>RANV Rhede<br>www.ranv.de <br>1.vorsitzender@ranv.de</p><p>AuGV Krechting<br>www.angelverein-krechting.de <br>info@angelverein-krechting.de</p>","rules_files":[{"id":524783,"name":"bocholter-aa-im-gebiet-der-stadt-rhede-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/8cdd86a55afbc5f29a876abd5eedfa1d375f94e2/bocholter-aa-im-gebiet-der-stadt-rhede-bestimmungen.pdf"},{"id":526177,"name":"bocholter-aa-im-gebiet-der-stadt-rhede-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/039d038d5b9b02e11045c34e90bf15c946f6d83e/bocholter-aa-im-gebiet-der-stadt-rhede-bestimmungen.pdf"}],"tickets":[{"name":"Tageskarte - Normalpreis inkl. Servicegebühr","price":"11,00 EUR","ticket_type_id":7682,"price_id":102023},{"name":"Wochenkarte - Normalpreis inkl. Servicegebühr","price":"23,00 EUR","ticket_type_id":7683,"price_id":102024},{"name":"Monatskarte - Normalpreis inkl. Servicegebühr","price":"38,50 EUR","ticket_type_id":7684,"price_id":102025}],"manager":{"id":1978,"name":"Angel- und Gewässerschutzverein Krechting 1983 e. V. |  Rheder Angel- und Naturschutzverein 1968 e.V.","street":"Steenofenkamp ","postal_code":"46414","city":"Rhede","telephone":"0162 2461101","email":"info@angelverein-krechting.de","website":"https://angelverein-krechting.de/","logo":"https://file.hejfish.com/image/r200x200/ea/72/ea72cce7d948938da8c47fdb7fa8d79b657c1df5.jpg","slug":"angel-und-gewaesserschutzverein-krechting-1983-e-v-rheder-angel-und-naturschutzverein-1968-e-v"},"season_begin":"0001-01-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":true,"boat":false,"belly_boat":false,"digital_ticket":true,"night_fishing":true,"ice_fishing":false,"depth_map":false,"has_gauges":false},"location":{"city":{"id":19287,"name":"Rhede"},"district":{"id":265,"name":"Kreis Borken"},"state":{"id":21,"name":"Nordrhein-Westfalen","slug":"nordrhein-westfalen"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"source_last_updated":"2026-05-07T11:44:53.490Z","error":false},"alleangeln":{"platform":"alleangeln","geocode_source":"alleangeln_json_ld","slug":"bocholter-aa-rhede","description":"Bocholter Aa (Rhede) ist ein Fluss in Nordrhein-Westfalen in der Nähe von Rhede. Das Gewässer wird von unseren Mitgliedern relativ stark befischt und als Top Gewässer bewertet.","followers":117,"catches_count":41,"website":"http://www.ranv.de/gastangler","best_method":"Spinnfischen","scraper_version":2,"source_last_updated":"2026-05-11T19:39:11.844Z","error":false}}},"last_updated":"2026-05-11T19:39:11.844Z"}