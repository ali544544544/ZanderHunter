2,"lng":9.393563},{"lat":54.29059,"lng":9.393493},{"lat":54.291135,"lng":9.393504},{"lat":54.291705,"lng":9.393638},{"lat":54.29183,"lng":9.393815},{"lat":54.292053,"lng":9.394163},{"lat":54.29225,"lng":9.39478},{"lat":54.292707,"lng":9.395961},{"lat":54.293092,"lng":9.397039},{"lat":54.293352,"lng":9.397688},{"lat":54.29353,"lng":9.397988},{"lat":54.294038,"lng":9.398546},{"lat":54.294507,"lng":9.399281},{"lat":54.294927,"lng":9.399753},{"lat":54.295425,"lng":9.400429},{"lat":54.295738,"lng":9.400987},{"lat":54.295847,"lng":9.401293},{"lat":54.296188,"lng":9.402553},{"lat":54.296235,"lng":9.402972},{"lat":54.296317,"lng":9.403878},{"lat":54.296257,"lng":9.404206},{"lat":54.296188,"lng":9.404292},{"lat":54.296217,"lng":9.404806}]],"source":"hejfish_api_map_geojson","confidence":"high"},"links":{"source":"https://www.hejfish.com/d/14952-neue-sorge-von-sandschleuse-bis-zur-einmuendung-in-die-eider","hejfish":"https://www.hejfish.com/d/14952-neue-sorge-von-sandschleuse-bis-zur-einmuendung-in-die-eider","alleangeln":"https://www.alleangeln.de/gewaesser/neue-sorge-christiansholm","image":"https://file.hejfish.com/image/cc1200x900/07/00/0700a6e61a5d7e6bb2dacc9614dd854df92fe496.jpg"},"fish":["Aal","Aland","Flussbarsch","Brasse","Hecht","Karpfen","Rapfen","Rotauge","Rotfeder","Schleie","Wels","Zander","Meerforelle","Atlantischer Lachs","Brachse"],"metadata":{"merged_fields":{"center":"hejfish","fish":["hejfish","alleangeln"],"description":"hejfish","geometry":"hejfish","water_type":"hejfish"},"sources":{"hejfish":{"platform":"hejfish","geocode_source":"hejfish_api_map_geojson","slug":"neue-sorge-von-sandschleuse-bis-zur-einmuendung-in-die-eider","seo_name":"Neue Sorge von Sandschleuse bis zur Einmündung in die Eider","description":"<p>Die Sorge ist ein rechter Nebenfluss der Eider und bietet dem Angler wie die Eider eine vielfältige Angelei. </p> <p>Das Angeln vom Boot ist auf der Neuen Sorge nicht erlaubt! </p>","borders":"<p>Von Sandschleuse (54.32123, 9.38651) bis bis zur Einmündung in die Eider</p>","techniques":["Ansitzangeln","Fliegenfischen","Oberflächenangeln","Spinnangeln","Stippangeln","Vertikal"],"rules_text":"<p style=\"margin: 0px;\" align=\"left\"><b>Der Erlaubnisschein ist nur gültig in Verbindung mit einem Fischereischein mit gültiger Fischereiabgabe-Marke!\r\n</b></p><p style=\"margin: 0px;\" align=\"left\"><b>Die/der Scheininhaber*in erhält die Erlaubnis erteilt, den Fischfang mit 3 Handangeln und einer Köderfischsenke von 1 x 1 m auszuüben.</b></p><p style=\"margin: 0px;\" align=\"left\"><b><br></b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\"><b>Es ist verboten:</b></p><p style=\"margin: 0px;\" align=\"left\"><b><br></b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\">1.\tmit mehr als 3 Angeln mit max. 2 Haken pro Angel zu fischen,\r\n</p><p style=\"margin: 0px;\" align=\"left\">2.\tdie Schleppangelei zu betreiben</p><p style=\"margin: 0px;\" align=\"left\">3.\tin Schöpfwerksausläufen, an / von Brücken zu fischen.<br>4. beim Fischfang elektronische Hilfsmittel (z.B. Fischfinder, Live-Sonar-Technologie o.ä.) zu verwenden, die Verwendung von Bissanzeigern ist erlaubt.&nbsp;</p><p style=\"margin: 0px;\" align=\"left\"><b><br></b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\"><b>Zur Bestandsschonung ist das Angeln mit Kunstködern sowie totem Köderfisch vom 01.01. bis einschließlich 15.05. untersagt.</b></p><p style=\"margin: 0px;\" align=\"left\"><b><br></b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\"><b>Mindestmaße und Schonzeiten:\r\n</b></p><p style=\"margin: 0px;\" align=\"left\">Aal: 50 cm, Karpfen: 35 cm, Rapfen: 50 cm, Schleie: 25 cm\r\n</p><p style=\"margin: 0px;\" align=\"left\">Zander:\t45 cm (15.03.– 15.05.)\r\n</p><p style=\"margin: 0px;\" align=\"left\">Hecht:\t45 cm (15.02.– 15.04.)\r\n</p><p style=\"margin: 0px;\" align=\"left\">Meerforelle: 40 cm (01.10.– 28.02.)\r\n</p><p style=\"margin: 0px;\" align=\"left\">Lachs:\t60 cm (01.10.– 28.02.)\r\n</p><p style=\"margin: 0px;\" align=\"left\">Es gilt immer die aktuellste Fassung des Landesfischereigesetzes Schleswig-Holstein und weiter die in der schleswig-holsteinischen Binnenfischereiverordnung (BiFVO) festgelegten Mindestmaße und Schonzeiten.</p><p style=\"margin: 0px;\" align=\"left\"><br></p><p style=\"margin: 0px;\" align=\"left\">\r\n</p><p style=\"margin: 0px;\" align=\"left\"><b>Fangbegrenzung für Zander: 3 Stück pro Tag</b></p><p style=\"margin: 0px;\" align=\"left\"><b><br></b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\">Das Kontingent ist nicht übertragbar oder anrechenbar auf andere Angler. Darüber hinaus müssen grundsätzlich alle gefangenen Fische, die das vorgeschriebene Mindestmaß erreicht haben, mitgenommen werden.</p><p style=\"margin: 0px;\" align=\"left\"><b><br></b></p><p style=\"margin: 0px;\" align=\"left\">Der/die<b> Inhaber*in</b> <b>ist verpflichtet</b>, eine <b>Fangmeldung </b>sorgfältig und vollständig zu erstellen und spätestens am Jahresende an den Pächter <b>zurückzugeben</b>!</p><p style=\"margin: 0px;\" align=\"left\"><b><br></b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\">Die Fangmeldung ist die   wichtigste Grundlage für den Besatz und für die Beweisführung in Schadensfällen.\r\n</p><p style=\"margin: 0px;\" align=\"left\"><b><br></b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p><p style=\"margin: 0px;\" align=\"left\"><b>\r\n</b></p>","rules_files":[{"id":529717,"name":"neue-sorge-von-sandschleuse-bis-pumpwerk-rinne-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/8a6596ae5617308ee6cb43b82e8827d43d857997/neue-sorge-von-sandschleuse-bis-pumpwerk-rinne-bestimmungen.pdf"},{"id":529718,"name":"neue-sorge-von-sandschleuse-bis-pumpwerk-rinne-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/e3d54ca441c989e01e6846aff65c58e50c1364f0/neue-sorge-von-sandschleuse-bis-pumpwerk-rinne-bestimmungen.pdf"},{"id":529719,"name":"neue-sorge-von-sandschleuse-bis-pumpwerk-rinne-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/63f3e2e2c9ac0c59f96e38a108aaa243b36c1926/neue-sorge-von-sandschleuse-bis-pumpwerk-rinne-bestimmungen.pdf"}],"tickets":[{"name":"Tages-Erlaubnisschein - Normalpreis inkl. 3,00€ Servicegebühr","price":"9,00 EUR","ticket_type_id":7720,"price_id":102114},{"name":"Tages-Erlaubnisschein - Jugendpreis inkl. 3,00€ Servicegebühr","price":"6,00 EUR","ticket_type_id":7720,"price_id":102115},{"name":"7-Tage-Erlaubnisschein - Normalpreis inkl. 3,00€ Servicegebühr","price":"15,00 EUR","ticket_type_id":7721,"price_id":102116},{"name":"7-Tage-Erlaubnisschein - Jugendpreis inkl. 3,00€ Servicegebühr","price":"9,00 EUR","ticket_type_id":7721,"price_id":102117},{"name":"Jahresschein - Normalpreis inkl. 6,00€ Servicegebühr","price":"66,00 EUR","ticket_type_id":7723,"price_id":102118},{"name":"Jahresschein - Jugendpreis inkl. 3,00€ Servicegebühr","price":"33,00 EUR","ticket_type_id":7723,"price_id":102119},{"name":"30-Tage-Erlaubnisschein - Normalpreis inkl. 3,60€ Servicegebühr","price":"39,60 EUR","ticket_type_id":7725,"price_id":102120},{"name":"30-Tage-Erlaubnisschein - Jugendpreis inkl. 3,00€ Servicegebühr","price":"21,00 EUR","ticket_type_id":7725,"price_id":102121}],"manager":{"id":1988,"name":"ASV \"Gut Fang\" Christiansholm/Meggerholm e.V.","street":"Bahnhofstraße 7","postal_code":"24799","city":"Christiansholm","telephone":"+49 4339 999545","email":"matams@gmx.de","website":"http://www.christiansholm.de/angelsp