zangeln","Naturköderangeln","Posenangeln","Spinnangeln"],"manager":{"id":1503,"name":"Pachtgemeinschaft Schwarzenbachtalsperre","street":"Georg Ertel Straße 1","postal_code":"76437","city":"Rastatt","telephone":"","email":"vorstand@pg-schwarzenbach.de","website":"http://www.pg-schwarzenbach.de/","logo":"https://file.hejfish.com/image/r200x200/c5/b2/c5b2d64754e2966b6123c2e760bb115f460ba6a1.png","slug":"pachtgemeinschaft-schwarzenbachtalsperre"},"season_begin":"0001-05-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":true,"boat":false,"belly_boat":false,"digital_ticket":true,"night_fishing":true,"ice_fishing":false,"depth_map":false,"has_gauges":false},"location":{"city":{"id":29319,"name":"Forbach"},"district":{"id":376,"name":"Kreis Rastatt"},"state":{"id":11,"name":"Baden-Württemberg","slug":"baden-wuerttemberg"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"source_last_updated":"2026-05-07T11:37:24.568Z","error":false},"alleangeln":{"platform":"alleangeln","geocode_source":"alleangeln_json_ld","slug":"schwarzenbachtalsperre","description":"Schwarzenbachtalsperre ist ein Stausee in Baden-Württemberg in der Nähe von Forbach. Das Gewässer wird von unseren Mitgliedern sehr stark befischt und als gutes Gewässer bewertet.","followers":1185,"catches_count":170,"images_count":31,"website":"http://asv-baden-baden.de/schwarzenbach-talsperre","best_method":"Spinnfischen","scraper_version":2,"source_last_updated":"2026-05-11T20:03:30.112Z","error":false}}},"last_updated":"2026-05-11T20:03:30.112Z"}