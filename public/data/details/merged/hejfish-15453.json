ht werden</p>","techniques":["Ansitzangeln","Feedern","Friedfischangeln","Karpfenangeln","Posenangeln","Raubfischangeln","Spinnangeln","Stippangeln"],"manager":{"id":2124,"name":"Fischereigemeinschaft Vöhringen e.V.","street":"Rothtalring 58","postal_code":"89257 ","city":"Illertissen","telephone":"+49 7306 35252","email":"info@fischereigemeinschaft-voehringen.de","website":"https://www.fischereigemeinschaft-voehringen.de/","logo":"https://file.hejfish.com/image/r200x200/76/cb/76cb8f692e2b9de7f35e868843d4f887b6ef5e01.png","slug":"fischereigemeinschaft-voehringen-e-v"},"season_begin":"0001-02-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":false,"boat":true,"belly_boat":true,"digital_ticket":true,"night_fishing":true,"ice_fishing":false,"depth_map":true,"has_gauges":false},"location":{"city":{"id":33627,"name":"Vöhringen (Iller)"},"district":{"id":435,"name":"Kreis Neu-Ulm"},"state":{"id":10,"name":"Bayern","slug":"bayern"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"source_last_updated":"2026-05-07T11:45:46.727Z","error":false},"alleangeln":{"platform":"alleangeln","geocode_source":"alleangeln_json_ld","slug":"vöhringer-see-kellerbau","description":"Vöhringer See (Kellerbau) ist ein See in Bayern in der Nähe von Vöhringen. Das Gewässer wird von unseren Mitgliedern sehr wenig befischt und als Top Gewässer bewertet.","followers":31,"catches_count":6,"images_count":0,"best_method":"Spinnfischen","source_last_updated":"2026-05-07T10:10:43.339Z","error":false}}},"last_updated":"2026-05-07T11:45:46.727Z"}