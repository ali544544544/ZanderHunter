{"id":13251,"slug":"kiesgrube-streuguthalle","url":"https://www.hejfish.com/d/13251-kiesgrube-streuguthalle","name":"Kiesgrube Streuguthalle","seo_name":"Kiesgrube Streuguthalle","description":"<p>Das Gewässer bietet meist schlammigen Untergrund, jedoch sind auch einige Plateaus mit fester Bodenstruktur vorhanden. Im vorderen Teil gibt es meist steile Angelplätze entlang des Weges, ansonsten sind die anderen Plätze alle gut begehbar und anfahrbar. Sehr guter Fischbestand aller Arten, es werden besonders oft größere Raubfische, insbesondere Waller gefangen. An der Vorderseite, zur B14 gerichtet, befindet sich eine offizielle Feuerstelle. Größe ca. 2,6ha und Tiefen von 1 bis 3 Meter.</p>","intro":"","details":"","borders":"<p>Kiesgrube Streuguthalle in Wernberg an der B14. Das gesamte Gewässer darf befischt werden.</p>","image":"https://file.hejfish.com/image/cc1200x900/a3/c4/a3c4f7e856a9d007b9e5c55276a825afc2373c39.jpeg","water_size_ha":null,"fish":["Wels","Hecht","Zander","Aal","Karpfen","Schleie","Rotauge","Rotfeder","Brasse"],"techniques":["Ansitzangeln","Feedern","Posenangeln","Spinnangeln"],"properties":[],"water_type":"See","rules_text":"","rules_files":[],"tickets":[],"ticket_types":[],"manager":{"id":1797,"name":"Sportanglerbund Wernberg-Köblitz e. V.","street":"Kärntnerstraße 8","postal_code":"92533","city":"Wernberg-Köblitz","telephone":"","email":"","website":"http://www.sab-wernberg.de","logo":"https://file.hejfish.com/image/r200x200/d3/66/d3668bd4f68a2349b79c3d2d5171b30ebf4a6a1c.jpeg","slug":"sportanglerbund-wernberg-koeblitz-e-v"},"season_begin":"0001-01-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":false,"boat":false,"belly_boat":false,"digital_ticket":true,"night_fishing":true,"ice_fishing":false,"depth_map":false,"has_gauges":false},"location":{"city":{"id":34695,"name":"Wernberg-Köblitz"},"district":{"id":455,"name":"Kreis Schwandorf"},"state":{"id":10,"name":"Bayern","slug":"bayern"},"country":{"id":2,"name":"Deuts