g":7.07011}],[{"lat":49.562021,"lng":7.066205},{"lat":49.562105,"lng":7.067664},{"lat":49.563719,"lng":7.066998},{"lat":49.56596,"lng":7.065797},{"lat":49.565835,"lng":7.06481},{"lat":49.565612,"lng":7.064338},{"lat":49.565264,"lng":7.064338},{"lat":49.565097,"lng":7.064359},{"lat":49.565181,"lng":7.064767},{"lat":49.565473,"lng":7.064939},{"lat":49.565584,"lng":7.064981},{"lat":49.565654,"lng":7.065153},{"lat":49.565431,"lng":7.065582},{"lat":49.56532,"lng":7.065475},{"lat":49.565139,"lng":7.065046},{"lat":49.564777,"lng":7.064853},{"lat":49.564373,"lng":7.064874},{"lat":49.563009,"lng":7.065969},{"lat":49.562188,"lng":7.066269}]],"source":"hejfish_api_map_geojson","confidence":"high"},"links":{"source":"https://www.hejfish.com/d/14816-bostalsee","hejfish":"https://www.hejfish.com/d/14816-bostalsee","alleangeln":"https://www.alleangeln.de/gewaesser/bostalsee","image":"https://file.hejfish.com/image/cc1200x900/39/5a/395a713cafdc9fd7908e7c79adc26252793bf91e.jpeg"},"fish":["Aal","Div. Weißfische","Flussbarsch","Forelle","Hecht","Zander","Wildkarpfen","Karpfen","Wels","9 weitere Fischarten"],"metadata":{"merged_fields":{"center":"hejfish","fish":["hejfish","alleangeln"],"description":"hejfish","geometry":"hejfish","water_type":"hejfish"},"sources":{"hejfish":{"platform":"hejfish","geocode_source":"hejfish_api_map_geojson","slug":"bostalsee","seo_name":"Bostalsee","description":"<h3><b>Vom 01.01. bis 15.02. besteht für den Fischereibezirk Bostalsee Angelsperre.</b></h3> <h3><b>Hinweis für Bootsangler:</b></h3> <h5><b>Angelboote dürfen nicht mit Elektro- oder Benzinmotoren betrieben werden!<br>Der Erwerb eines Boots Erlaubnisscheins ist unbedingt erforderlich (gilt auch für Schlauchboote, Kajaks, usw.). Außerhalb der Wassersportsaison (15.03. – 31.10.) erfolgt das Angeln vom Boot aus auf eigene Gefahr.<br></b></h5> <p>Idyllisch eingebettet in die Mittelgebirgslandschaft des Naturparks Saar-Hunsrück liegen das Sankt Wendeler Land und der 120 Hektar große Bostalsee. Er bietet viel Platz für alle, die ihre Freizeit gerne am, auf oder im Wasser verbringen möchten. Zwei große Sandstrände und Liegewiesen laden zum Baden, Beach-Volleyball oder Sandburgen bauen ein. Freizeit total mit Tretboot fahren, Surfen und Segeln, Spielen, Wandern oder Radeln.<br></p> <p>Der Bostalsee bietet auch Orte der Ruhe: denen, die in morgendlicher Stille vom Boot oder Ufer aus angeln oder einfach nur um den See wandern möchten.</p> <p>Im Bostalsee gibt es Aale, Forellen, Zander und Hechte. Dieser reichhaltige Fischbesatz und die gute Wasserqualität machen den Bostalsee zu einem beliebten Angelgewässer. Es kann von verschiedenen Uferzonen, aber auch vom Tret- oder Ruderboot aus geangelt werden.<br></p>","borders":"<p><b>Verbotszonen siehe Bostalsee-Angelbestimmungen mit Karte! Verbotszonen sind unbedingt zu beachten.</b></p>","techniques":["Ansitzangeln","Feedern","Fliegenfischen","Friedfischangeln","Karpfenangeln","Oberflächenangeln","Posenangeln","Raubfischangeln","Spinnangeln","Stippangeln","Vertikal"],"rules_text":"<h1 align=\"left\"><b>Angelbestimmungen siehe Anhang!</b></h1><h5 align=\"left\"><b>Die Bestimmungen sind unbedingt zu beachten!<br></b></h5>","rules_files":[{"id":1386513,"name":"bostalsee-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/b05a8eac43498433b483f62ee9c6b84efbb522de/bostalsee-bestimmungen.pdf"},{"id":1428242,"name":"bostalsee-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/826c4563cbb72ca6429fba57ce0a49dccaa5c9a7/bostalsee-bestimmungen.pdf"},{"id":1418663,"name":"jahreskarte-erwachsene-inkl-bootskarte-ohne-parkschein-eigenes-boot-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/baa950bfacbe568c2a6a615afcd647e5f52cd44d/jahreskarte-erwachsene-inkl-bootskarte-ohne-parkschein-eigenes-boot-bestimmungen.pdf"},{"id":1425330,"name":"jahreskarte-erwachsene-inkl-bootskarte-ohne-parkschein-eigenes-boot-bestimmungen","description":null,"file":"https://