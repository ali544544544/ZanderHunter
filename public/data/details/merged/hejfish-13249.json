{"id":13249,"slug":"kiesgrube-foereth","url":"https://www.hejfish.com/d/13249-kiesgrube-foereth","name":"Kiesgrube Företh","seo_name":"Kiesgrube Företh","description":"<p>Größtenteils fester Gewässergrund, an manchen Stellen leichter bis mittelmäßiger Krautbewuchs. Die Grube ist von allen Seiten gut befischbar. Guter Bestand aller Fischarten, insbesondere von großen Welsen und großen Karpfen. Die Angelplätze sind meist flach und daher gut für Gehbehinderte und ältere Angler erreichbar. Dennoch gibt es auch leicht abfallende Plätze. Größe ca. 7ha und Tiefen von 0,5 bis 3 Meter.</p>","intro":"","details":"","borders":"<p>Kiesgrube Företh zwischen Luhe und Unterwildenau bei der Autobahnausfahrt A93 Luhe-Wildenau. Das gesamte Gewässer darf befischt werden.\n</p>","image":"https://file.hejfish.com/image/cc1200x900/77/8a/778a4978e3824a38c5a443d449228c4b08af1fb4.jpeg","water_size_ha":null,"fish":["Karpfen","Wels","Hecht","Zander","Aal","Schleie","Rotauge","Rotfeder","Brasse"],"techniques":["Ansitzangeln","Feedern","Posenangeln","Spinnangeln"],"properties":[],"water_type":"See","rules_text":"","rules_files":[],"tickets":[],"ticket_types":[],"manager":{"id":1797,"name":"Sportanglerbund Wernberg-Köblitz e. V.","street":"Kärntnerstraße 8","postal_code":"92533","city":"Wernberg-Köblitz","telephone":"","email":"","website":"http://www.sab-wernberg.de","logo":"https://file.hejfish.com/image/r200x200/d3/66/d3668bd4f68a2349b79c3d2d5171b30ebf4a6a1c.jpeg","slug":"sportanglerbund-wernberg-koeblitz-e-v"},"season_begin":"0001-01-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":false,"boat":true,"belly_boat":true,"digital_ticket":true,"night_fishing":true,"ice_fishing":false,"depth_map":false,"has_gauges":false},"location":{"city":{"id":34504,"name":"Luhe-Wildenau"},"district":{"id":450,"name":"Kreis Neustadt an der Waldnaab"},"state":{"id":10,"name":"Bayern","slug":"bayern"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"product