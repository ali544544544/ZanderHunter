62,"lng":10.61812},{"lat":52.454225,"lng":10.617889},{"lat":52.453744,"lng":10.617755},{"lat":52.453497,"lng":10.617712},{"lat":52.453296,"lng":10.61779},{"lat":52.4532,"lng":10.617857},{"lat":52.453141,"lng":10.617927},{"lat":52.452986,"lng":10.618179},{"lat":52.452763,"lng":10.619069},{"lat":52.452456,"lng":10.620239},{"lat":52.452204,"lng":10.620636},{"lat":52.452067,"lng":10.620689},{"lat":52.451956,"lng":10.620561},{"lat":52.451818,"lng":10.620518},{"lat":52.451763,"lng":10.620518}],[{"lat":52.45104,"lng":10.618249},{"lat":52.45099,"lng":10.618096},{"lat":52.450839,"lng":10.617707},{"lat":52.450583,"lng":10.61717},{"lat":52.450323,"lng":10.616626},{"lat":52.450146,"lng":10.616248},{"lat":52.450022,"lng":10.616022},{"lat":52.449929,"lng":10.615751},{"lat":52.449903,"lng":10.615556},{"lat":52.449484,"lng":10.616103},{"lat":52.450694,"lng":10.618683}]],"source":"hejfish_api_map_geojson","confidence":"high"},"links":{"source":"https://www.hejfish.com/d/13361-tankumsee","hejfish":"https://www.hejfish.com/d/13361-tankumsee","alleangeln":"https://www.alleangeln.de/gewaesser/tankumsee","website":"http://www.asv-isenbuettel.eu/","image":"https://file.hejfish.com/image/cc1200x900/25/f2/25f279a92a96aa36ee7a28253b6e55bc64996164.jpeg"},"fish":["Schleie","Karpfen","Forelle","Aal","Zander","Hecht","Flussbarsch","Gründling","Giebel","Rotauge","Rotfeder","Brasse","Regenbogenforelle","Brachse","5 weitere Fischarten"],"metadata":{"merged_fields":{"center":"hejfish","fish":["hejfish","alleangeln"],"description":"hejfish","geometry":"hejfish","water_type":"hejfish"},"sources":{"hejfish":{"platform":"hejfish","geocode_source":"hejfish_api_map_geojson","slug":"tankumsee","seo_name":"Tankumsee","description":"<p><b>Nachtangeln nur mit gesonderter Karte erlaubt!</b></p> <p>Der beim Bau des Elbe-Seitenkanals entstandene und 1976 eingeweihte Tankumsee befindet sich in der Samtgemeinde Isenbüttel im Landkreis Gifhorn (Niedersachsen). Er liegt etwa 3,3 km nordöstlich vom Ortszentrum Isenbüttel entfernt. Am See ist ein Naherholungsgebiet mit Ferienhäusern entstanden. </p> <p>1972 gründeten verschiedene Einrichtungen und kommunale Behörden die Tankumsee-Planungs- und Ausbaugesellschaft (heute: Tankumsee Betriebsgesellschaft mbH). Sie erwarb und erschloss das spätere Erholungsgebiet. Offizielle Inbetriebnahme des Tankumsees war der 26. Juni 1976. </p> <p><b>Kurzbeschreibung allgemein: </b></p> <p>ca. 62 ha Seefläche </p> <p>durchschnittliche Tiefe ca. 4-6m ( im Uferbereich) </p> <p>Tiefste Stelle ca. 20m </p> <p><b>Angelzeit: </b></p> <p>Ganzjährig vom 01.01. bis 31.12 von 00.00 Uhr bis 24.00 Uhr unter Beachtung der Schonzeiten. </p> <p><b>Angelplätze: </b></p> <p>Das Angeln ist nur vom Ufer aus gestattet. Zu beangeln ist die gesamte Seefläche. In der Zeit vom 01.05. bis 15.09. ist das Angeln in der Badezone untersagt. (Rote Zone, siehe Gewässerkarte)</p>","borders":"<p>Angelverbotszonen siehe Bestimmungen. </p>","techniques":["Ansitzangeln","Feedern","Posenangeln","Spinnangeln"],"rules_text":"<p><b><u>Bestimmungen:</u></b></p><p><b>Angelzeit:\r\n</b>Ganzjährig vom 01.01. bis 31.12 von 00.00 Uhr bis 24.00 Uhr unter Beachtung der Schonzeiten.<br><b>Nachtangeln über Datumsgrenze mit Nachtangelkarte oder Mehrtageskarten. </b></p><p><b>Angelplätze: </b>Das Angeln ist nur vom Ufer aus gestattet. Zu beangeln ist die gesamte Seefläche. In der Zeit vom 01.05. bis 15.09. ist das Angeln in der Badezone untersagt. </p><p><b>Zugelassene Fanggeräte<br></b><u>Gastangler:</u><br>Vom 01.01. - 30.04. = 2 Handangeln mit je einem Haken.<br>Vom 01.05. - 31.12. = 2 Handangeln mit je einem Haken, davon kann 1 Handangel auf Raubfisch ausgelegt werden (Drilling erlaubt) - oder statt der Handangeln 1 Spinn- bzw. Fliegenrute.</p><p><b>Raubfischangeln</b><br>Vom 01.05. bis zum 31.12.<br>Köder: Stückfisch, Fischfetzen, toter Köderfisch, künstlicher Köder.<br><b>Stahlvorfach ist beim Fischen auf Raubfisch Pflicht! </b></p><p><b>Die Verwendung von lebenden Köderfischen ist verboten.</b></p><p><b>Mindestmaße (Schonzeiten)<br></b>Schleie = 25 cm // Forelle = 25 cm (1.1.-30.4.)<br>Karpfen = 40 cm // Hecht = 50 cm (1.1.-30.4.)<br>Aal = 45 cm // Zander = 50 cm (1.1.-30.4.)</p><p><b>Beschränkungen<br></b>Forelle, Karpfen, Hecht, Zander, Schleie: pro Tag und Edelfischart 2 Stück<br>Keine Entnahmebeschränkungen für Weißfische!<br>Weitere gefangene Fische dieser Art sind sofort wieder einzusetzen.<br>Hälterung von Barsch, Forelle, Hecht und Zander sind verboten.<br>Spinnangeln vom 1.1.-30.4. jeden Jahres verboten.</p>","rules_files":[{"id":275824,"name":"tankumsee-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/0a89e8a2ac29618e72a8ab8a6d70fb450994e604/tankumsee-bestimmungen.pdf"}],"tickets":[{"name":"Tageskarte (00:00-23:59) - Normalpreis inkl. Servicegebühr","price":"13,00 EUR","ticket_type_id":3490,"price_id":95527},{"name":"Nachtangelkarte (18:00-08:00) - Normalpreis inkl. Servicegebühr","price":"16,00 EUR","ticket_type_id":3491,"price_id":95528},{"name":"Wochenkarte - Normalpreis inkl. Servicegebühr","price":"44,00 EUR","ticket_type_id":3492,"price_id":95529},{"name":"Monatskarte - Normalpreis inkl. Servicegebühr","price":"88,00 EUR","ticket_type_id":3493,"price_id":95530}],"manager":{"id":1822,"name":"ASV Samtgemeinde Isenbüttel e.V.","street":"Dannenbütteler Weg 1 ","postal_code":" 38550","city":"Isenbüttel","telephone":"0175/1998464","email":"kolmer.holger@t-online.de","website":"http://www.asv-isenbuettel.eu/index.html","logo":"https://file.hejfish.com/image/r200x200/a0/e7/a0e73bf5a7825141aa4acf9c002cacf28b32a838.jpeg","slug":"asv-samtgemeinde-isenbuettel-e-v"},"season_begin":"0001-01-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":false,"boat":false,"belly_boat":false,"digital_ticket":false,"night_fishing":true,"ice_fishing":false,"depth_map":true,"has_gauges":false},"location":{"city":{"id":13358,"name":"Isenbüttel"},"district":{"id":196,"name":"Kreis Gifhorn"},"state":{"id":22,"