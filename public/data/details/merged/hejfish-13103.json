tadata":{"merged_fields":{"center":"hejfish","fish":["hejfish","alleangeln"],"description":"hejfish","geometry":"hejfish","water_type":"hejfish"},"sources":{"hejfish":{"platform":"hejfish","geocode_source":"hejfish_api_map_geojson","slug":"der-ludwig-donau-main-kanal","seo_name":"Der Ludwig-Donau-Main-Kanal","description":"<p>1825 beschloss König Ludwig I., einen Kanal zur Verbindung des Rheins mit der Donau zu bauen. 1835 begannen die Bauarbeiten, die 1846 mit der Fertigstellung beendet wurden. Die gesamte Länge des \"alten Kanals\" von Kehlheim bis Bamberg beträgt 175 km und hat über 100 Schleusen. Am 09. Oktober 1943 befuhr das letzte Schiff, die „Walhalla“, den Kanal auf dem Weg nach Kehlheim. In dem nahe gelegenen Ort Schwarzenbach fährt heute wieder das Treidelschiff Elfriede als Touristenattraktion Richtung Neumarkt.<br></p>","borders":"<p>Unser Verein bewirtschaftet ein ca. 6 Kilometer langes Teilstück, das am kleinen Einschnitt bei Rasch beginnt und an der Schleuse 33 bei Burgthann (Rübleinshof) endet. <br></p>","techniques":["Ansitzangeln","Feedern","Friedfischangeln","Karpfenangeln","Posenangeln","Raubfischangeln","Spinnangeln"],"rules_text":"<p><u><b>Gewässerordnung und Gewässerspezifische Regelungen entnehmen Sie dem PDF.<br></b></u></p><p><u>Abweichende Schonzeiten & Mindestmaße:</u></p>\r\n\r\n<style type=\"text/css\">\r\n\ttable.tableizer-table {\r\n\t\tfont-size: 10px;\r\n\t\tborder: 1px solid #000; \r\n\t\tfont-family: Arial, Helvetica, sans-serif;\r\n\t} \r\n\t.tableizer-table td {\r\n\t\tpadding: 1px;\r\n\t\tmargin: 1px;\r\n\t\tborder: 1px solid #000;\r\n\t}\r\n\t.tableizer-table th {\r\n\t\tbackground-color: #00C1D6; \r\n\t\tcolor: #000;\r\n\t\tfont-weight: bold;\r\n\t}\r\n</style>\r\n<table class=\"tableizer-table\">\r\n<thead><tr class=\"tableizer-firstrow\"><th>Fischart</th><th>Schonmaß in cm</th><th>Schonzeit</th></tr></thead><tbody>\r\n <tr><td>Bachforelle </td><td>28*</td><td>01.10. bis einschl. 15.03</td></tr>\r\n <tr><td>Regenbogenforelle</td><td>28*</td><td>15.12. bis einschl. 15.03.</td></tr>\r\n <tr><td>Äsche</td><td>35*</td><td>01.01. bis einschl. 30.04</td></tr>\r\n <tr><td>Äsche (Nur Wiesent)</td><td>45*</td><td>01.12. bis einschl. 30.04.</td></tr>\r\n <tr><td>Barbe</td><td>40 bzw. 50* (Schwarzach)</td><td>01.05. bis einschl. 30.06.</td></tr>\r\n <tr><td>Hecht und Zander</td><td>50</td><td>15.02. bis einschl. 30.04.</td></tr>\r\n <tr><td>Rutte</td><td>40 bzw. 45* (Schwarzach)</td><td>keine</td></tr>\r\n <tr><td>Aal</td><td>50</td><td>01.11. bis einschl. 28.02.</td></tr>\r\n <tr><td>Schleie</td><td>28*</td><td>01.05. bis einschl. 30.06.</td></tr>\r\n <tr><td>Karpfen</td><td>35</td><td>keine</td></tr>\r\n</tbody></table>\r\n\r\n<p>*In Abstimmung mit der Fachberatung für Fischerei<br>Des Weiteren gelten die Schonmaße und die Schonzeiten des Bayerischen Fischereigesetzes und der entsprechenden Bezirksfischereiverordnungen. Während der Raubfisch Schonzeit ist das Spinnangeln verboten.</p><p><u><b>Fanglimit pro Tag </b></u><br></p><ul><li>1 Stück Karpfen</li><li>2 Stück Schleie</li><li>1 Stück Hecht oder Zander*  </li><li>2 Stück Aal</li><li>1 Stück Waller</li><li>2 Stück Salmoniden Schonzeit: Bachforelle</li></ul><p><i>*Keine Beschränkung auf Hecht oder Zander an den Gewässern Schwarzach/Gsteinach, die Wiesent, Schwarzach/Burgthann und Schwarzach Rasch/Gründsberg</i></p><p><b>Liebe Fischerkollegen, \r\n</b></p><p>es freut uns sehr, dass Sie ein paar schöne Stunden an unserem Gewässer verbringen möchten.\r\n</p><p>Hier einige Worte, über die jeder mal für sich nachdenken sollte:\r\n</p><p>An unseren Gewässern suchen wir Erholung und Entspannung.\r\n</p><p>Unsere knapp bemessene Freizeit wollen wir sinnvoll gestalten und die Stunden am Wasser dazu nutzen, um wieder Kontakt mit der Natur zu knüpfen, der in der Hektik des Alltags verloren zu gehen droht.\r\n</p><p>Um diese Erwartungen erfüllen zu können, sollte sich jeder Angler am Gewässer und in der ihn umgebenden Landschaft so verhalten, als sei dieses Gebiet sein Eigentum, das er nach besten Kräften schonen, hegen und vor Beschädigung und Verunreinigung schützen muss.\r\n</p><p>Sie leisten damit auch einen erheblichen Beitrag zur Verwirklichung und Umsetzung eines unserer Leitziele, nämlich des Umweltschutzes.\r\n</p><p>Vielen Dank,\r\n</p><p>ihr Fischereiverein Altdorf</p><p><i>\r\n</i></p><p><i>\r\n</i></p><p><i>\r\n</i></p><p></p><style type=\"text/css\">\r\n\ttable.tableizer-table {\r\n\t\tfont-size: 12px;\r\n\t\tborder: 1px solid #000; \r\n\t\tfont-family: Arial, Helvetica, sans-serif;\r\n\t} \r\n\t.tableizer-table td {\r\n\t\tpadding: 4px;\r\n\t\tmargin: 3px;\r\n\t\tborder: 1px solid #000;\r\n\t}\r\n\t.tableizer-table th {\r\n\t\tbackground-color: #104E8B; \r\n\t\tcolor: #FFF;\r\n\t\tfont-weight: bold;\r\n\t}\r\n</style>","rules_files":[{"id":422225,"name":"der-ludwig-donau-main-kanal-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/3fb2d73b7dad620cec8abd86d92e719a70f89d27/der-ludwig-donau-main-kanal-bestimmungen.pdf"}],"tickets":[{"name":"Tageskarte - Normalpreis inkl. Servicegebühr","price":"18,00 EUR","ticket_type_id":3024,"price_id":92294},{"name":"Tageskarte - Jugendpreis inkl. Servicegebühr","price":"10,50 EUR","ticket_type_id":3024,"price_id":92310}],"manager":{"id":1752,"name":"Fischereiverein Altdorf b. Nürnberg","street":"Altdorfer Str. 3","postal_code":"90559","city":"Burgthann","telephone":"","email":"tageskarte@fischereiverein-altdorf.de","website":"https://www.fischereiverein-altdorf.com","logo":"https://file.hejfish.com/image/r200x200/83/1e/831e4c7fc70d23db8e2cac4dc41f213d582abea0.jpeg","slug":"fischereiverein-altdorf-b-nuernberg"},"season_begin":"0001-01-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":false,"boat":false,"belly_boat":false,"digital_ticket":true,"night_fishing":true,"ice_fishing":false,"depth_map":false,"has_gauges":false},"location":{"city":{"id":33883,"name":"Altdorf bei Nürnberg"},"district":{"id":439,"name":"Kreis Nürnberger Land"},"state":{"id":10,"name":"Bayern","slug":"bayern"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"source_last_updated":"2026-05-07T11:42:06.023Z","error":false},"alleangeln":{"platform":"alleangeln","geocode_source":"alleangeln_json_ld","slug":"ludwig-donau-main-kanal-schwarzenbach","description":"Ludwig-Donau-Main-Kanal (Schwarzenbach) ist ein Kanal in Bayern in der Nähe von Burgthann. Das Gewässer wird von unseren Mitgliedern relativ stark befischt und als Top Gewässer bewertet.","followers":96,"catches_count":27,"images_count":6,"website":"http://www.fischereiverein-altdorf.com/","best_method":"Posenfischen","scraper_version":2,"source_last_updated":"2026-05-11T19:28:17.342Z","error":false}}},"last_updated":"2026-05-11T19:28:17.342Z"}