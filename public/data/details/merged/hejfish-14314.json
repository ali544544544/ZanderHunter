re Fischarten:</b></div>Hauptfischarten sind Hecht, Karpfen, Plötze, Rotfeder und Schleie.<br></div> <div><br></div> <p> </p>","borders":"<p><b>Der gesamte See darf beangelt werden! </b></p>","techniques":["Ansitzangeln","Feedern","Posenangeln","Spinnangeln","Friedfischangeln","Naturköderangeln","Stippangeln"],"manager":{"id":1875,"name":"Magdeburger Anglerverein e. V. - INAKTIV","street":"Beimsstr. 89 a ","postal_code":"39110","city":"Magdeburg","telephone":"+49 391 8113033","email":"info@magdeburger-anglerverein.de","website":"https://www.magdeburger-anglerverein.de/","logo":"https://file.hejfish.com/image/r200x200/63/1a/631a65e4dfec68285fa47ba582239e084f563a01.jpeg","slug":"magdeburger-anglerverein-e-v-inaktiv"},"season_begin":"0001-01-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":false,"boat":false,"belly_boat":false,"digital_ticket":true,"night_fishing":true,"ice_fishing":false,"depth_map":true,"has_gauges":false},"location":{"city":{"id":16887,"name":"Magdeburg"},"district":{"id":239,"name":"Magdeburg"},"state":{"id":17,"name":"Sachsen-Anhalt","slug":"sachsen-anhalt"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"source_last_updated":"2026-05-07T11:44:15.662Z","error":false},"alleangeln":{"platform":"alleangeln","geocode_source":"alleangeln_json_ld","slug":"dr-götz-teich-magdeburg","description":"Dr.-Götz-Teich (Magdeburg) ist ein Teich in Sachsen-Anhalt in der Nähe von Magdeburg. Das Gewässer wird von unseren Mitgliedern relativ stark befischt und als durchschnittliches Gewässer bewertet.","followers":79,"catches_count":28,"images_count":7,"website":"http://www.magdeburger-anglerverein.de/","best_method":"Posenfischen","scraper_version":2,"source_last_updated":"2026-05-11T19:28:39.293Z","error":false}}},"last_updated":"2026-05-11T19:28:39.293Z"}