9.467146},{"lat":53.163916,"lng":9.467125},{"lat":53.164017,"lng":9.467173},{"lat":53.164052,"lng":9.467243},{"lat":53.164048,"lng":9.467364},{"lat":53.163879,"lng":9.467514},{"lat":53.163896,"lng":9.46764},{"lat":53.164049,"lng":9.467745},{"lat":53.164223,"lng":9.467602},{"lat":53.164433,"lng":9.467876},{"lat":53.164671,"lng":9.468268},{"lat":53.164752,"lng":9.468721},{"lat":53.164797,"lng":9.469072},{"lat":53.164847,"lng":9.469405},{"lat":53.164903,"lng":9.469678},{"lat":53.164934,"lng":9.46981}]],"source":"hejfish_api_map_geojson","confidence":"high"},"links":{"source":"https://www.hejfish.com/d/12921-wuemme-bei-scheessel","hejfish":"https://www.hejfish.com/d/12921-wuemme-bei-scheessel","alleangeln":"https://www.alleangeln.de/gewaesser/wümme-scheeßel","website":"http://www.asv-scheessel.de/","image":"https://file.hejfish.com/image/cc1200x900/26/fd/26fdc068d9abec013b29d872de2dcf7627dc92b9.jpeg"},"fish":["Aal","Hecht","Flussbarsch","Karpfen","Quappe","Forelle","Div. Weißfische","Bachforelle","Brachse","3 weitere Fischarten","Meerforelle"],"metadata":{"merged_fields":{"center":"hejfish","fish":["hejfish","alleangeln"],"description":"hejfish","geometry":"hejfish","water_type":"hejfish"},"sources":{"hejfish":{"platform":"hejfish","geocode_source":"hejfish_api_map_geojson","slug":"wuemme-bei-scheessel","seo_name":"Wümme bei Scheeßel","description":"<p><b>Das Fließgewässer des ASV Scheeßel</b></p> <p>Auf einer Länge von insgesamt ca. <b>10 km</b> bietet sich dem Angler ein abwechslungsreiches Bild. Die Breite der Wümme variiert von 5m bis 15m. </p> <p>Der Obere, 7 Kilometer messende Flussabschnitt der Wümme, in der Nähe von Lauenbrück gelegen, ist als eher flach zu bezeichnen. Zum Ende des Pachtabschnitts hin, der die Grenze zum ASV Scheeßeler Mühle markiert, wird der Fluss allmählig breiter, tiefer und langsam fließender – zum einen macht sich der Einfluss des Staus an der Mühle bemerkbar, zum anderen nimmt die Wümme in diesem Bereich noch die Beeke auf.</p> <p>Der zweite Abschnitt beginnt etwa 600 m unterhalb der Scheeßeler Mühle; ein ca. 3km langes Teilstück, dessen Ende die Grenze zum Angelverein Wohlsdorf markiert. Die Strömung ist in diesem Bereich wechselhaft, die Wassertiefe liegt durchschnittlich bei etwa 1 m, erreicht mitunter aber auch 2,5 Meter.</p> <p>Bis zur Einmündung der Veerse – flußabwärts betrachtet – darf dieser Abschnitt von beiden Uferseiten beangelt werden, dahinter nur von der rechten Uferseite.</p>","borders":"<p>Gewässer-Grenzen siehe Bestimmungen!</p>","techniques":["Ansitzangeln","Feedern","Fliegenfischen","Friedfischangeln","Naturköderangeln","Posenangeln","Spinnangeln","Stippangeln","Raubfischangeln"],"rules_text":"<p><b><u>Gewässergrenzen:\r\n</u></b></p><p><u>In der Wümme :\r\n<br></u>Beidseitig von der Lauenbrücker Grenze (Geodaten: 53.197418, 9.514184) bis zur Grenze Scheeßeler Mühle (Geodaten 53.166489, 9.473743). Ca. 800 m unterhalb der Grenze Scheeßeler Mühle (Geodaten 53.159113, 9.459431) beidseitig bis zur Einmündung der Veerse (Geodaten 53.149349, 9.459512). <br>Ab Veerse-Einmündung (Geodaten 53.149349, 9.459512) linke Uferseite ca. 1500 m abwärts bis Grenzschild (Geodaten 53.143108, 9.445003) </p><p><u><b>Bestimmungen</b></u>\r\n:</p><p>Der Erwerber einer Gastkarte darf mit 3 Handangeln angeln und muss den Nachweis einer Fischerprüfung haben. \r\nEbenso soll im Anschluss an das Angeln eine Fangliste abgegeben werden. </p><p>Beim Fischfang dürfen keine Wasserfahrzeuge benutzt werden. </p><p><b>Verboten ist : \r\n</b></p><p>das Befahren der Privatwege und Wiesen mit Fahrzeugen aller Art, das Aussetzen von Aalschnüren, Fischkörben und Reusen sowie das Angeln mit lebenden Köderfischen, unerlaubte Lagerfeuer, Verunreinigungen und Aufgrabungen der Wiesen.\r\n</p><p>Ein Verstoß wird mit Sperrung geahndet werden.\r\n</p><p>Der Erlaubnisschein ist stets mitzuführen und den sich ausweisenden Kontrollberechtigten auf Verlangen vorzulegen.\r\n</p><p>Auf das Niedersächsische Fischereigesetz (Nds.FischG) wird hingewiesen.</p><p>\r\n</p><p><b><u>Entnahme:</u></b></p><p>Die Entnahmemenge liegt pro Tag  auf 1 Hecht, 1 Zander, 1 Karpfen und 1 Schleie. Alle anderen Fischarten unterliegen keiner Fangbegrenzung. </p><p><b><u><br></u></b></p><p><b><u> </u></b></p>","rules_files":[{"id":124157,"name":"wuemme-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/09539ae61f2ce9450389550f8fc9a39a49349f55/wuemme-bestimmungen.pdf"},{"id":526072,"name":"wuemme-bei-scheessel-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/3c84287f9a52b711437525f86316ac8293a4686b/wuemme-bei-scheessel-bestimmungen.pdf"}],"tickets":[{"name":"Tageskarte - Normalpreis inkl. Servicegebühr","price":"13,00 EUR","ticket_type_id":2693,"price_id":94789},{"name":"Wochenkarte - Normalpreis inkl. Servicegebühr","price":"33,00 EUR","ticket_type_id":2694,"price_id":94790}],"manager":{"id":1697,"name":"Angelsportverein Scheeßel e.V. ","street":"Mühlenweg 42 ","postal_code":"27383","city":"Scheeßel","telephone":"0049 4263 5241","email":"info@asv-scheessel.de","website":"http://www.asv-scheessel.de/","logo":"https://file.hejfish.com/image/r200x200/27/ec/27ec91355f44691c91d2b6c774dcd78e06bfd71e.jpeg","slug":"angelsportverein-scheessel-e-v"},"season_begin":"0001-01-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":true,"boat":false,"belly_boat":false,"digital_ticket":true,"night_fishing":true,"ice_fishing":false,"depth_map":false,"has_gauges":false},"location":{"city":{"id":12822,"name":"Scheeßel"},"district":{"id":190,"name":"Kreis Rotenburg (Wümme)"},"state":{"id":22,"name":"Niedersachsen","slug":"niedersachsen"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"source_last_updated":"2026-05-07T11:41:47.085Z","error":false},"alleangeln":{"platform":"alleangeln","geocode_source":"alleangeln_json_ld","slug":"wümme-scheeßel","description":"Wümme (Scheeßel) ist ein Fluss in Niedersachsen in der Nähe von Scheeßel. Das Gewässer wird von unseren Mitgliedern sehr stark befischt und als Top Gewässer bewertet.","followers":379,"catches_count":91,"images_count":4,"website":"http://www.asv-scheessel.de/","best_method":"Spinnfischen","scraper_version":2,"source_last_updated":"2026-05-11T19:55:53.179Z","error":false}}},"last_updated":"2026-05-11T19:55:53.179Z"}