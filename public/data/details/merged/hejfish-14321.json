1006,"lng":11.713598},{"lat":52.080848,"lng":11.712563},{"lat":52.080775,"lng":11.711989},{"lat":52.080732,"lng":11.710036},{"lat":52.080716,"lng":11.709023},{"lat":52.081237,"lng":11.70898}]],"polygons":[],"source":"hejfish_api_map_geojson","confidence":"high"},"links":{"source":"https://www.hejfish.com/d/14321-alte-elbe-kreuzhorst-teil-1-bis-3","hejfish":"https://www.hejfish.com/d/14321-alte-elbe-kreuzhorst-teil-1-bis-3","alleangeln":"https://www.alleangeln.de/gewaesser/alte-elbe-kreuzhorst","website":"http://www.magdeburger-anglerverein.de/","image":null},"fish":["Hecht","Karpfen","Rotauge","Brasse","Aal","Flussbarsch","Schleie","Giebel","Karausche","Laube","Wels"],"metadata":{"merged_fields":{"center":"hejfish","fish":["hejfish","alleangeln"],"description":"hejfish","geometry":"hejfish","water_type":"hejfish"},"sources":{"hejfish":{"platform":"hejfish","geocode_source":"hejfish_api_map_geojson","slug":"alte-elbe-kreuzhorst-teil-1-bis-3","seo_name":"Alte Elbe Kreuzhorst, Teil 1 bis 3","description":"<p><b>3 - 280 - 18 Alte Elbe Kreuzhorst</b></p> <div><b>Lage</b>:</div> <div>Die Alte Elbe Kreuzhorst liegt im Südosten der Stadt Magdeburg östlich der Elbe zwischen den Stadtteilen Fermersleben, Salbke und Pechau am Nordrand des Naturschutzgebietes Kreuzhorst.</div> <div><br></div> <div><b>Besonderheiten</b>:</div> <div>Die Alte Elbe Kreuzhorst ist ein ehemaliger Elbarm ohne Verbindung zur Elbe. Der Altarm erstreckt sich über eine Länge von ca. 4,6 km und hat eine Breite von 40 - 80 m. Der Wasserstand reguliert sich über Grund- und Niederschlagswasser. Durch zunehmende Eutrophierung droht dem Altgewässer insbesondere in den Teilen 2 und 3 baldige Verlandung. Die Alte Elbe ist im Teil 1 noch bis zu 1,5 m tief, meist jedoch flacher. Der Grund ist mit einer dicken Faulschlammschicht bedeckt. Die flacher auslaufenden Ufer der Südseite sind mit breiten Schilfgürteln zugewachsen, an den bis zu 4 m hohen steileren Ufern der Nordseite behindert dichter Baum- und Strauchbewuchs das Angeln Auf weiten Wasserflächen breitet sich im Sommer ein Seerosenteppich aus, im Wasser wuchern dichte Krautfelder. Bei hochsommerlichen Temperaturen und in kalten Wintern kommt es immer wieder zu Fischsterben durch Sauerstoffmangel. </div> <div><b>Achtung! Auf der gesamten Südseite am Rand des NSG Kreuzhorst besteht Angelverbot!</b></div> <div><br></div> <div><b>Erreichbarkeit</b>:</div> <div>Die Alte Elbe Kreuzhorst erreicht man von Magdeburg über Prester auf der Luisenthaler Straße. Radfahrer und Fußgänger kommen von Prester auf dem Elbdamm zum Westende des Angelgewässers. Der Weg entlang Teil 1 ist nur für Radfahrer und Fußgänger zu benutzen. </div> <div><br></div> <div><b>Beangelbare Fischarten:</b></div> <div><u>Hauptfischarten</u> sind Aal, Hecht, Karpfen, Schleie.</div> <p><u>Weitere Arten</u> sind z. B. Barsch, Giebel, Karausche, Plötze, Rotfeder, Ukelei.<br></p>","borders":"<p><b>Achtung! Auf der gesamten Südseite am Rand des NSG Kreuzhorst besteht Angelverbot!</b><br></p>","techniques":["Ansitzangeln","Feedern","Posenangeln","Spinnangeln","Friedfischangeln","Karpfenangeln","Naturköderangeln","Raubfischangeln","Stippangeln"],"manager":{"id":1875,"name":"Magdeburger Anglerverein e. V. - INAKTIV","street":"Beimsstr. 89 a ","postal_code":"39110","city":"Magdeburg","telephone":"+49 391 8113033","email":"info@magdeburger-anglerverein.de","website":"https://www.magdeburger-anglerverein.de/","logo":"https://file.hejfish.com/image/r200x200/63/1a/631a65e4dfec68285fa47ba582239e084f563a01.jpeg","slug":"magdeburger-anglerverein-e-v-inaktiv"},"season_begin":"0001-01-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":false,"boat":false,"belly_boat":false,"digital_ticket":true,"night_fishing":true,"ice_fishing":false,"depth_map":true,"has_gauges":true},"location":{"city":{"id":16881,"name":"Magdeburg"},"district":{"id":239,"name":"Magdeburg"},"state":{"id":17,"name":"Sachsen-Anhalt","slug":"sachsen-anhalt"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"source_last_updated":"2026-05-07T11:44:16.541Z","error":false},"alleangeln":{"platform":"alleangeln","geocode_source":"alleangeln_json_ld","slug":"alte-elbe-kreuzhorst","description":"Alte Elbe (Kreuzhorst) ist ein Altarm in Sachsen-Anhalt in der Nähe von Magdeburg. Das Gewässer wird von unseren Mitgliedern relativ stark befischt und als Top Gewässer bewertet.","followers":144,"catches_count":41,"images_count":3,"website":"http://www.magdeburger-anglerverein.de/","best_method":"Spinnfischen","scraper_version":2,"source_last_updated":"2026-05-11T19:39:10.818Z","error":false}}},"last_updated":"2026-05-11T19:39:10.818Z"}