egt der Fischerverein folgende Schonzeiten fest: Hecht und Zander vom 01.02. bis 31.05.</p><p><b>Mindestmaße:  <br></b>Neben den gesetzlichen Mindestmaßen legt der Fischerverein Wietzendorf folgende Mindestmaße fest:</p><ul><li>Aal: 50 cm </li><li>Barsch: max. 35 cm</li><li>Hecht: 55 cm</li><li>Karpfen: 35 cm</li><li>Schleie: 30-45 cm Entnahmefenster  <br></li><li>Zander: 50 - 65 cm Entnahmefenster</li></ul><p><b>Begrenzung: </b>Pro Angeltag und Angler dürfen zusammen an allen Vereinsgewässern maximal 4 Edelfische und 10 Weißfische entnommen werden. </p><p><b>Fangmeldungen</b>: Fangmeldungen sind online auf hejfish.com unter \"Angelkarten & Käufe\" zu melden. Bitte auch Leermeldungen (nichts gefangen) abgeben. Andernfalls wird keine weitere Karte ausgegeben!</p><p><br></p>","rules_files":[{"id":1195048,"name":"ziegeleiteich-1-bei-wietzendorf-bestimmungen","description":null,"file":"https://api.hejfish.com/files/download/468e8887debe2856426167f30a55ae1715b5d7e5/ziegeleiteich-1-bei-wietzendorf-bestimmungen.pdf"}],"additional_areas":[],"catch_report_required":true}],"manager":{"id":1994,"name":"Fischerverein Wietzendorf e.V.","street":" Auf den Wöhren 15","postal_code":"29649","city":"Wietzendorf","telephone":"","email":"dominic.ahlborn@fischerverein-wietzendorf.de","website":"http://www.fischerverein-wietzendorf.de/","logo":"https://file.hejfish.com/image/r200x200/92/4c/924c18a04f65407cbbf57d3c22f6e4ca7708d346.png","slug":"fischerverein-wietzendorf-e-v"},"season_begin":"0001-04-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":true,"boat":false,"belly_boat":false,"digital_ticket":true,"night_fishing":false,"ice_fishing":false,"depth_map":false,"has_gauges":false},"location":{"city":{"id":12766,"name":"Wietzendorf"},"district":{"id":189,"name":"Heidekreis"},"state":{"id":22,"name":"Niedersachsen","slug":"niedersachsen"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"products":[{"id":1561,"name":"Statistikdaten i