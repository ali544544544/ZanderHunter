ometry":"hejfish","water_type":"hejfish"},"sources":{"hejfish":{"platform":"hejfish","geocode_source":"hejfish_api_map_geojson","slug":"happurger-stausee","seo_name":"Happurger Stausee","description":"<p>Der im Jahre 1955 zum Zwecke der Elektrizitätsgewinnung angelegte Stausee liegt in der idyllischen Mittelgebirgslandschaft der Frankenalb. Der See wird vom Rohrbach und vom Kainsbach gespeist. Das 1958 in Betrieb gegangene Pumpspeicherkraftwerk Happurg des Fränkischen Überlandwerks erzeugt mit dem Wasser des Sees sowie dem dazugehörigen Oberbecken auf dem Deckersberg elektrische Energie. Die Größe des Sees beträgt im Mittel etwa 47 Hektar. Den Namen hat der See von der angrenzenden Ortschaft Happurg. Erbaut wurde er von dem Nürnberger Architekten und Kulturpreisträger der Stadt Nürnberg Franz Reichel.</p> <p>Auf dem Happurger See, der nach Trockenperioden nicht immer voll geflutet ist und dann einen geringeren Wasserstand aufweist, sind Motorboote nicht zugelassen.</p>","borders":"<p>Bitte beachten Sie Bojenkette (Beginn der Speerzone)! </p>\n\n<p>Am Parkplatz \"Wanderparkplatz bei Förrenbach\" gibt es ein Nachtparkverbot! Wer über Nacht am Gewässer bleiben möchte sollte den großen Parkplatz an der Seeterrasse nutzen.</p>\n\n<p>Achtung! Neue temporäre Angelverbotszone an den beiden großen Einläufen Förrenbach und Keinsbach.</p>\n\n<p>Fänge sind auf hejfish.com unter \"Angelkarten &amp; Käufe\" zu melden, andernfalls wird keine weitere Karte ausgegeben! Bitte auch Leermeldungen (nichts gefangen) abgeben!<br></p>\n\n<p>Dieser Fischereierlaubnisschein ist nicht übertragbar.<br><br>Die aktuellen Angelbestimmungen müssen immer mitgeführt werden, digital oder in ausgedruckter Form.<br><br>Beachten Sie die Bestimmungen im Anhang, sowie die interaktive Karte!<b>      </b><br></p>\n\n<p>Link zu Gewässerplan Happurger Stausee @BayernAtlas: <a href=\"https://atlas.bayern.de/?c=679466,5484130&amp;z=17&amp;r=0&amp;l=luftbild_labels,f_e285ea30-8717-11f0-813d-eff55c86a862_2f537c3d-3ed2-4b31-9b1e-072d8a773aba&amp;mid=1\">HIER KLICKEN</a></p>\n\n<h1><b>                     Petri Heil!</b></h1>\n\n<p><b><br></b></p>","techniques":["Ansitzangeln","Feedern","Posenangeln","Fliegenfischen","Friedfischangeln","Karpfenangeln","Naturköderangeln","Raubfischangeln","Spinnangeln","Stippangeln"],"manager":{"id":1596,"name":"Fischereiverband Mittelfranken e.V.","street":"Maiacher Straße 60 d","postal_code":"90441","city":"Nürnberg","telephone":"+49 0911 42480113","email":"info@fv-mfr.de","website":"https://fv-mfr.de","logo":"https://file.hejfish.com/image/r200x200/e0/ab/e0ab875cea8b4b92f0c1cc2ec78590304709f02b.png","slug":"fischereiverband-mittelfranken-e-v"},"season_begin":"0001-01-01","season_end":"0001-12-31","features":{"accessible":false,"public_transport":true,"boat":false,"belly_boat":false,"digital_ticket":true,"night_fishing":true,"ice_fishing":false,"depth_map":true,"has_gauges":true},"location":{"city":{"id":33920,"name":"Hersbruck"},"district":{"id":439,"name":"Kreis Nürnberger Land"},"state":{"id":10,"name":"Bayern","slug":"bayern"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"source_last_updated":"2026-05-07T11:41:19.465Z","error":false},"alleangeln":{"platform":"alleangeln","geocode_source":"alleangeln_json_ld","slug":"happurger-stausee","description":"Happurger Stausee ist ein Stausee in Bayern in der Nähe von Happurg. Das Gewässer wird von unseren Mitgliedern sehr stark befischt und als Top Gewässer bewertet.","followers":319,"catches_count":387,"images_count":40,"best_method":"Grundangeln","source_last_updated":"2026-05-07T11:43:10.221Z","error":false}}},"last_updated":"2026-05-07T11:43:10.221Z"}