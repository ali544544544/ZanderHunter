11.636324},{"lat":52.190889,"lng":11.635594}],[{"lat":52.188993,"lng":11.639274},{"lat":52.188987,"lng":11.638781},{"lat":52.188921,"lng":11.638454},{"lat":52.188793,"lng":11.636834},{"lat":52.188405,"lng":11.636968},{"lat":52.188352,"lng":11.638711},{"lat":52.188335,"lng":11.642563},{"lat":52.188414,"lng":11.642734},{"lat":52.188572,"lng":11.642595},{"lat":52.189276,"lng":11.640766}]],"source":"hejfish_api_map_geojson","confidence":"high"},"links":{"source":"https://www.hejfish.com/d/14335-barrosee-dreieck","hejfish":"https://www.hejfish.com/d/14335-barrosee-dreieck","alleangeln":"https://www.alleangeln.de/gewaesser/barrosee-dreieck","website":"http://www.magdeburger-anglerverein.de/","image":null},"fish":["Rotauge","Flussbarsch","Aal","Brasse","Zander","Hecht","Schleie","Wels","Karpfen","Rotfeder"],"metadata":{"merged_fields":{"center":"hejfish","fish":["hejfish","alleangeln"],"description":"hejfish","geometry":"hejfish","water_type":"hejfish"},"sources":{"hejfish":{"platform":"hejfish","geocode_source":"hejfish_api_map_geojson","slug":"barrosee-dreieck","seo_name":"Barrosee Dreieck","description":"<div><b>Die Gewässer </b></div> <div><b><br></b><b>13 - 280 - 29 Großer Barrosee (Teil 1) und </b></div> <div><div><b>13 - 280 - 31 Barrosee Teil 3 (Dreieck), behindertengerechter Angelplatz</b></div><div><b><br></b><b>werden hier zu besseren Übersicht zusammen aufgeführt.</b></div><div><br></div><div><b>Lage</b>:<br></div><div>Die Barroseen liegen im Norden von Magdeburg unmittelbar südlich der Autobahn A2. N 52° 11' 25\" E 11° 38' 18\"</div><div><br><b>Besonderheiten</b>:</div><div>Die Barroseen sind ehemalige Kiesgruben. Der Große Barrosee hat eine Fläche von 11 ha, der Teil 3 (Dreieck) eine Fläche von 1 ha. Sie haben eine mittlere Tiefe von 4 m (max. 8 m). Die Teile 1 und 3 sind offizielle Angelgewässer, <b>der Teil 2 (Langes Loch) ist in Privatbesitz, Angeln ist dort nicht erlaubt.</b></div><div>Um den Großen Barrosee entstanden in den letzten Jahrzehnten Bungalowsiedlungen und Kleingartenanlagen. Das Privatgelände ist im Süden und Osten durch einen Zaun abgegrenzt, die Zufahrt durch ein Tor versperrt. Kraftfahrzeuge müssen in der Regel außerhalb am Straßenrand geparkt werden. Die privaten Grundstücksgrenzen am See reichen am Südufer bis an die Wasser-</div><div>kante, auf der Ostseite führt ein breiter Fahrweg entlang, dort gibt es einige frei zugängliche Angelstellen. Am nordwestlichen Ufer führt ein Trampelpfad durch dichten Baum- und Strauchwuchs um das Gewässer. Angeln ist dort nur an wenigen Stellen möglich.</div><div>Die Ufer des Dreieck sind dagegen frei zugänglich, überwiegend flach und bieten rundum freie Angelstellen. <b>Am westlichen Ufer befindet sich ein behindertengerechter Angelsteg.</b></div><div><b><br></b></div><div><b>Erreichbarkeit</b>:</div><div>Die Barroseen erreicht man von Süden (Eichenweiler) über den Schöppensteg, von Rothensee aus über die Oebisfelder Str. und die Straße An den Barroseen. Von Norden über Barleben, dort biegt man in die Rothenseer Straße ein und kommt zur Straße An den Barroseen.<br><br></div><div><b>Beangelbare Fischarten:</b></div><div>Die Barroseen haben einen guten Fischbestand aus Aal, Barsch, Blei (Brasse), Güster, Hecht, Karpfen, Plötze und Schleie.</div></div> <div><br></div>","borders":"<p><b>Das gesamte Gewässer darf beangelt werden! </b></p>","techniques":["Ansitzangeln","Feedern","Posenangeln","Spinnangeln","Friedfischangeln","Karpfenangeln","Naturköderangeln","Raubfischangeln","Stippangeln"],"manager":{"id":1875,"name":"Magdeburger Anglerverein e. V. - INAKTIV","street":"Beimsstr. 89 a ","postal_code":"39110","city":"Magdeburg","telephone":"+49 391 8113033","email":"info@magdeburger-anglerverein.de","website":"https://www.magdeburger-anglerverein.de/","logo":"https://file.hejfish.com/image/r200x200/63/1a/631a65e4dfec68285fa47ba582239e084f563a01.jpeg","slug":"magdeburger-anglerverein-e-v-inaktiv"},"season_begin":"0001-01-01","season_end":"0001-12-31","features":{"accessible":true,"public_transport":false,"boat":false,"belly_boat":false,"digital_ticket":true,"night_fishing":true,"ice_fishing":false,"depth_map":true,"has_gauges":false},"location":{"city":{"id":16887,"name":"Magdeburg"},"district":{"id":239,"name":"Magdeburg"},"state":{"id":17,"name":"Sachsen-Anhalt","slug":"sachsen-anhalt"},"country":{"id":2,"name":"Deutschland","code":"de","slug":"deutschland"}},"source_last_updated":"2026-05-07T11:44:17.106Z","error":false},"alleangeln":{"platform":"alleangeln","geocode_source":"alleangeln_json_ld","slug":"barrosee-dreieck","description":"Barrosee Dreieck ist ein Baggersee in Sachsen-Anhalt in der Nähe von Magdeburg. Das Gewässer wird von unseren Mitgliedern relativ stark befischt und als gutes Gewässer bewertet.","followers":117,"catches_count":27,"images_count":10,"website":"http://www.magdeburger-anglerverein.de/","best_method":"Feedern","scraper_version":2,"source_last_updated":"2026-05-11T19:28:02.311Z","error":false}}},"last_updated":"2026-05-11T19:28:02.311Z"}