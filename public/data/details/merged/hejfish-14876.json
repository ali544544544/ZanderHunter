\" text-indent:=\"\" -18.9333px;=\"\" text-transform:=\"\" none;=\"\" white-space:=\"\" widows:=\"\" word-spacing:=\"\" 0px;=\"\" -webkit-text-stroke-width:=\"\" background-color:=\"\" rgb(255,=\"\" 255,=\"\" 255);=\"\" text-decoration-thickness:=\"\" initial;=\"\" text-decoration-style:=\"\" text-decoration-color:=\"\" initial;\"=\"\"></p><p class=\"MsoNoSpacing\" style=\"text-align: justify; text-indent: -14.2pt;\"><br></p><p class=\"MsoNoSpacing\" style=\"text-align:justify;text-indent:-14.2pt;tab-stops:\r\n21.3pt\"><br></p><p class=\"MsoNoSpacing\" style=\"text-align:justify;text-indent:-14.2pt;tab-stops:\r\n21.3pt\"><br></p><p class=\"MsoNoSpacing\" style=\"text-align:justify;text-indent:-14.2pt;tab-stops:\r\n21.3pt\"><o:p><br></o:p></p><p class=\"MsoNoSpacing\" style=\"text-align:justify;text-indent:-14.2pt;tab-stops:\r\n21.3pt\"><o:p><br></o:p></p>","rules_files":[],"additional_areas":[],"catch_report_required":true},{"id":9563,"name":"Tageskarte (Jugend)","category":"DAY","duration":1,"prices":[{"id":101898,"name":"Jugendpreis inkl. Servicegebühr","value":"15,00 EUR","cents":1500,"type":"JUNIOR","valid_from":"2026-04-04","valid_to":"2026-09-30","available_from":"2026-04-04","age":17,"eligible":true}],"licenses":{"required":[],"optional":["Fischereischein / Jugendfischereischein Deutschland","Lichtbild­ausweis für Jugendliche bis zur Vollendung des 18. Lebensjahres"]},"rules_text":"<h3 style=\"text-align:justify;tab-stops:21.3pt\"><b style=\"color: inherit; font-family: inherit;\">Tägliche Fangmenge</b></h3><p class=\"MsoNoSpacing\" style=\"text-align:justify;tab-stops:21.3pt\"><o:p></o:p></p><h4 style=\"text-align:justify;tab-stops:21.3pt\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; 3 Salmoniden&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; </h4><p class=\"MsoNoSpacing\" style=\"text-align:justify;tab-stops:21.3pt\"><o:p></o:p></p><p class=\"MsoNoSpacing\" style=\"text-align:justify;tab-stops:21.3pt\"><b>&nbsp;</b></p><h3 style=\"text-align:justify;tab-stops:21.3pt\"><b>Schonzeiten und Schonmaße&nbsp; &nbsp; &nbsp;</b></h3><h4 style=\"text-align: justify; margin-left: 25px;\">&nbsp;&nbsp;&nbsp;Bachforelle&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;01.10. – 15.03.&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; &nbsp; 30 cm<br>&nbsp; &nbsp;Bachsaibling&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; &nbsp; &nbsp; 01.10. – 15.03.&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;30 cm<br>&nbsp; &nbsp;Regenbogenforelle&nbsp;&nbsp;&nbsp;&nbsp;01.10. – 15.03.&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;30 cm</h4><p class=\"MsoNoSpacing\" style=\"text-align:justify;tab-stops:21.3pt\"><o:p></o:p></p><p class=\"MsoNoSpacing\" style=\"text-align:justify;tab-stops:21.3pt\"><o:p></o:p></p><p class=\"MsoNoSpacing\" style=\"text-align:justify;tab-stops:21.3pt\"><o:p></o:p></p><p class=\"MsoNoSpacing\" style=\"text-align:justify;tab-stops:21.3pt 1.0cm\"><o:p>&nbsp;</o:p></p><h3 style=\"margin-bottom:0cm;margin-bottom:.0001pt;line-height:\r\nnormal;tab-stops:21.3pt 1.0cm 3.0cm 212.65pt\"><span style=\"color:red\">Ganzjährige\r\nSchonzeit:</span></h3><h4 style=\"margin-bottom:0cm;margin-bottom:.0001pt;line-height:\r\nnormal;tab-stops:21.3pt 1.0cm 3.0cm 212.65pt\"><span style=\"color:red\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Elritze, Mühlkoppe, Albino-Fische</span></h4><p class=\"MsoNormal\" style=\"margin-bottom:0cm;margin-bottom:.0001pt;line-height:\r\nnormal;tab-stops:21.3pt 1.0cm 3.0cm 212.65pt\"><o:p>&nbsp;</o:p></p><h3><b>Bedingungen</b></h3><h4 style=\"text-align:justify;tab-stops:21.3pt\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- Den Anordnungen der\r\nFischereiaufseher ist unbedingt Folge zu leisten.<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- Verstöße haben die Einziehung des\r\nErlaubnisscheines zur Folge und ziehen eine Ahndung nach sich.<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- Der Verein haftet für keinerlei\r\nErsatzansprüche, ebenso wenig für Unglücksfälle, Verletzungen,&nbsp;Sachschäden<br>&nbsp; &nbsp; &nbsp; &nbsp; und&nbsp;dergleichen.<br><span style=\"color: inherit; font-family: inherit;\">&nbsp;</span>&nbsp;&nbsp;&nbsp;&nbsp;<span style=\"color: inherit; font-family: inherit;\">- Während Gemeinschaftsveranstaltungen\r\nsind alle übrigen Vereinsgewässer gesperrt.<br></span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- Die Angelsaison beginnt mit dem\r\noffiziellen Anangeln.</h4><p style=\"text-align: justify;\"><br></p><h3 style=\"text-align: left;\"><span style=\"box-sizing: border-box;\"><b>Fangvorschriften</b></span></h3><h5 style=\"text-align: left; margin-left: 25px;\"></h5><h4 style=\"text-align: justify; margin-left: 25px;\"><p style=\"font-size: 14px; text-align: left;\"><span style=\"font-weight: 700;\">&nbsp;- Der Erlaubnisschein gilt nur in Verbindung mit einem gültigen Fischereischein.</span></p><p style=\"margin-left: 25px; font-size: 14px;\"></p><ul style=\"font-size: 14px; text-align: start;\"><ul></ul></ul><p style=\"font-size: 14px; text-align: start;\"></p><p style=\"font-size: 14px; text-align: left;\"><span style=\"font-weight: 700;\">&nbsp;- Das Angeln ist vom Ufer aus und nur mit einer Handangel von 00.00 bis 24.00 Uhr erlaubt.</span></p><p style=\"font-size: 14px; text-align: left;\"><span style=\"font-weight: 700;\">&nbsp;- Erwachsenen in Begleitung eines Kindes (4-6 Jahre) ist das Angeln mit 2 Handangeln gestattet.</span></p><p style=\"font-size: 14px; text-align: left;\"><span style=\"font-weight: 700;\">&nbsp;- Geangelte maßige Fische, sowie untermaßige Fische, die erkennbar verletzt und nicht mehr lebensfähig sind,</span></p><p style=\"font-size: 14px; text-align: left;\"><span style=\"font-weight: 700;\">&nbsp; &nbsp; dürfen nicht zurückgesetzt werden (sie zählen zur Fangmenge).</span></p><p style=\"font-size: 14px; text-align: left;\"><span style=\"font-weight: 700;\">&nbsp;- Jeder in Besitz genommene Fisch ist sofort ordnungsgemäß zu versorgen und in der Fangliste einzutragen.</span></p><p style=\"font-size: 14px; text-align: left;\"><span style=\"font-weight: 700;\">&nbsp;- Jeder Angler ist verpflichtet, entsprechende Geräte zur waidgerechten Landung (z.B. Kescher, Löseschere)</span></p><p style=\"font-size: 14px; text-align: left;\"><span style=\"font-weight: 700;\">&nbsp; &nbsp; immer mitzuführen.</span></p><p style=\"font-size: 14px; text-align: left;\"><span style=\"font-weight: 700;\">- Während Gemeinschaftsveranstaltungen ist das Spinnfischen nicht gestattet.</span></p></h4><p style=\"text-align: justify;\"><br></p><h5 style=\"margin-bottom: 0.0001pt; line-height: normal;\"></h5><h3 style=\"text-align:justify;tab-stops:21.3pt\"><b>Verboten ist:</b></h3><p class=\"MsoNoSpacing\" style=\"text-align:justify;tab-stops:21.3pt\"><o:p></o:p></p>\r\n\r\n<h4 style=\"text-align: justify; margin-left: 25px;\">- Anfüttern<br>- Angeln bei Badebetrieb<br>- Befahren von Grünflächen und\r\ngesperrten Wegen<br>- Setzkescher<br><span style=\"font-size:8.0pt\">- </span>Zelten und\r\nBetreiben von offenen Feuerstellen<br>-\r\nBefahren gesperrter Wege und der Grünanlagen<br>- Abfallentsorgung außerhalb der\r\nAbfalltonnen</h4>","rules_files":[],"additional_areas":[],"catch_report_required":true}],"manager":{"id":1953,"name":"Fischereiverein Ölschnitzsee Windheim e.V.  ","street":"Winterleite 6  ","postal_code":"96361","city":"Steinbach am Wald","telephone":"0171 3500 450","email":"fvoelschnitzsee@web.de","website":"http://xn--fvlschnitzsee-jmb.de/","logo":"https://file.hejfish.com/image/r200x200/6a/9b/6a9bcae840a7b1a961db04d2bd85d54cc951adea.jpg","slug":"fischereiverein-oelschnitzsee-windheim-e-v"},"season_begin":"0001-04-04","season_end":"0001-09-30","features":{"accessible":false,"public_transport":false,"boat":false,"belly_boat":false,"digital_ticket":true,"night_fishing":true,"ice_fishing":false,"depth_map":false,"has_gauges":false},"location":{"city":{"id":35564,"name":"Steinbach am Wald"},"district":{"id":475,"name":"Kreis Kronach"},"state":{"id":10,"name":"Baye